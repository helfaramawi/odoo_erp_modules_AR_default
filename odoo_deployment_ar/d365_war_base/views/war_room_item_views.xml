<odoo>
    <record id="view_war_room_item_tree" model="ir.ui.view">
        <field name="name">war.room.item.tree</field>
        <field name="model">war.room.item</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence"/>
                <field name="name"/>
                <field name="item_type"/>
                <field name="priority"/>
                <field name="status"/>
                <field name="owner_id"/>
                <field name="due_date"/>
            </tree>
        </field>
    </record>

    <record id="view_war_room_item_form" model="ir.ui.view">
        <field name="name">war.room.item.form</field>
        <field name="model">war.room.item</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="sequence" readonly="1"/>
                            <field name="name"/>
                            <field name="item_type"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="owner_id"/>
                            <field name="due_date"/>
                            <field name="related_requirement_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_war_room_items" model="ir.actions.act_window">
        <field name="name">War Room Items</field>
        <field name="res_model">war.room.item</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
