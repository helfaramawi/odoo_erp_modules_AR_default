<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_x_warroom_d365_reverse_engineering_workflow_review_wizard" model="ir.ui.view">
    <field name="name">x_warroom_d365_reverse_engineering.workflow.review.wizard</field>
    <field name="model">workflow.review.wizard</field>
    <field name="arch" type="xml">
      <form string="Workflow Review">
        <group>
          <field name="review_notes"/>
          <field name="reviewer"/>
          <field name="review_date"/>
        </group>
        <footer>
          <button string="Close" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
