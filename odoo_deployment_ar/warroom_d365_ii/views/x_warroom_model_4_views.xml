<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_x_warroom_d365_reverse_engineering_x_warroom_model_4_tree" model="ir.ui.view">
    <field name="name">x_warroom_d365_reverse_engineering.x_warroom_model_4.tree</field>
    <field name="model">x_warroom_model_4</field>
    <field name="arch" type="xml">
      <tree string="X Warroom Model 4">
        <field name="name"/>
        <field name="x_source_ref"/>
        <field name="x_validation_status"/>
        <field name="state"/>
      </tree>
    </field>
  </record>

  <record id="view_x_warroom_d365_reverse_engineering_x_warroom_model_4_search" model="ir.ui.view">
    <field name="name">x_warroom_d365_reverse_engineering.x_warroom_model_4.search</field>
    <field name="model">x_warroom_model_4</field>
    <field name="arch" type="xml">
      <search string="Search X Warroom Model 4">
        <field name="name"/>
        <field name="x_source_ref"/>
        <field name="x_validation_status"/>
        <field name="state"/>
      </search>
    </field>
  </record>

  <record id="view_x_warroom_d365_reverse_engineering_x_warroom_model_4_form" model="ir.ui.view">
    <field name="name">x_warroom_d365_reverse_engineering.x_warroom_model_4.form</field>
    <field name="model">x_warroom_model_4</field>
    <field name="arch" type="xml">
      <form string="X Warroom Model 4">
        <header>
          <button name="action_set_under_review" type="object" string="Under Review" class="oe_highlight"/>
          <button name="action_set_confirmed" type="object" string="Confirmed" class="oe_highlight"/>
          <button name="action_set_rejected" type="object" string="Rejected" class="oe_highlight"/>
          <button name="action_set_pending_validation" type="object" string="Pending Validation" class="oe_highlight"/>
          <button name="action_set_approved_for_build" type="object" string="Approved For Build" class="oe_highlight"/>
          <field name="state" widget="statusbar" statusbar_visible="draft,under_review,confirmed,approved_for_build"/>
        </header>
        <sheet>
          <group>
            <field name="name"/>
            <field name="x_source_ref"/>
            <field name="x_validation_status"/>
          </group>
          <notebook>
            <page string="Traceability">
              <group>
                <label string="Evidence-driven mapping generated by War Room"/>
              </group>
            </page>
            <page string="Implementation Notes">
              <group>
                <label string="Review TODOs before deployment"/>
              </group>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_x_warroom_d365_reverse_engineering_x_warroom_model_4" model="ir.actions.act_window">
    <field name="name">X Warroom Model 4</field>
    <field name="res_model">x_warroom_model_4</field>
    <field name="view_mode">tree,form</field>
    <field name="search_view_id" ref="view_x_warroom_d365_reverse_engineering_x_warroom_model_4_search"/>
  </record>

  <menuitem
    id="menu_x_warroom_d365_reverse_engineering_x_warroom_model_4"
    name="Model 4"
    parent="menu_x_warroom_d365_reverse_engineering_root"
    action="action_x_warroom_d365_reverse_engineering_x_warroom_model_4"
    sequence="50"/>
</odoo>
