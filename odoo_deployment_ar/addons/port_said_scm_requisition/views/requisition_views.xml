<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_requisition_form" model="ir.ui.view">
    <field name="name">port_said.requisition.form</field>
    <field name="model">port_said.requisition</field>
    <field name="arch" type="xml">
      <form string="طلب الاحتياج">
        <header>
          <button name="action_submit"    string="تقديم"                    type="object" class="btn-primary"  invisible="state != 'draft'"/>
          <button name="action_approve"   string="✅ موافقة + إنشاء ارتباط" type="object" class="btn-success" invisible="state != 'submitted'"/>
          <button name="action_create_po"       string="إنشاء أمر توريد" type="object" class="btn-primary"   invisible="state != 'approved'"/>
          <button name="action_print_requisition" string="طباعة الطلب"   type="object" class="btn-secondary" invisible="state == 'draft'"/>
          <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,po_created"/>
        </header>
        <sheet>
          <div class="oe_title"><h1><field name="requisition_number" readonly="1"/></h1></div>
          <group>
            <group string="بيانات الطلب">
              <field name="date_request"/>
              <field name="department_id"/>
              <field name="requested_by"/>
              <field name="urgency"/>
              <field name="fiscal_year"/>
            </group>
            <group string="الموازنة">
              <field name="budget_line"/>
              <field name="budget_position_id"/>
              <field name="available_balance" readonly="1"/>
              <field name="total_amount" readonly="1"/>
              <field name="commitment_id" readonly="1"/>
            </group>
          </group>
          <field name="description" placeholder="وصف الاحتياج..."/>
          <field name="justification" placeholder="مبرر الطلب..."/>
          <field name="line_ids">
            <tree editable="bottom">
              <field name="description"/>
              <field name="qty"/>
              <field name="uom_id"/>
              <field name="estimated_price"/>
              <field name="estimated_amount" readonly="1"/>
            </tree>
          </field>
          <field name="notes"/>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <record id="view_requisition_list" model="ir.ui.view">
    <field name="name">port_said.requisition.list</field>
    <field name="model">port_said.requisition</field>
    <field name="arch" type="xml">
      <tree string="طلبات الاحتياج" decoration-success="state == 'approved'" decoration-warning="state == 'submitted'">
        <field name="state" column_invisible="1"/>
        <field name="requisition_number"/>
        <field name="date_request"/>
        <field name="department_id"/>
        <field name="budget_line"/>
        <field name="total_amount" sum="الإجمالي"/>
        <field name="commitment_id"/>
      </tree>
    </field>
  </record>

  <record id="action_requisition" model="ir.actions.act_window">
    <field name="name">طلبات الاحتياج</field>
    <field name="res_model">port_said.requisition</field>
    <field name="view_mode">tree,form</field>
  </record>

    <!-- Menus managed by port_said_menu -->

  <menuitem id="menu_ps_requisition"
            name="طلبات الاحتياج"
            parent="port_said_menu.menu_ps_30_purchase"
            action="port_said_scm_requisition.action_requisition"
            sequence="31"/>
</odoo>