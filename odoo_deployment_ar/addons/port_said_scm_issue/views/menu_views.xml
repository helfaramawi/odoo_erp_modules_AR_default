<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_issue_permits2" model="ir.actions.act_window">
        <field name="name">أذونات الصرف</field>
        <field name="res_model">stock.issue.permit</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_return_permits2" model="ir.actions.act_window">
        <field name="name">أذونات الارتجاع</field>
        <field name="res_model">stock.return.permit</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_transfer_permits2" model="ir.actions.act_window">
        <field name="name">أذونات التحويل</field>
        <field name="res_model">stock.transfer.permit</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_issue_register_lines2" model="ir.actions.act_window">
        <field name="name">سجل حركات الصرف</field>
        <field name="res_model">stock.issue.register.line</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_scm_issue_root" name="أذونات الصرف والارتجاع"
              sequence="50" web_icon="stock,static/description/icon.png"/>
    <menuitem id="menu_issue_permits" name="أذونات الصرف"
              parent="menu_scm_issue_root" action="action_issue_permits2" sequence="10"/>
    <menuitem id="menu_return_permits" name="أذونات الارتجاع"
              parent="menu_scm_issue_root" action="action_return_permits2" sequence="20"/>
    <menuitem id="menu_transfer_permits" name="أذونات التحويل"
              parent="menu_scm_issue_root" action="action_transfer_permits2" sequence="30"/>
    <menuitem id="menu_issue_register_lines" name="سجل حركات الصرف"
              parent="menu_scm_issue_root" action="action_issue_register_lines2" sequence="40"/>
</odoo>
