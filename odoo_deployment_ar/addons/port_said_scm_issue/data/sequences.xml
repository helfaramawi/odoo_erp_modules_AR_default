<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_issue_permit" model="ir.sequence">
        <field name="name">إذن الصرف</field>
        <field name="code">stock.issue.permit</field>
        <field name="prefix">IP/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="seq_return_permit" model="ir.sequence">
        <field name="name">إذن الارتجاع</field>
        <field name="code">stock.return.permit</field>
        <field name="prefix">RP/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="seq_transfer_permit" model="ir.sequence">
        <field name="name">إذن التحويل</field>
        <field name="code">stock.transfer.permit</field>
        <field name="prefix">TP/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
    <!-- تسلسل سجل حركات الصرف المخزوني -->
    <record id="seq_stock_issue_register" model="ir.sequence">
        <field name="name">سجل حركات الصرف المخزوني</field>
        <field name="code">stock.issue.register</field>
        <field name="prefix">ISR/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
