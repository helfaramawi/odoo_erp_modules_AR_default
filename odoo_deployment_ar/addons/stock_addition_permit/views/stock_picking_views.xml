<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add smart buttons to stock.picking -->
    <record id="view_stock_picking_addition_permit" model="ir.ui.view">
        <field name="name">stock.picking.addition.permit.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_inspections" type="object"
                    class="oe_stat_button" icon="fa-clipboard"
                    invisible="inspection_count == 0">
                    <field name="inspection_count" widget="statinfo" string="فحص"/>
                </button>
                <button name="action_view_addition_permits" type="object"
                    class="oe_stat_button" icon="fa-plus-square"
                    invisible="addition_permit_count == 0">
                    <field name="addition_permit_count" widget="statinfo" string="إذن إضافة"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
