<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Smart button on Purchase Order to show Addition Permits -->
    <record id="view_purchase_order_addition_permit_button" model="ir.ui.view">
        <field name="name">purchase.order.addition.permit.button</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_addition_permits"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-archive"
                        invisible="addition_permit_count == 0">
                    <field name="addition_permit_count"
                           widget="statinfo"
                           string="إذن إضافة"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
