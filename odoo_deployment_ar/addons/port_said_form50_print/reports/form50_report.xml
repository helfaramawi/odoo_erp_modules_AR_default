<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- معاينة استمارة 50 -->
  <record id="action_report_form50_preview" model="ir.actions.report">
    <field name="name">معاينة استمارة 50 ع.ح</field>
    <field name="model">port_said.daftar55</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">port_said_form50_print.report_form50_template</field>
    <field name="report_file">port_said_form50_print.report_form50_template</field>
    <field name="attachment_use" eval="False"/>
    <field name="attachment"/>
    <field name="print_report_name">'معاينة-استمارة-' + (object.sequence_number or '') + '_' + (object.fiscal_year or '')</field>
  </record>

  <!-- طباعة نهائية استمارة 50 -->
  <record id="action_report_form50_final" model="ir.actions.report">
    <field name="name">نهائي استمارة 50 ع.ح</field>
    <field name="model">port_said.daftar55</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">port_said_form50_print.report_form50_final_template</field>
    <field name="report_file">port_said_form50_print.report_form50_final_template</field>
    <field name="attachment_use" eval="False"/>
    <field name="attachment"/>
    <field name="print_report_name">'نهائي-استمارة-' + (object.sequence_number or '') + '_' + (object.fiscal_year or '') + '-50'</field>
  </record>

  <!-- معايرة مواضع الحقول — للمطوّر فقط -->
  <record id="action_report_form50_calibration" model="ir.actions.report">
    <field name="name">معايرة مواضع استمارة 50</field>
    <field name="model">port_said.daftar55</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">port_said_form50_print.report_form50_calibration_template</field>
    <field name="report_file">port_said_form50_print.report_form50_calibration_template</field>
    <field name="attachment_use" eval="False"/>
    <field name="attachment"/>
    <field name="print_report_name">'معايرة-مواضع-استمارة-50'</field>
  </record>

</odoo>
