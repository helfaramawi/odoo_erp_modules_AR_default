<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="paperformat_form50_a4" model="report.paperformat">
    <field name="name">استمارة 50 ع.ح — A4</field>
    <field name="default">False</field>
    <field name="format">A4</field>
    <field name="orientation">Portrait</field>
    <field name="margin_top">0</field>
    <field name="margin_bottom">0</field>
    <field name="margin_left">0</field>
    <field name="margin_right">0</field>
    <field name="header_line">False</field>
    <field name="header_spacing">0</field>
    <field name="dpi">150</field>
  </record>

  <record id="action_report_form50" model="ir.actions.report">
    <field name="name">استمارة 50 ع.ح</field>
    <field name="model">port_said.daftar55</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">port_said_form50_print.report_form50_template</field>
    <field name="report_file">port_said_form50_print.report_form50_template</field>
    <field name="print_report_name">'استمارة-50-' + (object.sequence_number or '')</field>
    <field name="paperformat_id" ref="paperformat_form50_a4"/>
    <field name="attachment_use">False</field>
    <field name="binding_model_id" ref="port_said_daftar55.model_port_said_daftar55"/>
    <field name="binding_type">report</field>
  </record>

  <!-- معاينة — نفس القالب بدون إلزام الطباعة النهائية -->
  <record id="action_report_form50_preview" model="ir.actions.report">
    <field name="name">معاينة استمارة 50 ع.ح</field>
    <field name="model">port_said.daftar55</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">port_said_form50_print.report_form50_template</field>
    <field name="report_file">port_said_form50_print.report_form50_template</field>
    <field name="print_report_name">'معاينة-استمارة-50-' + (object.sequence_number or '')</field>
    <field name="paperformat_id" ref="paperformat_form50_a4"/>
    <field name="attachment_use">False</field>
  </record>

  <!-- طباعة نهائية رسمية -->
  <record id="action_report_form50_final" model="ir.actions.report">
    <field name="name">طباعة نهائية — استمارة 50 ع.ح</field>
    <field name="model">port_said.daftar55</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">port_said_form50_print.report_form50_template</field>
    <field name="report_file">port_said_form50_print.report_form50_template</field>
    <field name="print_report_name">'نهائي-استمارة-50-' + (object.sequence_number or '')</field>
    <field name="paperformat_id" ref="paperformat_form50_a4"/>
    <field name="attachment_use">False</field>
  </record>

</odoo>
