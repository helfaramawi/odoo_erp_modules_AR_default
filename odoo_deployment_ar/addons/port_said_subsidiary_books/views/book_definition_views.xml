<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- Tree -->
  <record id="view_book_tree" model="ir.ui.view">
    <field name="name">port_said.subsidiary.book.tree</field>
    <field name="model">port_said.subsidiary.book</field>
    <field name="arch" type="xml">
      <tree string="الدفاتر المساعدة" decoration-muted="not active">
        <field name="sequence" widget="handle"/>
        <field name="form_number"/>
        <field name="name"/>
        <field name="account_class"/>
        <field name="side"/>
        <field name="scope"/>
        <field name="grouping_key"/>
        <field name="folio_count"/>
        <field name="active" widget="boolean_toggle"/>
      </tree>
    </field>
  </record>

  <!-- Form -->
  <record id="view_book_form" model="ir.ui.view">
    <field name="name">port_said.subsidiary.book.form</field>
    <field name="model">port_said.subsidiary.book</field>
    <field name="arch" type="xml">
      <form string="تعريف دفتر">
        <header>
          <button name="action_print_book" type="object" string="طباعة الدفتر" class="oe_highlight"/>
          <button name="action_open_folios" type="object" string="فتح الفوليوهات"/>
        </header>
        <sheet>
          <div class="oe_button_box" name="button_box">
            <button name="action_open_folios" type="object" class="oe_stat_button" icon="fa-book">
              <field name="folio_count" widget="statinfo" string="فوليوهات"/>
            </button>
          </div>
          <widget name="web_ribbon" title="معطّل" bg_color="bg-danger" invisible="active"/>
          <div class="oe_title">
            <label for="name"/>
            <h1><field name="name" placeholder="اسم الدفتر القانوني"/></h1>
          </div>
          <group>
            <group string="الهوية القانونية">
              <field name="code"/>
              <field name="form_number"/>
              <field name="sequence"/>
              <field name="active" invisible="1"/>
              <field name="company_id" groups="base.group_multi_company"/>
            </group>
            <group string="التسلسل والطباعة">
              <field name="sequence_id"/>
              <field name="folio_size"/>
              <field name="print_template"/>
              <field name="columns_layout"/>
            </group>
          </group>
          <group string="أبعاد التصنيف الثلاثة" col="3">
            <field name="account_class"/>
            <field name="side"/>
            <field name="scope"/>
          </group>
          <group string="قواعد الفلترة على account.move.line">
            <field name="account_classification_ids" widget="many2many_tags"/>
            <field name="journal_ids" widget="many2many_tags" placeholder="كل اليوميات"/>
            <field name="grouping_key"/>
            <field name="include_unposted"/>
          </group>
          <notebook>
            <page string="ملاحظات قانونية">
              <field name="notes"/>
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter">
          <field name="message_follower_ids"/>
          <field name="message_ids"/>
        </div>
      </form>
    </field>
  </record>

  <!-- Search -->
  <record id="view_book_search" model="ir.ui.view">
    <field name="name">port_said.subsidiary.book.search</field>
    <field name="model">port_said.subsidiary.book</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="code"/>
        <field name="form_number"/>
        <separator/>
        <filter string="جارية" name="f_current" domain="[('account_class','=','current')]"/>
        <filter string="نظامية" name="f_memo" domain="[('account_class','=','memo')]"/>
        <filter string="شخصية" name="f_personal" domain="[('account_class','=','personal')]"/>
        <separator/>
        <filter string="مدينة" name="f_dr" domain="[('side','=','debit')]"/>
        <filter string="دائنة" name="f_cr" domain="[('side','=','credit')]"/>
        <separator/>
        <filter string="مفردات" name="f_detail" domain="[('scope','=','detail')]"/>
        <filter string="إجمالي" name="f_totals" domain="[('scope','=','totals')]"/>
        <group expand="1" string="تجميع حسب">
          <filter string="التصنيف" name="g_class" context="{'group_by':'account_class'}"/>
          <filter string="الجانب" name="g_side" context="{'group_by':'side'}"/>
          <filter string="النطاق" name="g_scope" context="{'group_by':'scope'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- Action -->
  <record id="action_book" model="ir.actions.act_window">
    <field name="name">الدفاتر المساعدة</field>
    <field name="res_model">port_said.subsidiary.book</field>
    <field name="view_mode">tree,form</field>
    <field name="search_view_id" ref="view_book_search"/>
  </record>

</odoo>
