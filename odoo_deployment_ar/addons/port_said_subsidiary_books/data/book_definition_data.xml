  <record id="book_memo_dr_totals" model="port_said.subsidiary.book">
    <field name="name">دفتر إجمالي الحسابات النظامية المدينة</field>
    <field name="code">SUB_MEMO_DR_TOTALS</field>
    <field name="form_number">78 مكرر ع.ح</field>
