<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="report_subsidiary_detail">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="folio">
        <t t-call="web.external_layout">
          <div class="page" dir="rtl" style="font-family:'Diwani Letter','Traditional Arabic',serif;">

            <!-- Header — mirror of image 15 layout -->
            <div style="text-align:center; margin-bottom:6px;">
              <h3 style="margin:0;">
                <t t-out="folio.book_id.name"/>
              </h3>
              <div style="font-size:11px;">
                نموذج رقم <t t-out="folio.book_id.form_number"/>
                — محافظة بورسعيد
              </div>
            </div>

            <!-- Identity strip -->
            <table style="width:100%; font-size:10px; margin-bottom:4px;" class="table-borderless">
              <tr>
                <td><strong>السنة المالية:</strong> <t t-out="folio.fiscal_year"/></td>
                <td><strong>الشهر:</strong> <t t-out="dict(folio._fields['period_month'].selection).get(folio.period_month)"/></td>
                <td><strong>رقم الفولية:</strong> <t t-out="folio.folio_number"/></td>
                <td><strong>الحالة:</strong> <t t-out="dict(folio._fields['state'].selection).get(folio.state)"/></td>
              </tr>
              <tr>
                <td t-if="folio.partner_id" colspan="2"><strong>اسم الشريك:</strong> <t t-out="folio.partner_id.name"/></td>
                <td t-if="folio.account_id" colspan="2"><strong>الحساب:</strong> <t t-out="folio.account_id.code"/> — <t t-out="folio.account_id.name"/></td>
              </tr>
            </table>

            <!-- Carry-forward strip -->
            <table style="width:100%; font-size:10px; margin-bottom:4px; border:1px solid #000;">
              <tr style="background:#f0f0f0;">
                <td style="padding:3px; border:1px solid #000; width:25%;"><strong>نقل من قبله</strong></td>
                <td style="padding:3px; border:1px solid #000; width:25%;"><strong>حركة مدينة</strong></td>
                <td style="padding:3px; border:1px solid #000; width:25%;"><strong>حركة دائنة</strong></td>
                <td style="padding:3px; border:1px solid #000; width:25%;"><strong>نقل بعده</strong></td>
              </tr>
              <tr>
                <td style="padding:3px; border:1px solid #000; text-align:left;">
                  <span t-field="folio.opening_balance" t-options="{'widget': 'monetary', 'display_currency': folio.currency_id}"/>
                </td>
                <td style="padding:3px; border:1px solid #000; text-align:left;">
                  <span t-field="folio.period_debit" t-options="{'widget': 'monetary', 'display_currency': folio.currency_id}"/>
                </td>
                <td style="padding:3px; border:1px solid #000; text-align:left;">
                  <span t-field="folio.period_credit" t-options="{'widget': 'monetary', 'display_currency': folio.currency_id}"/>
                </td>
                <td style="padding:3px; border:1px solid #000; text-align:left; font-weight:bold;">
                  <span t-field="folio.closing_balance" t-options="{'widget': 'monetary', 'display_currency': folio.currency_id}"/>
                </td>
              </tr>
            </table>

            <!-- Detail lines table — columns mirror image 15 -->
            <table style="width:100%; font-size:9.5px; border-collapse:collapse;" class="table">
              <thead>
                <tr style="background:#dddddd;">
                  <th style="padding:3px; border:1px solid #000;">رقم الشطب</th>
                  <th style="padding:3px; border:1px solid #000;">تاريخ الشطب</th>
                  <th style="padding:3px; border:1px solid #000;">بيان الاستمارة</th>
                  <th style="padding:3px; border:1px solid #000;">المرجع</th>
                  <th style="padding:3px; border:1px solid #000;">مدين</th>
                  <th style="padding:3px; border:1px solid #000;">دائن</th>
                  <th style="padding:3px; border:1px solid #000;">رصيد</th>
                </tr>
              </thead>
              <tbody>
                <t t-set="running" t-value="folio.opening_balance"/>
                <t t-foreach="folio.move_line_ids" t-as="line">
                  <t t-set="running" t-value="running + line.debit - line.credit"/>
                  <tr>
                    <td style="padding:2px; border:1px solid #000;"><t t-out="line.move_id.name"/></td>
                    <td style="padding:2px; border:1px solid #000;"><t t-out="line.date"/></td>
                    <td style="padding:2px; border:1px solid #000;"><t t-out="line.name or line.move_id.ref or ''"/></td>
                    <td style="padding:2px; border:1px solid #000;"><t t-out="line.ref or ''"/></td>
                    <td style="padding:2px; border:1px solid #000; text-align:left;">
                      <span t-if="line.debit" t-out="'%.2f' % line.debit"/>
                    </td>
                    <td style="padding:2px; border:1px solid #000; text-align:left;">
                      <span t-if="line.credit" t-out="'%.2f' % line.credit"/>
                    </td>
                    <td style="padding:2px; border:1px solid #000; text-align:left;">
                      <t t-out="'%.2f' % running"/>
                    </td>
                  </tr>
                </t>
                <!-- Totals row -->
                <tr style="background:#f5f5f5; font-weight:bold;">
                  <td colspan="4" style="padding:3px; border:1px solid #000; text-align:center;">
                    إجمالي حركة الشهر
                  </td>
                  <td style="padding:3px; border:1px solid #000; text-align:left;">
                    <span t-field="folio.period_debit" t-options="{'widget': 'monetary', 'display_currency': folio.currency_id}"/>
                  </td>
                  <td style="padding:3px; border:1px solid #000; text-align:left;">
                    <span t-field="folio.period_credit" t-options="{'widget': 'monetary', 'display_currency': folio.currency_id}"/>
                  </td>
                  <td style="padding:3px; border:1px solid #000; text-align:left;">
                    <span t-field="folio.closing_balance" t-options="{'widget': 'monetary', 'display_currency': folio.currency_id}"/>
                  </td>
                </tr>
              </tbody>
            </table>

            <!-- Signature strip -->
            <table style="width:100%; margin-top:30px; font-size:10px;" class="table-borderless">
              <tr>
                <td style="text-align:center;">
                  <div>موظف الشطب</div>
                  <div style="margin-top:25px; border-top:1px solid #000; padding-top:3px;">
                    <t t-out="folio.crossout_signed_by or '............................'"/>
                  </div>
                </td>
                <td style="text-align:center;">
                  <div>رئيس الحسابات</div>
                  <div style="margin-top:25px; border-top:1px solid #000; padding-top:3px;">
                    <t t-out="folio.accounts_head_signed_by or '............................'"/>
                  </div>
                </td>
                <td style="text-align:center;">
                  <div>المراجع المالي</div>
                  <div style="margin-top:25px; border-top:1px solid #000; padding-top:3px;">
                    ............................
                  </div>
                </td>
              </tr>
            </table>

            <div style="text-align:center; font-size:9px; margin-top:15px;">
              نُقِل بعده — يحوَّل الرصيد <span t-field="folio.closing_balance"/>
              إلى الفولية اللاحقة من نفس الدفتر
            </div>

          </div>
          <p style="page-break-after: always;"/>
        </t>
      </t>
    </t>
  </template>

</odoo>
