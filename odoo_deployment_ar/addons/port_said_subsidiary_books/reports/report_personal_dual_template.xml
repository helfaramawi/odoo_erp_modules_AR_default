<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="report_personal_dual">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="folio">
        <t t-call="web.external_layout">
          <div class="page" dir="rtl" style="font-family:'Diwani Letter','Traditional Arabic',serif;">

            <!-- Title -->
            <div style="text-align:center; margin-bottom:6px;">
              <h3 style="margin:0;">دفتر الحسابات</h3>
              <div style="font-size:11px;">
                الشخصية ( ذو الخانتين )
                — نموذج رقم 29 حسابات
              </div>
              <div style="font-size:11px;">
                <strong>اسم:</strong> <t t-out="folio.partner_id.name"/>
                — <strong>رقم الفولية:</strong> <t t-out="folio.folio_number"/>
                — <strong>الشهر:</strong> <t t-out="dict(folio._fields['period_month'].selection).get(folio.period_month)"/>
                <t t-out="folio.fiscal_year"/>
              </div>
            </div>

            <!-- Two-sided table: منه (Dr) on right, له (Cr) on left.
                 In RTL Arabic forms the convention is right side = منه (debit/from)
                 and left side = له (credit/to). -->
            <table style="width:100%; font-size:9px; border-collapse:collapse; border:2px solid #000;">
              <thead>
                <tr style="background:#dddddd; text-align:center;">
                  <th colspan="6" style="padding:4px; border:1px solid #000; background:#c8e6c9;">منه (الجانب المدين)</th>
                  <th colspan="6" style="padding:4px; border:1px solid #000; background:#ffcdd2;">له (الجانب الدائن)</th>
                </tr>
                <tr style="background:#f0f0f0;">
                  <!-- منه = Debit -->
                  <th style="padding:2px; border:1px solid #000;">الباقي الشهري</th>
                  <th style="padding:2px; border:1px solid #000;">تاريخ</th>
                  <th style="padding:2px; border:1px solid #000;">رقم إذن الصرف</th>
                  <th style="padding:2px; border:1px solid #000;">بيان</th>
                  <th style="padding:2px; border:1px solid #000;">المفردات</th>
                  <th style="padding:2px; border:1px solid #000;">الإجمالي</th>
                  <!-- له = Credit -->
                  <th style="padding:2px; border:1px solid #000;">الباقي الشهري</th>
                  <th style="padding:2px; border:1px solid #000;">تاريخ</th>
                  <th style="padding:2px; border:1px solid #000;">رقم إذن التسوية</th>
                  <th style="padding:2px; border:1px solid #000;">بيان</th>
                  <th style="padding:2px; border:1px solid #000;">المفردات</th>
                  <th style="padding:2px; border:1px solid #000;">الإجمالي</th>
                </tr>
              </thead>
              <tbody>
                <!-- Build separated debit / credit lists -->
                <t t-set="dr_lines" t-value="folio.move_line_ids.filtered(lambda l: l.debit > 0)"/>
                <t t-set="cr_lines" t-value="folio.move_line_ids.filtered(lambda l: l.credit > 0)"/>
                <t t-set="max_rows" t-value="max(len(dr_lines), len(cr_lines), 5)"/>
                <t t-set="dr_running" t-value="folio.opening_balance if folio.opening_balance > 0 else 0"/>
                <t t-set="cr_running" t-value="-folio.opening_balance if folio.opening_balance &lt; 0 else 0"/>

                <t t-foreach="range(max_rows)" t-as="i">
                  <t t-set="dr" t-value="dr_lines[i] if i &lt; len(dr_lines) else None"/>
                  <t t-set="cr" t-value="cr_lines[i] if i &lt; len(cr_lines) else None"/>
                  <t t-if="dr">
                    <t t-set="dr_running" t-value="dr_running + dr.debit"/>
                  </t>
                  <t t-if="cr">
                    <t t-set="cr_running" t-value="cr_running + cr.credit"/>
                  </t>
                  <tr>
                    <!-- منه (Debit) -->
                    <td style="padding:2px; border:1px solid #000; text-align:left; font-size:8px;">
                      <t t-if="dr"><t t-out="'%.2f' % dr_running"/></t>
                    </td>
                    <td style="padding:2px; border:1px solid #000;">
                      <t t-if="dr"><t t-out="dr.date"/></t>
                    </td>
                    <td style="padding:2px; border:1px solid #000;">
                      <t t-if="dr"><t t-out="dr.move_id.name"/></t>
                    </td>
                    <td style="padding:2px; border:1px solid #000; font-size:8px;">
                      <t t-if="dr"><t t-out="dr.name or dr.move_id.ref"/></t>
                    </td>
                    <td style="padding:2px; border:1px solid #000; text-align:left; font-size:8px;">
                      <t t-if="dr"><t t-out="'%.2f' % dr.debit"/></t>
                    </td>
                    <td style="padding:2px; border:1px solid #000; text-align:left; font-size:8px;">
                      <t t-if="dr"><t t-out="'%.2f' % dr.debit"/></t>
                    </td>
                    <!-- له (Credit) -->
                    <td style="padding:2px; border:1px solid #000; text-align:left; font-size:8px;">
                      <t t-if="cr"><t t-out="'%.2f' % cr_running"/></t>
                    </td>
                    <td style="padding:2px; border:1px solid #000;">
                      <t t-if="cr"><t t-out="cr.date"/></t>
                    </td>
                    <td style="padding:2px; border:1px solid #000;">
                      <t t-if="cr"><t t-out="cr.move_id.name"/></t>
                    </td>
                    <td style="padding:2px; border:1px solid #000; font-size:8px;">
                      <t t-if="cr"><t t-out="cr.name or cr.move_id.ref"/></t>
                    </td>
                    <td style="padding:2px; border:1px solid #000; text-align:left; font-size:8px;">
                      <t t-if="cr"><t t-out="'%.2f' % cr.credit"/></t>
                    </td>
                    <td style="padding:2px; border:1px solid #000; text-align:left; font-size:8px;">
                      <t t-if="cr"><t t-out="'%.2f' % cr.credit"/></t>
                    </td>
                  </tr>
                </t>

                <!-- Totals row: نقل بعده -->
                <tr style="background:#f5f5f5; font-weight:bold;">
                  <td colspan="6" style="padding:3px; border:2px solid #000; text-align:center;">
                    إجمالي مدين: <t t-out="'%.2f' % folio.period_debit"/>
                    — نقل بعده مدين: <t t-out="'%.2f' % max(folio.closing_balance, 0)"/>
                  </td>
                  <td colspan="6" style="padding:3px; border:2px solid #000; text-align:center;">
                    إجمالي دائن: <t t-out="'%.2f' % folio.period_credit"/>
                    — نقل بعده دائن: <t t-out="'%.2f' % max(-folio.closing_balance, 0)"/>
                  </td>
                </tr>
              </tbody>
            </table>

            <!-- Signatures (matching paper book convention) -->
            <table style="width:100%; margin-top:30px; font-size:10px;" class="table-borderless">
              <tr>
                <td style="text-align:center;">
                  <div>الكاتب المنوط</div>
                  <div style="margin-top:25px; border-top:1px solid #000; padding-top:3px;">
                    <t t-out="folio.crossout_signed_by or '............................'"/>
                  </div>
                </td>
                <td style="text-align:center;">
                  <div>رئيس الحسابات</div>
                  <div style="margin-top:25px; border-top:1px solid #000; padding-top:3px;">
                    <t t-out="folio.accounts_head_signed_by or '............................'"/>
                  </div>
                </td>
                <td style="text-align:center;">
                  <div>الختم الرسمي</div>
                  <div style="margin-top:25px; border-top:1px solid #000; padding-top:3px;">
                    ............................
                  </div>
                </td>
              </tr>
            </table>

            <div style="text-align:center; font-size:9px; margin-top:15px;">
              نُقِل بعده / يُحوَّل إلى صفحة <t t-out="folio.folio_number"/> + 1
              من نفس الدفتر — رصيد الترحيل (مدين/دائن):
              <t t-out="'%.2f' % folio.closing_balance"/>
            </div>

          </div>
          <p style="page-break-after: always;"/>
        </t>
      </t>
    </t>
  </template>

</odoo>
