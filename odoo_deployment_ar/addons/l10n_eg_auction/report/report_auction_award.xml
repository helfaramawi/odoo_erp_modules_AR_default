<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_auction_award" model="ir.actions.report">
        <field name="name">إخطار الترسية - Award Notification</field>
        <field name="model">auction.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_eg_auction.report_auction_award_template</field>
        <field name="print_report_name">'إخطار الترسية - ' + (object.name or '')</field>
        <field name="binding_model_id" ref="model_auction_request"/>
<field name="paperformat_id" ref="l10n_eg_auction.paperformat_gov_a4"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_auction_award_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                
                    <t t-call="web.external_layout">
                
                    <div class="page" style="direction:rtl;font-family:'Amiri','Noto Naskh Arabic',Arial,sans-serif;font-size:12pt;">
<style>
    .o_company_logo,.o_address_name,.o_report_layout_header,header.o_report_layout_header,
    .odoo-header,.header-content,footer,.footer,.o_footer{display:none!important;}
    .page{margin-top:0!important;padding-top:0!important;}
</style>

                        
                        <table style="width:100%;border-collapse:collapse;margin-bottom:6px;border-bottom:2px solid #000;padding-bottom:6px;">
                            <tr>
                                <td style="width:78px;text-align:center;vertical-align:top;">&#160;</td>
                                <td style="text-align:center;vertical-align:middle;">
                                    <div style="font-size:13pt;font-weight:bold;">جمهورية مصر العربية</div>
                                    <div style="font-size:12pt;font-weight:bold;">محافظة بورسعيد</div>
                                    <div style="font-size:11pt;">الإدارة العامة للشؤون المالية والإدارية</div>
                                    <div style="font-size:11pt;font-weight:bold;">إدارة التعاقدات</div>
                                </td>
                                <td style="width:78px;text-align:center;vertical-align:middle;">
                                    <img src="data:image/png;base64," style="width:70px;height:70px;object-fit:contain;" alt="محافظة بورسعيد"/>
                                </td>
                            </tr>
                        </table>
                        <h2 style="text-align:center;text-decoration:underline;margin-bottom:20px;">إخطار الترسية</h2>

                        <table style="width:100%;border-collapse:collapse;margin-bottom:16px;">
                            <tr>
                                <td style="border:1px solid #000;padding:7px;background:#f0f0f0;font-weight:bold;width:30%;">رقم المزاد</td>
                                <td style="border:1px solid #000;padding:7px;"><t t-esc="doc.name"/></td>
                                <td style="border:1px solid #000;padding:7px;background:#f0f0f0;font-weight:bold;width:20%;">تاريخ الإخطار</td>
                                <td style="border:1px solid #000;padding:7px;"><t t-esc="doc.award_notification_date"/></td>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000;padding:7px;background:#f0f0f0;font-weight:bold;">نوع المزاد</td>
                                <td style="border:1px solid #000;padding:7px;">
                                    <t t-if="doc.auction_type == 'sale'">بيع</t>
                                    <t t-else="">إيجار / حق انتفاع</t>
                                </td>
                                <td style="border:1px solid #000;padding:7px;background:#f0f0f0;font-weight:bold;">طريقة الطرح</td>
                                <td style="border:1px solid #000;padding:7px;">
                                    <t t-if="doc.tender_method == 'public'">مزايدة عامة</t>
                                    <t t-elif="doc.tender_method == 'local'">مزايدة محلية</t>
                                    <t t-else="">اتفاق مباشر</t>
                                </td>
                            </tr>
                        </table>

                        <p style="margin-bottom:14px;line-height:1.8;">
                            <strong>يُشعر </strong>السيد/ <strong><t t-esc="doc.awarded_partner_id.name"/></strong>
                            بأنه قد تمت الترسية عليه في مزاد رقم (<t t-esc="doc.name"/>)
                            المنعقد بتاريخ <t t-esc="doc.auction_date"/>
                            بمبلغ <strong><t t-esc="'{:,.2f}'.format(doc.awarded_amount)"/> جنيه مصري</strong>
                            عن: <t t-esc="doc.asset_description or doc.product_id.name or doc.description or ''"/>
                        </p>

                        <t t-if="doc.auction_type == 'sale'">
                            <p style="line-height:1.8;">
                                يرجى التفضل بتسديد المبلغ المستحق والتوقيع على عقد البيع خلال
                                <strong>ثلاثة أيام عمل</strong> من تاريخ هذا الإخطار.
                                رقم أمر البيع: <strong><t t-esc="doc.sale_order_id.name if doc.sale_order_id else '—'"/></strong>
                            </p>
                        </t>
                        <t t-else="">
                            <p style="line-height:1.8;">
                                يرجى التفضل بتسديد التأمين النهائي والتوقيع على عقد الإيجار خلال
                                <strong>أسبوع</strong> من تاريخ هذا الإخطار.
                                رقم العقد: <strong><t t-esc="doc.lease_contract_id.name if doc.lease_contract_id else '—'"/></strong>
                            </p>
                        </t>

                        <div style="margin-top:40px;">
                            <table style="width:100%;border-collapse:collapse;">
                                <tr>
                                    <td style="border:1px solid #000;padding:20px 15px;text-align:center;width:50%;">
                                        <p style="font-weight:bold;margin:0;">مدير إدارة التعاقدات</p>
                                        <p style="margin-top:40px;color:#555;">التوقيع: .........................</p>
                                        <p style="color:#555;">التاريخ: .........................</p>
                                    </td>
                                    <td style="border:1px solid #000;padding:20px 15px;text-align:center;width:50%;">
                                        <p style="font-weight:bold;margin:0;">الفائز بالمزاد - <t t-esc="doc.awarded_partner_id.name"/></p>
                                        <p style="margin-top:40px;color:#555;">التوقيع: .........................</p>
                                        <p style="color:#555;">التاريخ: .........................</p>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        
                        <div style="margin-top:6px;font-size:8pt;color:#555;text-align:center;border-top:1px solid #ccc;padding-top:4px;">
                            نظام أوبو إيآر بي — Paradise AI Solutions طُبع بتاريخ: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d-%m-%Y %H:%M')"/> إخطار الترسية — محافظة بورسعيد
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
