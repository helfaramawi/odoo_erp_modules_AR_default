<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_auction_request" model="ir.sequence">
        <field name="name">تسلسل رقم المزاد</field>
        <field name="code">auction.request</field>
        <field name="prefix">MZD/%(year)s/</field>
        <field name="padding">5</field>
        <field name="use_date_range">True</field>
    </record>
    <record id="seq_auction_lease_contract" model="ir.sequence">
        <field name="name">تسلسل رقم عقد الإيجار</field>
        <field name="code">auction.lease.contract</field>
        <field name="prefix">EQD/%(year)s/</field>
        <field name="padding">5</field>
        <field name="use_date_range">True</field>
    </record>

    <!-- Custom paperformat: A4 no header spacing for government forms -->
    <record id="paperformat_gov_a4" model="report.paperformat">
        <field name="name">A4 حكومة مصر — بدون رأس</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>
</odoo>
