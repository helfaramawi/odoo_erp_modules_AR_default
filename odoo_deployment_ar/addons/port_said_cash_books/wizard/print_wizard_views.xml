<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_cash_print_wizard_form" model="ir.ui.view">
    <field name="name">port_said.cash.print.wizard.form</field>
    <field name="model">port_said.cash.print.wizard</field>
    <field name="arch" type="xml">
      <form string="طباعة دفتر نقدي/بنكي">
        <sheet>
          <group>
            <group>
              <field name="book_id" options="{'no_create': True}"/>
              <field name="fiscal_year"/>
            </group>
            <group>
              <field name="period_month"/>
              <field name="only_closed"/>
            </group>
          </group>
        </sheet>
        <footer>
          <button name="action_print" type="object" string="طباعة" class="oe_highlight"/>
          <button special="cancel" string="إلغاء"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_cash_print_wizard" model="ir.actions.act_window">
    <field name="name">طباعة دفتر</field>
    <field name="res_model">port_said.cash.print.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>

  <menuitem id="menu_cash_print"
            name="طباعة دفتر"
            parent="menu_cash_root"
            action="action_cash_print_wizard"
            sequence="60"/>

</odoo>
