<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- التسلسل الخاص بأوامر الدفع الواردة -->
  <record id="seq_payment_order" model="ir.sequence">
    <field name="name">أوامر الدفع الواردة</field>
    <field name="code">port_said.payment_order</field>
    <field name="prefix">PO-IN/%(year)s/</field>
    <field name="padding">4</field>
    <field name="use_date_range">True</field>
    <field name="company_id" eval="False"/>
  </record>

  <!-- التسلسل الخاص بالكفالات -->
  <record id="seq_surety" model="ir.sequence">
    <field name="name">الكفالات</field>
    <field name="code">port_said.surety</field>
    <field name="prefix">SUR/%(year)s/</field>
    <field name="padding">4</field>
    <field name="use_date_range">True</field>
    <field name="company_id" eval="False"/>
  </record>

  <!-- Cron jobs للفوليوهات -->
  <record id="cron_cash_generate_monthly" model="ir.cron">
    <field name="name">دفاتر نقدية/بنكي — توليد فوليوهات شهرية</field>
    <field name="model_id" ref="model_port_said_cash_folio"/>
    <field name="state">code</field>
    <field name="code">model.cron_generate_monthly_folios()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">months</field>
    <field name="numbercall">-1</field>
    <field name="active" eval="True"/>
  </record>

  <record id="cron_cash_recompute_open" model="ir.cron">
    <field name="name">دفاتر نقدية/بنكي — إعادة حساب الفوليوهات المفتوحة</field>
    <field name="model_id" ref="model_port_said_cash_folio"/>
    <field name="state">code</field>
    <field name="code">model.cron_recompute_open_folios()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">days</field>
    <field name="numbercall">-1</field>
    <field name="active" eval="True"/>
  </record>

</odoo>
