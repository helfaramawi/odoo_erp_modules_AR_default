<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_transfer_folio_tree" model="ir.ui.view">
    <field name="name">port_said.cash_transfer.folio.tree</field>
    <field name="model">port_said.cash_transfer.folio</field>
    <field name="arch" type="xml">
      <tree string="فوليوهات حركة النقود"
            decoration-info="state == 'draft'"
            decoration-success="state == 'audited'"
            decoration-muted="state == 'archived'">
        <field name="folio_number"/>
        <field name="direction"/>
        <field name="fiscal_year"/>
        <field name="period_month"/>
        <field name="opening_cumulative" sum="إجمالي"/>
        <field name="total_confirmed" sum="إجمالي"/>
        <field name="total_disputed" sum="إجمالي" optional="show"/>
        <field name="total_lost" sum="إجمالي" optional="show"/>
        <field name="closing_cumulative" sum="إجمالي"/>
        <field name="transfer_count"/>
        <field name="state"/>
      </tree>
    </field>
  </record>

  <record id="view_transfer_folio_form" model="ir.ui.view">
    <field name="name">port_said.cash_transfer.folio.form</field>
    <field name="model">port_said.cash_transfer.folio</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_refresh" type="object" string="تحديث التحويلات"
                  invisible="state != 'draft'"/>
          <button name="action_close" type="object" string="إقفال شهري"
                  invisible="state != 'draft'" class="oe_highlight"/>
          <button name="action_audit" type="object" string="اعتماد المراجعة"
                  invisible="state != 'closed'"
                  groups="account.group_account_manager"/>
          <button name="action_reopen" type="object" string="إعادة فتح"
                  invisible="state == 'draft'"
                  groups="account.group_account_manager"
                  confirm="إعادة فتح إجراء استثنائي يُسجَّل."/>
          <field name="state" widget="statusbar"
                 statusbar_visible="draft,closed,audited,archived"/>
        </header>
        <sheet>
          <div class="oe_title">
            <label for="folio_number" string="رقم الفولية"/>
            <h1><field name="folio_number" readonly="1"/></h1>
          </div>
          <group>
            <group>
              <field name="direction" readonly="state != 'draft'"/>
              <field name="fiscal_year" readonly="state != 'draft'"/>
              <field name="period_month" readonly="state != 'draft'"/>
              <field name="date_from" readonly="state != 'draft'"/>
              <field name="date_to" readonly="state != 'draft'"/>
            </group>
            <group>
              <field name="previous_folio_id" readonly="1"/>
              <field name="transfer_count" readonly="1"/>
              <field name="currency_id" invisible="1"/>
            </group>
          </group>
          <group string="الإجماليات" col="5">
            <field name="opening_cumulative" readonly="state != 'draft'"/>
            <field name="total_confirmed" readonly="1"/>
            <field name="total_disputed" readonly="1"/>
            <field name="total_lost" readonly="1"/>
            <field name="closing_cumulative" readonly="1"/>
          </group>
          <notebook>
            <page string="التحويلات">
              <field name="transfer_ids" readonly="1">
                <tree>
                  <field name="sequence_number"/>
                  <field name="transfer_date"/>
                  <field name="sender_employee_id"/>
                  <field name="receiver_unit_name"/>
                  <field name="amount"/>
                  <field name="state"/>
                </tree>
              </field>
            </page>
            <page string="التواقيع والإقفال">
              <group>
                <group>
                  <field name="cashier_signed_by"/>
                  <field name="accounts_head_signed_by"/>
                </group>
                <group>
                  <field name="closed_by" readonly="1"/>
                  <field name="closed_date" readonly="1"/>
                </group>
              </group>
            </page>
            <page string="ملاحظات">
              <field name="notes"/>
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter">
          <field name="message_follower_ids"/>
          <field name="activity_ids"/>
          <field name="message_ids"/>
        </div>
      </form>
    </field>
  </record>

  <record id="view_transfer_folio_search" model="ir.ui.view">
    <field name="name">port_said.cash_transfer.folio.search</field>
    <field name="model">port_said.cash_transfer.folio</field>
    <field name="arch" type="xml">
      <search>
        <field name="folio_number"/>
        <field name="fiscal_year"/>
        <separator/>
        <filter string="مرسلة" name="f_out" domain="[('direction','=','outgoing')]"/>
        <filter string="واردة" name="f_in" domain="[('direction','=','incoming')]"/>
        <separator/>
        <filter string="مفتوحة" name="f_draft" domain="[('state','=','draft')]"/>
        <filter string="مُقفَلة" name="f_closed" domain="[('state','=','closed')]"/>
        <filter string="مراجَعة" name="f_audited" domain="[('state','=','audited')]"/>
        <group expand="1" string="تجميع حسب">
          <filter string="الاتجاه" name="g_dir" context="{'group_by':'direction'}"/>
          <filter string="السنة المالية" name="g_fy" context="{'group_by':'fiscal_year'}"/>
          <filter string="الشهر" name="g_month" context="{'group_by':'period_month'}"/>
          <filter string="الحالة" name="g_state" context="{'group_by':'state'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="action_transfer_folio" model="ir.actions.act_window">
    <field name="name">فوليوهات حركة النقود</field>
    <field name="res_model">port_said.cash_transfer.folio</field>
    <field name="view_mode">tree,form</field>
    <field name="search_view_id" ref="view_transfer_folio_search"/>
  </record>

</odoo>
