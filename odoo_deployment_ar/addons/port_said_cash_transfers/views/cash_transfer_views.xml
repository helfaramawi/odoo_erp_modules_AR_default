<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_cash_transfer_tree" model="ir.ui.view">
    <field name="name">port_said.cash_transfer.tree</field>
    <field name="model">port_said.cash_transfer</field>
    <field name="arch" type="xml">
      <tree string="حركات النقود"
            decoration-info="state in ['draft','prepared']"
            decoration-warning="state == 'in_transit'"
            decoration-success="state in ['confirmed','closed']"
            decoration-danger="state in ['disputed','lost']"
            decoration-muted="state == 'cancelled'">
        <field name="sequence_number"/>
        <field name="transfer_date"/>
        <field name="direction"/>
        <field name="sender_employee_id" optional="show"/>
        <field name="receiver_unit_name"/>
        <field name="amount" sum="إجمالي"/>
        <field name="purpose" optional="hide"/>
        <field name="state"/>
      </tree>
    </field>
  </record>

  <record id="view_cash_transfer_form" model="ir.ui.view">
    <field name="name">port_said.cash_transfer.form</field>
    <field name="model">port_said.cash_transfer</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_prepare" type="object" string="إعداد التحويل"
                  invisible="state != 'draft'" class="oe_highlight"/>
          <button name="action_dispatch" type="object" string="إرسال"
                  invisible="state != 'prepared'" class="oe_highlight"/>
          <button name="action_mark_delivered" type="object" string="تأكيد التسليم"
                  invisible="state != 'in_transit'" class="oe_highlight"/>
          <button name="action_confirm" type="object" string="تأكيد الاستلام"
                  invisible="state != 'delivered'" class="oe_highlight"/>
          <button name="action_dispute" type="object" string="فتح تنازع"
                  invisible="state != 'delivered'"/>
          <button name="action_resolve_dispute" type="object" string="تسوية التنازع"
                  invisible="state != 'disputed'"
                  groups="account.group_account_manager"/>
          <button name="action_report_lost" type="object" string="إبلاغ عن فقدان"
                  invisible="state not in ['in_transit','disputed']"
                  groups="account.group_account_manager"
                  confirm="هذا إجراء استثنائي يتطلب محضر شرطة."/>
          <button name="action_close" type="object" string="إغلاق الملف"
                  invisible="state not in ['confirmed','lost','cancelled']"/>
          <button name="action_cancel" type="object" string="إلغاء"
                  invisible="state in ['delivered','confirmed','closed','cancelled','lost']"/>
          <field name="state" widget="statusbar"
                 statusbar_visible="draft,prepared,in_transit,delivered,confirmed,closed"/>
        </header>
        <sheet>
          <div class="oe_title">
            <label for="sequence_number" string="رقم بالدفتر"/>
            <h1><field name="sequence_number" readonly="1"/></h1>
          </div>
          <group>
            <group string="التحويل">
              <field name="direction" readonly="state != 'draft'"/>
              <field name="transfer_date" readonly="state != 'draft'"/>
              <field name="amount" readonly="state not in ['draft','prepared']"/>
              <field name="currency_id" invisible="1"/>
              <field name="fiscal_year" readonly="1"/>
            </group>
            <group string="المرجع">
              <field name="daftar55_id"/>
              <field name="source_cash_book_id"
                     invisible="direction != 'outgoing'"/>
            </group>
          </group>
          <group>
            <field name="purpose" readonly="state not in ['draft','prepared']"
                   placeholder="الغرض من التحويل..."/>
          </group>
          <group>
            <field name="denomination_notes"
                   readonly="state not in ['draft','prepared']"
                   placeholder="200×50 = 10,000 / 500×20 = 10,000..."/>
          </group>

          <group string="المُرسِل" col="2">
            <group>
              <field name="sender_employee_id" readonly="state != 'draft'"/>
              <field name="sender_unit"/>
            </group>
          </group>

          <group string="النقل" invisible="direction != 'outgoing'">
            <group>
              <field name="transporter_id"/>
              <field name="escort_security"/>
            </group>
            <group>
              <field name="transport_vehicle_plate"/>
              <field name="dispatch_datetime"/>
              <field name="arrival_datetime"/>
            </group>
          </group>

          <group string="المُستلِم">
            <group>
              <field name="receiver_unit_type" readonly="state != 'draft'"/>
              <field name="receiver_unit_name"/>
            </group>
            <group>
              <field name="receiver_employee_id"
                     invisible="receiver_unit_type != 'internal_branch'"
                     required="receiver_unit_type == 'internal_branch'"/>
              <field name="receiver_external_name"
                     invisible="receiver_unit_type == 'internal_branch'"
                     required="receiver_unit_type != 'internal_branch'"/>
              <field name="receiver_id_number"/>
            </group>
          </group>

          <notebook>
            <page string="التنازع"
                  invisible="state not in ['disputed','confirmed','closed']
                             or disputed_amount == 0">
              <group>
                <group>
                  <field name="disputed_amount"/>
                </group>
              </group>
              <field name="dispute_reason"/>
              <field name="dispute_resolution"
                     invisible="state == 'disputed'"/>
            </page>
            <page string="الفقدان" invisible="state != 'lost'">
              <group>
                <group>
                  <field name="police_report_number"/>
                  <field name="police_report_date"/>
                </group>
              </group>
              <field name="loss_description"/>
            </page>
            <page string="الإلغاء" invisible="state != 'cancelled'">
              <field name="cancellation_reason"/>
            </page>
            <page string="التواقيع والتواريخ">
              <group>
                <group>
                  <field name="preparation_date" readonly="1"/>
                  <field name="prepared_by" readonly="1"/>
                  <field name="approved_by" readonly="1"/>
                </group>
                <group>
                  <field name="confirmation_date" readonly="1"/>
                  <field name="closed_by" readonly="1"/>
                  <field name="folio_id" readonly="1"/>
                </group>
              </group>
            </page>
            <page string="الربط المحاسبي">
              <field name="move_id" readonly="1"/>
            </page>
            <page string="ملاحظات">
              <field name="notes"/>
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter">
          <field name="message_follower_ids"/>
          <field name="activity_ids"/>
          <field name="message_ids"/>
        </div>
      </form>
    </field>
  </record>

  <record id="view_cash_transfer_search" model="ir.ui.view">
    <field name="name">port_said.cash_transfer.search</field>
    <field name="model">port_said.cash_transfer</field>
    <field name="arch" type="xml">
      <search>
        <field name="sequence_number"/>
        <field name="receiver_unit_name"/>
        <field name="sender_employee_id"/>
        <field name="daftar55_id"/>
        <separator/>
        <filter string="مرسلة" name="f_out" domain="[('direction','=','outgoing')]"/>
        <filter string="واردة" name="f_in" domain="[('direction','=','incoming')]"/>
        <separator/>
        <filter string="في الطريق" name="f_transit" domain="[('state','=','in_transit')]"/>
        <filter string="متنازَع فيها" name="f_disputed" domain="[('state','=','disputed')]"/>
        <filter string="مفقودة" name="f_lost" domain="[('state','=','lost')]"/>
        <filter string="مُؤكَّدة" name="f_confirmed" domain="[('state','=','confirmed')]"/>
        <group expand="1" string="تجميع حسب">
          <filter string="الاتجاه" name="g_dir" context="{'group_by':'direction'}"/>
          <filter string="الحالة" name="g_state" context="{'group_by':'state'}"/>
          <filter string="السنة المالية" name="g_fy" context="{'group_by':'fiscal_year'}"/>
          <filter string="الشهر" name="g_month" context="{'group_by':'transfer_date:month'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="action_cash_transfer" model="ir.actions.act_window">
    <field name="name">حركات النقود</field>
    <field name="res_model">port_said.cash_transfer</field>
    <field name="view_mode">tree,form</field>
    <field name="search_view_id" ref="view_cash_transfer_search"/>
  </record>

</odoo>
