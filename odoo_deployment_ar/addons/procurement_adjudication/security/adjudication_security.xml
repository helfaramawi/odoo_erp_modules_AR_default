<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_procurement_eg" model="ir.module.category">
        <field name="name">التعاقدات الحكومية — بورسعيد</field>
        <field name="sequence">85</field>
    </record>

    <record id="group_adjudication_member" model="res.groups">
        <field name="name">عضو لجنة البت</field>
        <field name="category_id" ref="procurement_adjudication.module_category_procurement_eg"/>
        <field name="comment">تقييم العروض الفنية والمالية</field>
    </record>

    <record id="group_adjudication_chairman" model="res.groups">
        <field name="name">رئيس لجنة البت</field>
        <field name="category_id" ref="procurement_adjudication.module_category_procurement_eg"/>
        <field name="implied_ids" eval="[(4, ref('group_adjudication_member'))]"/>
        <field name="comment">فتح المظاريف وإصدار نتائج البت</field>
    </record>

    <record id="group_adjudication_director" model="res.groups">
        <field name="name">مدير التعاقدات — ترسية</field>
        <field name="category_id" ref="procurement_adjudication.module_category_procurement_eg"/>
        <field name="implied_ids" eval="[(4, ref('group_adjudication_chairman'))]"/>
        <field name="comment">إخطار الترسية النهائي وإنشاء أمر التوريد</field>
    </record>
</odoo>
