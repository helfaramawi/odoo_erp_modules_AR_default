<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_adjudication_inherit" model="ir.ui.view">
        <field name="name">hr.employee.adjudication.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_adjudications" type="object"
                    class="oe_stat_button" icon="fa-gavel"
                    invisible="adjudication_count == 0">
                    <div class="o_stat_info">
                        <field name="adjudication_count" class="o_stat_value"/>
                        <span class="o_stat_text">ملف بت</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <record id="view_adjudication_hr_inherit" model="ir.ui.view">
        <field name="name">procurement.adjudication.hr.inherit</field>
        <field name="model">procurement.adjudication</field>
        <field name="inherit_id" ref="procurement_adjudication.view_adjudication_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='technical_committee_id']" position="after">
                <field name="technical_chairman_name" readonly="1"
                       invisible="not technical_chairman_name"/>
                <field name="technical_member_count"  readonly="1"
                       invisible="not technical_member_count"/>
            </xpath>
            <xpath expr="//field[@name='financial_committee_id']" position="after">
                <field name="financial_chairman_name" readonly="1"
                       invisible="not financial_chairman_name"/>
            </xpath>
        </field>
    </record>
</odoo>
