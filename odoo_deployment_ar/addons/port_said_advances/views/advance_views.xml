<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_advance_form" model="ir.ui.view">
  <field name="name">port_said.advance.form</field>
  <field name="model">port_said.advance</field>
  <field name="arch" type="xml">
    <form string="سلفة حكومية — استمارة 62 ع.ح">
      <header>
        <field name="state" widget="statusbar" statusbar_visible="draft,approved,disbursed,settled"/>
      </header>
      <sheet>
        <field name="is_overdue" invisible="1"/>
        <div class="o_field_widget" style="margin-bottom:10px;">
          <button name="action_submit" string="تقديم للاعتماد" type="object" class="btn btn-primary btn-sm" invisible="state != 'draft'"/>
          <button name="action_approve" string="اعتماد" type="object" class="btn btn-success btn-sm" invisible="state != 'submitted'" groups="account.group_account_manager"/>
          <button name="action_disburse" string="تسجيل الصرف" type="object" class="btn btn-primary btn-sm" invisible="state != 'approved'" groups="account.group_account_manager"/>
          <button name="action_settle" string="تسوية السلفة" type="object" class="btn btn-success btn-sm" invisible="state != 'disbursed'"/>
          <button name="action_cancel" string="إلغاء" type="object" class="btn btn-danger btn-sm" invisible="state in ('disbursed','settled','cancelled')" groups="account.group_account_manager"/>
        </div>
        <field name="is_overdue" invisible="1"/>
        <div class="alert alert-danger" role="alert" invisible="not is_overdue">
          <strong>تنبيه:</strong> هذه السلفة تجاوزت تاريخ الاستحقاق ولم تُسوَّ بعد
        </div>
        <div class="oe_title">
          <h1><field name="name" readonly="1"/></h1>
        </div>
        <group>
          <group string="بيانات السلفة">
            <field name="advance_type"/>
            <field name="advance_date"/>
            <field name="due_date"/>
            <field name="fiscal_year"/>
          </group>
          <group string="المستفيد">
            <field name="employee_id" invisible="advance_type == 'vendor'"/>
            <field name="employee_job" readonly="1" invisible="advance_type == 'vendor'"/>
            <field name="department_id" readonly="1" invisible="advance_type == 'vendor'"/>
            <field name="national_id" readonly="1" invisible="advance_type == 'vendor'"/>
            <field name="vendor_id" invisible="advance_type != 'vendor'"/>
          </group>
        </group>
        <group string="القيم المالية والمراجع">
          <group>
            <field name="amount"/>
            <field name="amount_settled"/>
            <field name="amount_outstanding" readonly="1"
                   decoration-success="amount_outstanding == 0"/>
            <field name="budget_line"/>
          </group>
          <group>
            <field name="commitment_id"/>
            <field name="daftar55_id"/>
            <field name="settlement_daftar55_id"/>
            <field name="dossier_id"/>
          </group>
        </group>
        <field name="purpose" placeholder="الغرض من السلفة..."/>
        <field name="notes" placeholder="ملاحظات إضافية..."/>
        <group>
          <field name="approved_by" readonly="1"/>
          <field name="account_move_id" readonly="1"/>
        </group>
      </sheet>
      <chatter/>
    </form>
  </field>
</record>

<record id="view_advance_list" model="ir.ui.view">
  <field name="name">port_said.advance.list</field>
  <field name="model">port_said.advance</field>
  <field name="arch" type="xml">
    <tree string="السلف الحكومية"
          decoration-danger="is_overdue"
          decoration-success="state == 'settled'"
          decoration-warning="state == 'submitted'">
      <field name="is_overdue" column_invisible="1"/>
      <field name="name"/>
      <field name="advance_date"/>
      <field name="advance_type"/>
      <field name="employee_id" string="المستفيد" optional="show"/>
      <field name="vendor_id" optional="hide"/>
      <field name="amount" sum="الإجمالي"/>
      <field name="amount_settled" sum="المسوَّى" optional="show"/>
      <field name="amount_outstanding" sum="الرصيد القائم"
             decoration-danger="amount_outstanding &gt; 0 and is_overdue"/>
      <field name="due_date" decoration-danger="is_overdue"/>
      <field name="state" widget="badge"
             decoration-success="state == 'settled'"
             decoration-danger="state == 'cancelled'"
             decoration-primary="state == 'disbursed'"
             decoration-warning="state == 'submitted'"/>
    </tree>
  </field>
</record>

<record id="action_advances" model="ir.actions.act_window">
  <field name="name">السلف الحكومية</field>
  <field name="res_model">port_said.advance</field>
  <field name="view_mode">list,form</field>
  <field name="domain">[("state","!=","cancelled")]</field>
</record>

<record id="action_advances_overdue" model="ir.actions.act_window">
  <field name="name">السلف المتأخرة</field>
  <field name="res_model">port_said.advance</field>
  <field name="view_mode">list,form</field>
  <field name="domain">[("is_overdue","=",True)]</field>
</record>

</odoo>