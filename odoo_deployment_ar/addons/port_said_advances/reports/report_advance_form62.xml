<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="rpt_advance_form62">
  <t t-call="web.html_container">
    <t t-foreach="docs" t-as="doc">
      <t t-call="web.external_layout">
        <div class="page" style="direction:rtl;font-size:10.5pt;">
<style>.o_company_logo,.o_address_name,.o_report_layout_header,header.o_report_layout_header,.odoo-header,.header-content,footer,.footer,.o_footer{display:none!important;}.page{margin-top:0!important;padding-top:0!important;}body{font-family:Arial,sans-serif;direction:rtl;}</style>
<table style="width:100%;border-collapse:collapse;margin-bottom:8px;border-bottom:2px solid #000;padding-bottom:6px;"><tr><td style="width:78px;text-align:center;vertical-align:top;">&#160;</td><td style="text-align:center;vertical-align:middle;"><div style="font-size:13pt;font-weight:bold;">جمهورية مصر العربية</div><div style="font-size:12pt;font-weight:bold;">محافظة بورسعيد</div><div style="font-size:11pt;">الإدارة العامة للشؤون المالية والإدارية</div><div style="font-size:11pt;font-weight:bold;">إدارة الحسابات والمالية</div></td><td style="width:78px;text-align:center;vertical-align:middle;"><img src="data:image/png;base64," style="width:68px;height:68px;object-fit:contain;" alt="بورسعيد"/></td></tr></table>

          <div style="text-align:center;border-top:3px double #000;border-bottom:3px double #000;padding:5px 0;margin-bottom:10px;">
            <span style="font-size:14pt;font-weight:bold;">استمارة صرف سلفة</span>
            <span style="font-size:11pt;margin-right:16px;">استمارة 62 ع.ح</span>
          </div>
          <table style="width:100%;margin-bottom:10px;font-size:10pt;">
            <tr>
              <td style="border:1px solid #000;padding:5px 8px;background:#f5f5f5;font-weight:bold;width:18%;">رقم السلفة</td>
              <td style="border:1px solid #000;padding:5px 8px;width:18%;font-weight:bold;font-size:12pt;"><t t-esc="doc.name"/></td>
              <td style="border:1px solid #000;padding:5px 8px;background:#f5f5f5;font-weight:bold;width:14%;">التاريخ</td>
              <td style="border:1px solid #000;padding:5px 8px;width:18%;"><t t-esc="doc.advance_date"/></td>
              <td style="border:1px solid #000;padding:5px 8px;background:#f5f5f5;font-weight:bold;width:14%;">السنة المالية</td>
              <td style="border:1px solid #000;padding:5px 8px;width:18%;"><t t-esc="doc.fiscal_year"/></td>
            </tr>
            <tr>
              <td style="border:1px solid #000;padding:5px 8px;background:#f5f5f5;font-weight:bold;">نوع السلفة</td>
              <td style="border:1px solid #000;padding:5px 8px;" colspan="2">
                <t t-esc="{'permanent':'سلفة مستديمة','travel':'بدل سفر','transport':'بدل انتقال','vendor':'دفعة مقدمة','petty_cash':'عهدة نقدية'}.get(doc.advance_type, doc.advance_type)"/>
              </td>
              <td style="border:1px solid #000;padding:5px 8px;background:#f5f5f5;font-weight:bold;">تاريخ الاستحقاق</td>
              <td style="border:1px solid #000;padding:5px 8px;" colspan="2"><t t-esc="doc.due_date"/></td>
            </tr>
          </table>
          <table style="width:100%;margin-bottom:10px;font-size:10pt;">
            <tr style="background:#1F3864;color:white;">
              <th colspan="4" style="padding:6px;border:1px solid #ddd;text-align:center;">بيانات المستفيد</th>
            </tr>
            <tr>
              <td style="border:1px solid #ddd;padding:5px 8px;background:#f5f5f5;font-weight:bold;width:20%;">الاسم</td>
              <td style="border:1px solid #ddd;padding:5px 8px;width:30%;font-weight:bold;"><t t-esc="doc.employee_id.name if doc.employee_id else (doc.vendor_id.name if doc.vendor_id else '')"/></td>
              <td style="border:1px solid #ddd;padding:5px 8px;background:#f5f5f5;font-weight:bold;width:20%;">الرقم القومي</td>
              <td style="border:1px solid #ddd;padding:5px 8px;width:30%;"><t t-esc="doc.national_id or '—'"/></td>
            </tr>
            <tr>
              <td style="border:1px solid #ddd;padding:5px 8px;background:#f5f5f5;font-weight:bold;">الوظيفة</td>
              <td style="border:1px solid #ddd;padding:5px 8px;"><t t-esc="doc.employee_job or '—'"/></td>
              <td style="border:1px solid #ddd;padding:5px 8px;background:#f5f5f5;font-weight:bold;">الإدارة</td>
              <td style="border:1px solid #ddd;padding:5px 8px;"><t t-esc="doc.department_id.name if doc.department_id else '—'"/></td>
            </tr>
          </table>
          <table style="width:100%;margin-bottom:10px;font-size:10pt;">
            <tr style="background:#1F3864;color:white;">
              <th colspan="4" style="padding:6px;border:1px solid #ddd;text-align:center;">بيانات السلفة</th>
            </tr>
            <tr>
              <td style="border:1px solid #ddd;padding:5px 8px;background:#f5f5f5;font-weight:bold;width:20%;">مبلغ السلفة</td>
              <td style="border:1px solid #ddd;padding:5px 8px;width:30%;font-weight:bold;font-size:13pt;color:#1F3864;"><t t-esc="'%s' % '{:,.2f}'.format(doc.amount)"/> ج.م</td>
              <td style="border:1px solid #ddd;padding:5px 8px;background:#f5f5f5;font-weight:bold;width:20%;">بند الميزانية</td>
              <td style="border:1px solid #ddd;padding:5px 8px;width:30%;"><t t-esc="doc.budget_line or '—'"/></td>
            </tr>
            <tr>
              <td style="border:1px solid #ddd;padding:5px 8px;background:#f5f5f5;font-weight:bold;">الغرض</td>
              <td style="border:1px solid #ddd;padding:5px 8px;" colspan="3"><t t-esc="doc.purpose"/></td>
            </tr>
            <t t-if="doc.commitment_id">
            <tr>
              <td style="border:1px solid #ddd;padding:5px 8px;background:#f5f5f5;font-weight:bold;">رقم الارتباط</td>
              <td style="border:1px solid #ddd;padding:5px 8px;"><t t-esc="doc.commitment_id.commitment_number"/></td>
              <td style="border:1px solid #ddd;padding:5px 8px;background:#f5f5f5;font-weight:bold;">مرجع دفتر 55</td>
              <td style="border:1px solid #ddd;padding:5px 8px;"><t t-esc="doc.daftar55_id.sequence_number if doc.daftar55_id else '—'"/></td>
            </tr>
            </t>
          </table>
          <div style="background:#FFF9C4;border:1px solid #FFC107;border-radius:4px;padding:10px;margin-bottom:12px;font-size:10pt;">
            <strong>إقرار المستفيد:</strong> أقر باستلام المبلغ المذكور أعلاه وأتعهد بتسوية هذه السلفة في موعد أقصاه <t t-esc="doc.due_date"/> وذلك بتقديم المستندات والمستحقات اللازمة.
            <div style="margin-top:16px;">
              التوقيع: ..............................
              التاريخ: ..............................
            </div>
          </div>
<table style="width:100%;border-collapse:collapse;margin-top:16px;"><tr><td style="width:33%;text-align:center;padding:10px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F3864;">رئيس قسم الحسابات</div><div style="margin-top:20px;border-top:1px solid #999;padding-top:4px;font-size:8pt;">الاسم والتوقيع</div></td><td style="width:33%;text-align:center;padding:10px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F3864;">مدير الشؤون المالية</div><div style="margin-top:20px;border-top:1px solid #999;padding-top:4px;font-size:8pt;">الاسم والتوقيع</div></td><td style="width:33%;text-align:center;padding:10px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F3864;">رئيس الديوان العام</div><div style="margin-top:20px;border-top:1px solid #999;padding-top:4px;font-size:8pt;">الاسم والختم الرسمي</div></td></tr></table>
<div style="margin-top:10px;font-size:8pt;color:#555;text-align:center;border-top:1px solid #ccc;padding-top:4px;">نظام أوبو إيآر بي — Paradise Integrated Solutions طُبع بتاريخ: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d-%m-%Y %H:%M')"/> — محافظة بورسعيد</div>
        </div>
      </t>
    </t>
  </t>
</template>
</odoo>
