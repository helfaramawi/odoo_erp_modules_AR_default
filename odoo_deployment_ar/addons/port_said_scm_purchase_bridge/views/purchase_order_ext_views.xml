<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Inherit purchase.order form — use safe xpath targets -->
  <record id="view_po_ps_inherit" model="ir.ui.view">
    <field name="name">purchase.order.ps.inherit</field>
    <field name="model">purchase.order</field>
    <field name="inherit_id" ref="purchase.purchase_order_form"/>
    <field name="arch" type="xml">
      <!-- Add Port Said fields after the notes field (exists in all Odoo versions) -->
      <xpath expr="//field[@name='notes']" position="after">
        <group string="تكامل الديوان العام — بورسعيد" name="ps_integration">
          <group>
            <field name="requisition_ps_id" readonly="1"/>
            <field name="commitment_id"/>
            <field name="budget_line" readonly="1"/>
          </group>
          <group string="خطاب الضمان">
            <field name="guarantee_letter_required"/>
            <field name="guarantee_letter_ref" invisible="not guarantee_letter_required"/>
            <field name="guarantee_amount"     invisible="not guarantee_letter_required"/>
            <field name="guarantee_expiry"     invisible="not guarantee_letter_required"/>
            <field name="guarantee_state"      invisible="not guarantee_letter_required"/>
          </group>
        </group>
      </xpath>
    </field>
  </record>
</odoo>
