<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="rpt_advances_register_gov">
  <t t-call="web.html_container">
    <t t-foreach="docs" t-as="doc">
      <t t-call="web.external_layout">
        <div class="page" style="direction:rtl;font-size:10.5pt;">
<style>.o_company_logo,.o_address_name,.o_report_layout_header,header.o_report_layout_header,.odoo-header,.header-content,footer,.footer,.o_footer{display:none!important;}.page{margin-top:0!important;padding-top:0!important;}body{font-family:Arial,sans-serif;direction:rtl;}</style>
<table style="width:100%;border-collapse:collapse;margin-bottom:8px;border-bottom:2px solid #1F497D;padding-bottom:6px;"><tr><td style="width:78px;text-align:center;">&#160;</td><td style="text-align:center;"><div style="font-size:11pt;color:#666;">جمهورية مصر العربية</div><div style="font-size:14pt;font-weight:bold;color:#1F497D;">محافظة بورسعيد — الديوان العام</div><div style="font-size:11pt;font-weight:bold;color:#333;margin-top:3px;">إدارة الحسابات والشؤون المالية</div></td><td style="width:78px;text-align:center;"><img src="data:image/png;base64," style="width:68px;height:68px;object-fit:contain;"/></td></tr></table>

          <div style="text-align:center;border-top:3px double #1F497D;border-bottom:3px double #1F497D;padding:5px 0;margin-bottom:10px;">
            <span style="font-size:14pt;font-weight:bold;color:#1F497D;">سجل السلف الحكومية القائمة</span>
          </div>
          <t t-set="advances" t-value="doc._get_advances_register_data()"/>
          <table style="width:100%;font-size:9.5pt;margin-bottom:12px;">
            <thead>
              <tr style="background:#1F497D;color:white;">
                <th style="padding:5px;border:1px solid #ccc;width:5%;">#</th>
                <th style="padding:5px;border:1px solid #ccc;width:12%;">رقم السلفة</th>
                <th style="padding:5px;border:1px solid #ccc;width:10%;">التاريخ</th>
                <th style="padding:5px;border:1px solid #ccc;width:10%;">النوع</th>
                <th style="padding:5px;border:1px solid #ccc;width:18%;">المستفيد</th>
                <th style="padding:5px;border:1px solid #ccc;width:11%;text-align:left;">المبلغ</th>
                <th style="padding:5px;border:1px solid #ccc;width:11%;text-align:left;">الرصيد</th>
                <th style="padding:5px;border:1px solid #ccc;width:10%;">الاستحقاق</th>
                <th style="padding:5px;border:1px solid #ccc;width:8%;text-align:center;">الحالة</th>
                <th style="padding:5px;border:1px solid #ccc;width:5%;text-align:center;">تأخر</th>
              </tr>
            </thead>
            <tbody>
              <t t-foreach="advances" t-as="adv">
                <tr t-attf-style="background:{{ '#ffe0e0' if adv.is_overdue else ('#f9f9f9' if adv_index % 2 == 0 else 'white') }};">
                  <td style="padding:4px;border:1px solid #ddd;text-align:center;"><t t-esc="adv_index + 1"/></td>
                  <td style="padding:4px;border:1px solid #ddd;font-weight:bold;"><t t-esc="adv.name"/></td>
                  <td style="padding:4px;border:1px solid #ddd;"><t t-esc="adv.advance_date"/></td>
                  <td style="padding:4px;border:1px solid #ddd;font-size:8.5pt;"><t t-esc="{'permanent':'مستديمة','travel':'سفر','transport':'انتقال','vendor':'مورد','petty_cash':'نقدية'}.get(adv.advance_type,'')"/></td>
                  <td style="padding:4px;border:1px solid #ddd;"><t t-esc="adv.employee_id.name if adv.employee_id else (adv.vendor_id.name if adv.vendor_id else '')"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:left;font-weight:bold;"><t t-esc="'%s' % '{:,.2f}'.format(adv.amount)"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:left;font-weight:bold;color:#C00000;"><t t-esc="'%s' % '{:,.2f}'.format(adv.amount_outstanding)"/></td>
                  <td style="padding:4px;border:1px solid #ddd;"><t t-esc="adv.due_date"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:center;font-size:8.5pt;"><t t-esc="{'disbursed':'مصروف','submitted':'مقدم','approved':'معتمد'}.get(adv.state,'')"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:center;">
                    <t t-if="adv.is_overdue"><span style="color:#C00000;font-weight:bold;">✗</span></t>
                    <t t-else=""><span style="color:#375623;">✓</span></t>
                  </td>
                </tr>
              </t>
            </tbody>
            <tfoot>
              <tr style="background:#1F497D;color:white;font-weight:bold;">
                <td colspan="5" style="padding:5px;border:1px solid #ddd;text-align:center;"><t t-esc="len(advances)"/> سلفة</td>
                <td style="padding:5px;border:1px solid #ddd;text-align:left;"><t t-esc="'%s' % '{:,.2f}'.format(sum(a.amount for a in advances))"/></td>
                <td style="padding:5px;border:1px solid #ddd;text-align:left;"><t t-esc="'%s' % '{:,.2f}'.format(sum(a.amount_outstanding for a in advances))"/></td>
                <td colspan="3" style="padding:5px;border:1px solid #ddd;"/>
              </tr>
            </tfoot>
          </table>
<table style="width:100%;border-collapse:collapse;margin-top:16px;"><tr><td style="width:33%;text-align:center;padding:10px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F497D;">رئيس قسم الحسابات</div><div style="margin-top:20px;border-top:1px solid #999;padding-top:4px;font-size:8pt;">الاسم والتوقيع</div></td><td style="width:33%;text-align:center;padding:10px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F497D;">مدير الشؤون المالية</div><div style="margin-top:20px;border-top:1px solid #999;padding-top:4px;font-size:8pt;">الاسم والتوقيع</div></td><td style="width:33%;text-align:center;padding:10px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F497D;">رئيس الديوان العام</div><div style="margin-top:20px;border-top:1px solid #999;padding-top:4px;font-size:8pt;">الاسم والختم</div></td></tr></table>
<div style="margin-top:10px;font-size:8pt;color:#555;text-align:center;border-top:1px solid #ccc;padding-top:4px;">Paradise Integrated Solutions — طُبع بتاريخ: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d-%m-%Y %H:%M')"/> — محافظة بورسعيد</div>
        </div>
      </t>
    </t>
  </t>
</template>
</odoo>
