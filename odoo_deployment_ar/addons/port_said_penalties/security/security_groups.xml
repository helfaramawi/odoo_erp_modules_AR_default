<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="group_penalty_user" model="res.groups">
    <field name="name">دفتر الجزاءات — مستخدم</field>
    <field name="category_id" ref="base.module_category_human_resources"/>
    <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
  </record>

  <record id="group_penalty_manager" model="res.groups">
    <field name="name">دفتر الجزاءات — مدير</field>
    <field name="category_id" ref="base.module_category_human_resources"/>
    <field name="implied_ids" eval="[(4, ref('group_penalty_user')), (4, ref('account.group_account_manager'))]"/>
  </record>
</odoo>
