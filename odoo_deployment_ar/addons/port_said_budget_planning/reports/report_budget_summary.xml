<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="rpt_budget_summary">
  <t t-call="web.html_container">
    <t t-foreach="docs" t-as="doc">
      <t t-call="web.external_layout">
        <div class="page" style="direction:rtl;font-size:10.5pt;">
<style>.o_company_logo,.o_address_name,.o_report_layout_header,header.o_report_layout_header,.odoo-header,.header-content,footer,.footer,.o_footer{display:none!important;}.page{margin-top:0!important;padding-top:0!important;}body{font-family:Arial,sans-serif;direction:rtl;}</style>
<table style="width:100%;border-collapse:collapse;margin-bottom:8px;border-bottom:2px solid #000;padding-bottom:6px;"><tr><td style="width:78px;text-align:center;vertical-align:top;">&#160;</td><td style="text-align:center;vertical-align:middle;"><div style="font-size:13pt;font-weight:bold;">جمهورية مصر العربية</div><div style="font-size:12pt;font-weight:bold;">محافظة بورسعيد</div><div style="font-size:11pt;">الإدارة العامة للشؤون المالية والإدارية</div><div style="font-size:11pt;font-weight:bold;">إدارة الموازنة والحسابات</div></td><td style="width:78px;text-align:center;vertical-align:middle;"><img src="data:image/png;base64," style="width:68px;height:68px;object-fit:contain;" alt="بورسعيد"/></td></tr></table>

          <div style="text-align:center;border-top:3px double #000;border-bottom:3px double #000;padding:5px 0;margin-bottom:10px;">
            <span style="font-size:14pt;font-weight:bold;">ملخص الموازنة التقديرية</span>
            <span style="font-size:11pt;margin-right:16px;">السنة المالية: <t t-esc="doc.fiscal_year"/></span>
          </div>
          <table style="width:100%;margin-bottom:10px;font-size:10pt;">
            <tr>
              <td style="border:1px solid #000;padding:5px;background:#f5f5f5;font-weight:bold;width:20%;">اسم الموازنة</td>
              <td style="border:1px solid #000;padding:5px;width:30%;font-weight:bold;"><t t-esc="doc.name"/></td>
              <td style="border:1px solid #000;padding:5px;background:#f5f5f5;font-weight:bold;width:16%;">السنة المالية</td>
              <td style="border:1px solid #000;padding:5px;width:34%;"><t t-esc="doc.fiscal_year"/></td>
            </tr>
            <tr>
              <td style="border:1px solid #000;padding:5px;background:#f5f5f5;font-weight:bold;">الفترة</td>
              <td style="border:1px solid #000;padding:5px;"><t t-esc="doc.date_from"/> إلى <t t-esc="doc.date_to"/></td>
              <td style="border:1px solid #000;padding:5px;background:#f5f5f5;font-weight:bold;">الإدارة</td>
              <td style="border:1px solid #000;padding:5px;"><t t-esc="doc.department or 'الديوان العام'"/></td>
            </tr>
          </table>
          <!-- KPIs مالية -->
          <table style="width:100%;margin-bottom:12px;font-size:11pt;">
            <tr>
              <td style="padding:10px;border:1px solid #ddd;text-align:center;background:#EBF5FB;">
                <div style="font-size:14pt;font-weight:bold;color:#1F3864;"><t t-esc="'%s' % '{:,.2f}'.format(doc.total_approved)"/> ج.م</div>
                <div style="font-size:9pt;color:#666;">إجمالي الاعتمادات المعتمدة</div>
              </td>
              <td style="padding:10px;border:1px solid #ddd;text-align:center;background:#FFF3E0;">
                <div style="font-size:14pt;font-weight:bold;color:#C55A11;"><t t-esc="'%s' % '{:,.2f}'.format(doc.total_committed)"/> ج.م</div>
                <div style="font-size:9pt;color:#666;">الارتباطات المرصودة</div>
              </td>
              <td style="padding:10px;border:1px solid #ddd;text-align:center;background:#E8F5E9;">
                <div style="font-size:14pt;font-weight:bold;color:#375623;"><t t-esc="'%s' % '{:,.2f}'.format(doc.total_actual)"/> ج.م</div>
                <div style="font-size:9pt;color:#666;">المصروف الفعلي</div>
              </td>
              <td style="padding:10px;border:1px solid #ddd;text-align:center;">
                <div style="font-size:14pt;font-weight:bold;"><t t-esc="'%s' % '{:.1f}'.format(doc.execution_rate)"/>%</div>
                <div style="font-size:9pt;color:#666;">نسبة التنفيذ</div>
              </td>
            </tr>
          </table>
          <table style="width:100%;font-size:9.5pt;margin-bottom:12px;">
            <thead>
              <tr style="background:#1F3864;color:white;">
                <th style="padding:5px;border:1px solid #ccc;width:12%;">الكود</th>
                <th style="padding:5px;border:1px solid #ccc;width:28%;">الوصف</th>
                <th style="padding:5px;border:1px solid #ccc;width:14%;text-align:left;">الاعتماد</th>
                <th style="padding:5px;border:1px solid #ccc;width:12%;text-align:left;">الارتباطات</th>
                <th style="padding:5px;border:1px solid #ccc;width:12%;text-align:left;">الفعلي</th>
                <th style="padding:5px;border:1px solid #ccc;width:12%;text-align:left;">الرصيد</th>
                <th style="padding:5px;border:1px solid #ccc;width:10%;text-align:center;">التنفيذ</th>
              </tr>
            </thead>
            <tbody>
              <t t-foreach="doc.line_ids" t-as="line">
                <tr t-attf-style="background:{{ '#ffe0e0' if line.amount_available &lt; 0 else ('#fff3cd' if line.execution_pct &gt; 90 else ('#f9f9f9' if line_index % 2 == 0 else 'white')) }};">
                  <td style="padding:4px;border:1px solid #ddd;font-weight:bold;font-size:8.5pt;"><t t-esc="line.full_code"/></td>
                  <td style="padding:4px;border:1px solid #ddd;"><t t-esc="line.description"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:left;font-weight:bold;"><t t-esc="'%s' % '{:,.2f}'.format(line.amount_approved)"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:left;color:#C55A11;"><t t-esc="'%s' % '{:,.2f}'.format(line.amount_committed)"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:left;color:#375623;font-weight:bold;"><t t-esc="'%s' % '{:,.2f}'.format(line.amount_actual)"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:left;font-weight:bold;"><t t-esc="'%s' % '{:,.2f}'.format(line.amount_available)"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:center;font-weight:bold;"><t t-esc="'%s' % '{:.1f}'.format(line.execution_pct)"/>%</td>
                </tr>
              </t>
            </tbody>
            <tfoot>
              <tr style="background:#1F3864;color:white;font-weight:bold;">
                <td colspan="2" style="padding:5px;border:1px solid #ddd;text-align:center;">الإجمالي</td>
                <td style="padding:5px;border:1px solid #ddd;text-align:left;"><t t-esc="'%s' % '{:,.2f}'.format(doc.total_approved)"/></td>
                <td style="padding:5px;border:1px solid #ddd;text-align:left;"><t t-esc="'%s' % '{:,.2f}'.format(doc.total_committed)"/></td>
                <td style="padding:5px;border:1px solid #ddd;text-align:left;"><t t-esc="'%s' % '{:,.2f}'.format(doc.total_actual)"/></td>
                <td colspan="2" style="padding:5px;border:1px solid #ddd;text-align:center;"><t t-esc="'%s' % '{:.1f}'.format(doc.execution_rate)"/>%</td>
              </tr>
            </tfoot>
          </table>
<table style="width:100%;border-collapse:collapse;margin-top:16px;"><tr><td style="width:33%;text-align:center;padding:10px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F3864;">مدير الموازنة</div><div style="margin-top:20px;border-top:1px solid #999;padding-top:4px;font-size:8pt;">الاسم والتوقيع</div></td><td style="width:33%;text-align:center;padding:10px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F3864;">مدير الشؤون المالية</div><div style="margin-top:20px;border-top:1px solid #999;padding-top:4px;font-size:8pt;">الاسم والتوقيع</div></td><td style="width:33%;text-align:center;padding:10px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F3864;">رئيس الديوان العام</div><div style="margin-top:20px;border-top:1px solid #999;padding-top:4px;font-size:8pt;">الاسم والختم</div></td></tr></table>
<div style="margin-top:10px;font-size:8pt;color:#555;text-align:center;border-top:1px solid #ccc;padding-top:4px;">نظام أوبو إيآر بي — Paradise Integrated Solutions طُبع بتاريخ: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d-%m-%Y %H:%M')"/> — محافظة بورسعيد</div>
        </div>
      </t>
    </t>
  </t>
</template>
</odoo>
