<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_inventory_revaluation_wizard" model="ir.ui.view">
    <field name="name">inventory.revaluation.wizard.form</field>
    <field name="model">inventory.revaluation.wizard</field>
    <field name="arch" type="xml">
      <form string="Inventory Revaluation Report / تقرير إعادة التقييم">
        <group>
          <field name="as_of_date"/>
          <field name="company_id" groups="base.group_multi_company"/>
          <field name="show_zero_qty"/>
        </group>
        <group string="Locations / المواقع">
          <field name="location_ids" widget="many2many_tags" nolabel="1"/>
        </group>
        <footer>
          <button name="action_print_report" string="Print / طباعة" type="object" class="btn-primary"/>
          <button string="Cancel / إلغاء" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
  <record id="action_inventory_revaluation_wizard" model="ir.actions.act_window">
    <field name="name">Inventory Revaluation / إعادة تقييم المخزون</field>
    <field name="res_model">inventory.revaluation.wizard</field>
    <field name="view_mode">form</field><field name="target">new</field>
  </record>
  <menuitem id="menu_inventory_revaluation" name="Revaluation Report / تقرير إعادة التقييم"
    parent="stock.menu_stock_root" action="action_inventory_revaluation_wizard" sequence="50"/>
</odoo>