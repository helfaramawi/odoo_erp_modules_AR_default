<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_custody" model="ir.module.category">
        <field name="name">إدارة العهد</field>
        <field name="sequence">80</field>
    </record>
    <record id="group_custody_user" model="res.groups">
        <field name="name">أمين المخزن</field>
        <field name="category_id" ref="module_category_custody"/>
        <field name="comment">يمكنه إنشاء وتعديل العهد</field>
    </record>
    <record id="group_custody_manager" model="res.groups">
        <field name="name">مدير العهد</field>
        <field name="category_id" ref="module_category_custody"/>
        <field name="implied_ids" eval="[(4, ref('group_custody_user'))]"/>
        <field name="comment">صلاحيات كاملة على العهد بما فيها الحذف</field>
    </record>

    <!-- Record Rules: موظف يرى عهده فقط ما لم يكن مدير عهد -->
    <record id="rule_custody_own_records" model="ir.rule">
        <field name="name">العهد — المستخدم يرى عهده فقط</field>
        <field name="model_id" ref="model_custody_assignment"/>
        <field name="domain_force">
            ['|',
             ('employee_id.user_id', '=', user.id),
             ('create_uid', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('l10n_eg_custody.group_custody_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- مدير العهد يرى الكل بدون قيود -->
    <record id="rule_custody_manager_all" model="ir.rule">
        <field name="name">العهد — مدير يرى الكل</field>
        <field name="model_id" ref="model_custody_assignment"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('l10n_eg_custody.group_custody_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
