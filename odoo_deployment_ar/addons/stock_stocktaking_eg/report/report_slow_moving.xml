<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Slow-moving stock wizard report (FR-I6) -->
    <record id="action_report_slow_moving" model="ir.actions.report">
        <field name="name">بيان مخزون راكد - Slow Moving Stock</field>
        <field name="model">stock.stocktaking.session</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_stocktaking_eg.report_slow_moving_template</field>
        <field name="print_report_name">'بيان مخزون راكد - ' + (object.warehouse_id.name or '')</field>
        <field name="binding_model_id" ref="model_stock_stocktaking_session"/>
<field name="paperformat_id" ref="stock_stocktaking_eg.paperformat_gov_a4"/>
        <field name="binding_type">report</field>
</record>

    <template id="report_slow_moving_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                
                    <t t-call="web.external_layout">
                
                    <div class="page" style="direction:rtl;font-family:'Cairo',Arial,sans-serif;font-size:11pt;">
<style>
    /* Hide ALL Odoo company header/footer elements */
    .o_company_logo { display:none!important; }
    .o_address_name { display:none!important; }
    .o_report_layout_header { display:none!important; }
    header.o_report_layout_header { display:none!important; }
    .odoo-header { display:none!important; }
    .header-content { display:none!important; }
    footer { display:none!important; }
    .footer { display:none!important; }
    .o_footer { display:none!important; }
    /* Force page to start at top */
    .page { margin-top:0!important; padding-top:0!important; }
</style>

                        <table style="width:100%;border-collapse:collapse;margin-bottom:6px;border-bottom:2px solid #000;padding-bottom:6px;">
                            <tr>
                                <td style="width:78px;text-align:center;vertical-align:top;">
                                    &#160;
                                </td>
                                <td style="text-align:center;vertical-align:middle;">
                                    <div style="font-size:13pt;font-weight:bold;">جمهورية مصر العربية</div>
                                    <div style="font-size:12pt;font-weight:bold;">محافظة بورسعيد</div>
                                    <div style="font-size:11pt;">الإدارة العامة للشؤون المالية والإدارية</div>
                                    <div style="font-size:11pt;font-weight:bold;">إدارة المخازن</div>
                                </td>
                                <td style="width:78px;text-align:center;vertical-align:middle;">
                                    <img src="data:image/png;base64,"
                                         style="width:70px;height:70px;object-fit:contain;"
                                         alt="محافظة بورسعيد"/>
                                </td>
                            </tr>
                        </table>
                        <div style="text-align:center;margin-bottom:10px;">
                            <h3 style="margin:4px 0;">بيان المخزون الراكد</h3>
                            <div style="display:flex;justify-content:space-between;margin-top:6px;">
                                <span>المستودع: <t t-esc="doc.warehouse_id.name"/></span>
                                <span>تاريخ الجرد: <t t-esc="doc.stocktaking_date"/></span>
                            </div>
                        </div>
                        <p style="margin-bottom:12px;line-height:1.7;">
                            الأصناف الآتية لم يتم صرفها خلال الفترة السابقة ويُقترح الإعلان عن بيعها وفق اللوائح والأنظمة المعمول بها:
                        </p>
                        <table style="width:100%;border-collapse:collapse;font-size:10pt;margin-bottom:16px;">
                            <thead>
                                <tr style="background:#ffe0b2;">
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">م</th>
                                    <th style="border:1px solid #000;padding:6px;">اسم الصنف</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">الكمية الموجودة</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">الوحدة</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">القيمة التقديرية</th>
                                    <th style="border:1px solid #000;padding:6px;">ملاحظات</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Items with no movement (physical_qty == system_qty and qty > 0 and noted as slow) -->
                                <t t-set="slow_lines" t-value="doc.line_ids.filtered(lambda l: l.physical_qty > 0 and l.difference_type == 'none')"/>
                                <t t-foreach="slow_lines" t-as="line">
                                    <tr>
                                        <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="line_index + 1"/></td>
                                        <td style="border:1px solid #000;padding:5px;"><t t-esc="line.product_id.name"/></td>
                                        <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="'%.2f' % line.physical_qty"/></td>
                                        <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="line.uom_id.name if line.uom_id else ''"/></td>
                                        <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="'%.2f' % (line.physical_qty * line.standard_cost)"/></td>
                                        <td style="border:1px solid #000;padding:5px;"></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Sale Authorization Block -->
                        <div style="border:2px solid #000;padding:12px;margin-top:16px;">
                            <h3 style="text-align:center;margin:0 0 10px;">تصريح بالبيع</h3>
                            <p style="line-height:1.8;">
                                بموجب هذا الكشف، يُصرح بعرض الأصناف المذكورة أعلاه للبيع بالمزاد العلني
                                وفقاً لأحكام لائحة المخازن الحكومية والقواعد المعمول بها.
                            </p>
                            <div style="display:flex;justify-content:space-between;margin-top:20px;">
                                <div style="text-align:center;">
                                    <p style="font-weight:bold;">أمين المخزن</p>
                                    <p style="margin-top:20px;color:#555;">التوقيع: .................</p>
                                </div>
                                <div style="text-align:center;">
                                    <p style="font-weight:bold;">مدير إدارة المخازن</p>
                                    <p style="margin-top:20px;color:#555;">التوقيع: .................</p>
                                </div>
                                <div style="text-align:center;">
                                    <p style="font-weight:bold;">رئيس الديوان / المفوض</p>
                                    <p style="margin-top:20px;color:#555;">التوقيع: .................</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
