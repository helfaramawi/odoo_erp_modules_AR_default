<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_warehouse_eg" model="ir.module.category">
        <field name="name">مخازن حكومية — بورسعيد</field>
        <field name="sequence">86</field>
    </record>

    <record id="group_stocktaking_user" model="res.groups">
        <field name="name">عضو لجنة الجرد</field>
        <field name="category_id" ref="stock_stocktaking_eg.module_category_warehouse_eg"/>
        <field name="comment">إدخال الكميات الفعلية في جلسة الجرد</field>
    </record>

    <record id="group_stocktaking_chairman" model="res.groups">
        <field name="name">رئيس لجنة الجرد</field>
        <field name="category_id" ref="stock_stocktaking_eg.module_category_warehouse_eg"/>
        <field name="implied_ids" eval="[(4, ref('group_stocktaking_user'))]"/>
        <field name="comment">ترحيل الجرد واعتماده نهائياً</field>
    </record>
</odoo>
