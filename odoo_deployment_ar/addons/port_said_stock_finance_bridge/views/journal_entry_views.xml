<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_sfje_form" model="ir.ui.view">
  <field name="name">stock.finance.journal.entry.form</field>
  <field name="model">stock.finance.journal.entry</field>
  <field name="arch" type="xml">
    <form string="قيد محاسبي للحركة المخزنية">
      <header>
        <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
      </header>
      <sheet>
        <div class="o_field_widget" style="margin-bottom:10px;">
          <button name="action_auto_fill" string="تحديث تلقائي من القواعد"
                  type="object" class="btn btn-secondary btn-sm"
                  invisible="state != 'draft'"/>
          <button name="action_post" string="ترحيل القيد"
                  type="object" class="btn btn-primary btn-sm"
                  invisible="state != 'draft'"
                  groups="account.group_account_manager"/>
          <button name="action_cancel" string="إلغاء"
                  type="object" class="btn btn-danger btn-sm"
                  invisible="state == 'cancel'"
                  groups="account.group_account_manager"/>
          <button name="action_view_account_move" string="عرض القيد في المحاسبة"
                  type="object" class="btn btn-secondary btn-sm"
                  invisible="not account_move_id"/>
        </div>
        <div class="oe_title">
          <h1><field name="name" readonly="1"/></h1>
        </div>
        <group>
          <group string="بيانات القيد">
            <field name="move_type"/>
            <field name="date"/>
            <field name="ref"/>
            <field name="warehouse_id"/>
            <field name="amount"/>
          </group>
          <group string="الروابط">
            <field name="issue_permit_id" readonly="1"/>
            <field name="addition_permit_id" readonly="1"/>
            <field name="transfer_permit_id" readonly="1"/>
            <field name="return_permit_id" readonly="1"/>
            <field name="account_move_id" readonly="1"/>
          </group>
        </group>
        <group string="الحسابات المحاسبية">
          <group>
            <field name="debit_account_id"/>
            <field name="credit_account_id"/>
            <field name="journal_id"/>
          </group>
          <group string="الأبعاد المالية">
            <field name="dimension_id"/>
            <field name="analytic_account_id"/>
          </group>
        </group>
        <field name="notes"/>
      </sheet>
      <chatter/>
    </form>
  </field>
</record>

<record id="view_sfje_list" model="ir.ui.view">
  <field name="name">stock.finance.journal.entry.list</field>
  <field name="model">stock.finance.journal.entry</field>
  <field name="arch" type="xml">
    <tree string="القيود المحاسبية للمخزون"
          decoration-success="state == 'posted'"
          decoration-muted="state == 'cancel'">
      <field name="name"/>
      <field name="date"/>
      <field name="move_type"/>
      <field name="ref"/>
      <field name="warehouse_id"/>
      <field name="amount" sum="الإجمالي"/>
      <field name="debit_account_id"/>
      <field name="credit_account_id"/>
      <field name="dimension_id" optional="show"/>
      <field name="account_move_id" optional="show"/>
      <field name="state" widget="badge"/>
    </tree>
  </field>
</record>

<record id="action_journal_entries" model="ir.actions.act_window">
  <field name="name">القيود المحاسبية للمخزون</field>
  <field name="res_model">stock.finance.journal.entry</field>
  <field name="view_mode">list,form</field>
</record>

</odoo>
