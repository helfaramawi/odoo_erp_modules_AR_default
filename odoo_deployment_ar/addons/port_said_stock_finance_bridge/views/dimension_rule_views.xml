<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_dimension_rule_form" model="ir.ui.view">
  <field name="name">stock.finance.dimension.rule.form</field>
  <field name="model">stock.finance.dimension.rule</field>
  <field name="arch" type="xml">
    <form string="قاعدة الأبعاد المالية">
      <sheet>
        <group>
          <group string="مصدر البعد">
            <field name="name"/>
            <field name="sequence"/>
            <field name="active"/>
          </group>
          <group string="فلاتر">
            <field name="warehouse_id"/>
            <field name="product_categ_id"/>
            <field name="department_name"/>
          </group>
        </group>
        <group string="البعد المالي الناتج">
          <field name="dimension_id"/>
          <field name="analytic_account_id"/>
        </group>
        <field name="notes"/>
      </sheet>
    </form>
  </field>
</record>

<record id="view_dimension_rule_list" model="ir.ui.view">
  <field name="name">stock.finance.dimension.rule.list</field>
  <field name="model">stock.finance.dimension.rule</field>
  <field name="arch" type="xml">
    <tree string="قواعد الأبعاد المالية">
      <field name="sequence" widget="handle"/>
      <field name="name"/>
      <field name="warehouse_id"/>
      <field name="product_categ_id" optional="show"/>
      <field name="department_name" optional="show"/>
      <field name="dimension_id"/>
      <field name="analytic_account_id" optional="show"/>
      <field name="active" optional="show"/>
    </tree>
  </field>
</record>

<record id="action_dimension_rules" model="ir.actions.act_window">
  <field name="name">قواعد الأبعاد المالية</field>
  <field name="res_model">stock.finance.dimension.rule</field>
  <field name="view_mode">list,form</field>
</record>

</odoo>
