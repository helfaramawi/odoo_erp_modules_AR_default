<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_account_rule_form" model="ir.ui.view">
  <field name="name">stock.finance.account.rule.form</field>
  <field name="model">stock.finance.account.rule</field>
  <field name="arch" type="xml">
    <form string="قاعدة الحسابات المحاسبية">
      <sheet>
        <group>
          <group string="تعريف القاعدة">
            <field name="name"/>
            <field name="move_type"/>
            <field name="sequence"/>
            <field name="active"/>
          </group>
          <group string="فلاتر (اختيارية)">
            <field name="warehouse_id"/>
            <field name="product_categ_id"/>
          </group>
        </group>
        <group string="الحسابات المحاسبية">
          <group>
            <field name="debit_account_id"/>
            <field name="credit_account_id"/>
          </group>
          <group>
            <field name="journal_id"/>
            <field name="move_ref_template"/>
          </group>
        </group>
        <field name="notes"/>
      </sheet>
    </form>
  </field>
</record>

<record id="view_account_rule_list" model="ir.ui.view">
  <field name="name">stock.finance.account.rule.list</field>
  <field name="model">stock.finance.account.rule</field>
  <field name="arch" type="xml">
    <tree string="قواعد الحسابات المحاسبية">
      <field name="sequence" widget="handle"/>
      <field name="name"/>
      <field name="move_type"/>
      <field name="warehouse_id" optional="show"/>
      <field name="product_categ_id" optional="show"/>
      <field name="debit_account_id"/>
      <field name="credit_account_id"/>
      <field name="journal_id"/>
      <field name="active" optional="show"/>
    </tree>
  </field>
</record>

<record id="action_account_rules" model="ir.actions.act_window">
  <field name="name">قواعد الحسابات</field>
  <field name="res_model">stock.finance.account.rule</field>
  <field name="view_mode">list,form</field>
</record>

</odoo>
