<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_contract_price_list" model="ir.ui.view">
    <field name="name">contract.price.list</field>
    <field name="model">contract.price</field>
    <field name="arch" type="xml">
      <tree string="Contract Prices / أسعار العقود" decoration-muted="not active">
        <field name="name"/><field name="partner_id"/><field name="product_id"/>
        <field name="price"/><field name="currency_id"/>
        <field name="date_start"/><field name="date_end"/><field name="active"/>
      </tree>
    </field>
  </record>
  <record id="view_contract_price_form" model="ir.ui.view">
    <field name="name">contract.price.form</field>
    <field name="model">contract.price</field>
    <field name="arch" type="xml">
      <form string="Contract Price / سعر العقد">
        <sheet>
          <group>
            <group><field name="name"/><field name="partner_id"/><field name="product_id"/></group>
            <group><field name="price"/><field name="currency_id"/></group>
          </group>
          <group string="Validity / الصلاحية">
            <field name="date_start"/><field name="date_end"/>
          </group>
          <field name="notes"/>
        </sheet>
      </form>
    </field>
  </record>
  <record id="action_contract_prices" model="ir.actions.act_window">
    <field name="name">Contract Prices / أسعار العقود</field>
    <field name="res_model">contract.price</field>
    <field name="view_mode">tree,form</field>
  </record>
</odoo>