<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ══════════════════════════════════════════════════════════════
     كارت الأصل التفصيلي — Asset Card
══════════════════════════════════════════════════════════════ -->
<template id="rpt_asset_card">
  <t t-call="web.html_container">
    <t t-foreach="docs" t-as="doc">
      <t t-call="web.external_layout">
        <div class="page" style="direction:rtl;font-family:'Cairo','Amiri', 'Noto Naskh Arabic', Arial, sans-serif;font-size:10pt;">
<style>
  .o_company_logo,.o_address_name,.o_report_layout_header,
  header.o_report_layout_header,.odoo-header,.header-content,
  footer,.footer,.o_footer{display:none!important;}
  .page{margin-top:0!important;padding-top:0!important;}
</style>
          <table style="width:100%;border-collapse:collapse;margin-bottom:8px;border-bottom:2px solid #000;padding-bottom:6px;">
            <tr>
              <td style="width:78px;text-align:center;vertical-align:top;">&#160;</td>
              <td style="text-align:center;vertical-align:middle;">
                <div style="font-size:13pt;font-weight:bold;">جمهورية مصر العربية</div>
                <div style="font-size:12pt;font-weight:bold;">محافظة بورسعيد</div>
                <div style="font-size:11pt;">الإدارة العامة للشؤون المالية والإدارية</div>
                <div style="font-size:11pt;font-weight:bold;">إدارة الأصول الثابتة والمخازن</div>
              </td>
              <td style="width:78px;text-align:center;vertical-align:middle;">
                <img t-att-src="'data:image/png;base64,' + (env.company.logo.decode('utf-8') if env.company.logo else '')"
                     style="width:70px;height:70px;object-fit:contain;" alt="شعار المحافظة"/>
              </td>
            </tr>
          </table>

          <h2 style="text-align:center;font-size:13pt;text-decoration:underline;margin:10px 0;">
            كارت الأصل الثابت — <t t-esc="doc.asset_number"/>
          </h2>

          <!-- رأس الكارت -->
          <table style="width:100%;border-collapse:collapse;margin-bottom:10px;font-size:10pt;">
            <tr>
              <td style="width:25%;font-weight:bold;padding:4px;border:1px solid #ddd;background:#EBF5FB;">رقم الأصل</td>
              <td style="padding:4px;border:1px solid #ddd;font-weight:bold;color:#1F3864;"><t t-esc="doc.asset_number"/></td>
              <td style="width:25%;font-weight:bold;padding:4px;border:1px solid #ddd;background:#EBF5FB;">الفئة</td>
              <td style="padding:4px;border:1px solid #ddd;"><t t-esc="doc.category_id.name if doc.category_id else ''"/></td>
            </tr>
            <tr>
              <td style="font-weight:bold;padding:4px;border:1px solid #ddd;background:#EBF5FB;">الاسم</td>
              <td colspan="3" style="padding:4px;border:1px solid #ddd;"><t t-esc="doc.name"/></td>
            </tr>
            <tr>
              <td style="font-weight:bold;padding:4px;border:1px solid #ddd;background:#EBF5FB;">الإدارة</td>
              <td style="padding:4px;border:1px solid #ddd;"><t t-esc="doc.department_id.name if doc.department_id else '—'"/></td>
              <td style="font-weight:bold;padding:4px;border:1px solid #ddd;background:#EBF5FB;">أمين العهدة</td>
              <td style="padding:4px;border:1px solid #ddd;"><t t-esc="doc.custodian_employee_id.name if doc.custodian_employee_id else '—'"/></td>
            </tr>
            <tr>
              <td style="font-weight:bold;padding:4px;border:1px solid #ddd;background:#EBF5FB;">تكلفة الاقتناء</td>
              <td style="padding:4px;border:1px solid #ddd;font-weight:bold;color:#1F3864;"><t t-esc="'%s' % '{:,.2f}'.format(doc.purchase_value)"/> ج.م</td>
              <td style="font-weight:bold;padding:4px;border:1px solid #ddd;background:#EBF5FB;">معدل الإهلاك</td>
              <td style="padding:4px;border:1px solid #ddd;"><t t-esc="doc.depreciation_rate"/>% (<t t-esc="doc.category_id.method if doc.category_id else ''"/>)</td>
            </tr>
            <tr>
              <td style="font-weight:bold;padding:4px;border:1px solid #ddd;background:#EBF5FB;">تاريخ الاقتناء</td>
              <td style="padding:4px;border:1px solid #ddd;"><t t-esc="doc.purchase_date or '—'"/></td>
              <td style="font-weight:bold;padding:4px;border:1px solid #ddd;background:#EBF5FB;">نهاية العمر الإنتاجي</td>
              <td style="padding:4px;border:1px solid #ddd;font-weight:bold;"><t t-esc="doc.end_of_life_date or '—'"/></td>
            </tr>
            <tr>
              <td style="font-weight:bold;padding:4px;border:1px solid #ddd;background:#EBF5FB;">مرجع دفتر 55</td>
              <td style="padding:4px;border:1px solid #ddd;"><t t-esc="doc.daftar55_id.sequence_number if doc.daftar55_id else '—'"/></td>
              <td style="font-weight:bold;padding:4px;border:1px solid #ddd;background:#EBF5FB;">أمر الشراء</td>
              <td style="padding:4px;border:1px solid #ddd;"><t t-esc="doc.purchase_order_id.name if doc.purchase_order_id else '—'"/></td>
            </tr>
          </table>

          <!-- جدول الإهلاك التفصيلي -->
          <div style="background:#1F3864;color:white;padding:5px 10px;font-weight:bold;border-radius:4px 4px 0 0;">
            جدول الإهلاك التفصيلي
          </div>
          <table style="width:100%;border-collapse:collapse;font-size:10pt;margin-bottom:12px;">
            <thead>
              <tr style="background:#2E75B6;color:white;">
                <th style="padding:5px;border:1px solid #ddd;text-align:center;">السنة</th>
                <th style="padding:5px;border:1px solid #ddd;">تاريخ القيد</th>
                <th style="padding:5px;border:1px solid #ddd;">السنة المالية</th>
                <th style="padding:5px;border:1px solid #ddd;text-align:left;">مبلغ الإهلاك (ج.م)</th>
                <th style="padding:5px;border:1px solid #ddd;text-align:left;">القيمة الدفترية (ج.م)</th>
                <th style="padding:5px;border:1px solid #ddd;text-align:center;">حالة القيد</th>
              </tr>
            </thead>
            <tbody>
              <t t-foreach="doc.depreciation_line_ids" t-as="line">
                <tr t-attf-style="background:{{ '#f0f7ee' if line.move_id and line.move_id.state == 'posted' else '#fffde7' if not line.move_id else 'white' }};">
                  <td style="padding:4px;border:1px solid #ddd;text-align:center;font-weight:bold;color:#1F3864;"><t t-esc="line.sequence"/></td>
                  <td style="padding:4px;border:1px solid #ddd;"><t t-esc="line.depreciation_date or '—'"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:center;"><t t-esc="line.fiscal_year or '—'"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:left;font-weight:bold;"><t t-esc="'%s' % '{:,.2f}'.format(line.amount)"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:left;"><t t-esc="'%s' % '{:,.2f}'.format(line.remaining_value)"/></td>
                  <td style="padding:4px;border:1px solid #ddd;text-align:center;">
                    <t t-if="line.move_id and line.move_id.state == 'posted'">
                      <span style="color:#375623;font-weight:bold;">✔ مرحَّل</span>
                    </t>
                    <t t-elif="line.move_id">
                      <span style="color:#F39C12;font-weight:bold;">مسودة</span>
                    </t>
                    <t t-else="">
                      <span style="color:#999;">معلق</span>
                    </t>
                  </td>
                </tr>
              </t>
            </tbody>
            <tfoot>
              <tr style="background:#1F3864;color:white;font-weight:bold;">
                <td colspan="3" style="padding:5px;border:1px solid #ddd;text-align:center;">الإجمالي</td>
                <td style="padding:5px;border:1px solid #ddd;text-align:left;"><t t-esc="'%s' % '{:,.2f}'.format(sum(l.amount for l in doc.depreciation_line_ids))"/> ج.م</td>
                <td colspan="2" style="padding:5px;border:1px solid #ddd;text-align:center;">القيمة الدفترية الحالية: <t t-esc="'%s' % '{:,.2f}'.format(doc.book_value)"/> ج.م</td>
              </tr>
            </tfoot>
          </table>

          <!-- توقيعات -->
          <table style="width:100%;border-collapse:collapse;margin-top:16px;">
            <tr>
              <td style="width:33%;text-align:center;padding:12px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F3864;">رئيس قسم الأصول</div><div style="margin-top:22px;border-top:1px solid #999;padding-top:4px;font-size:9pt;color:#666;">الاسم والتوقيع</div></td>
              <td style="width:33%;text-align:center;padding:12px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F3864;">مدير الشؤون المالية</div><div style="margin-top:22px;border-top:1px solid #999;padding-top:4px;font-size:9pt;color:#666;">الاسم والتوقيع</div></td>
              <td style="width:33%;text-align:center;padding:12px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F3864;">رئيس الديوان العام</div><div style="margin-top:22px;border-top:1px solid #999;padding-top:4px;font-size:9pt;color:#666;">الاسم والختم الرسمي</div></td>
            </tr>
          </table>

          <div style="margin-top:8px;font-size:8pt;color:#555;text-align:center;border-top:1px solid #ccc;padding-top:4px;">
            نظام أوبو إيآر بي — Paradise Integrated Solutions
            طُبع بتاريخ: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d-%m-%Y %H:%M')"/>
            — محافظة بورسعيد
          </div>
        </div>
      </t>
    </t>
  </t>
</template>


<!-- ══════════════════════════════════════════════════════════════
     جدول الإهلاك المستقبلي
══════════════════════════════════════════════════════════════ -->
<template id="rpt_depreciation_schedule">
  <t t-call="web.html_container">
    <t t-foreach="docs" t-as="doc">
      <t t-call="web.external_layout">
        <div class="page" style="direction:rtl;font-family:'Cairo','Amiri', 'Noto Naskh Arabic', Arial, sans-serif;font-size:10pt;">
<style>
  .o_company_logo,.o_address_name,.o_report_layout_header,
  header.o_report_layout_header,.odoo-header,.header-content,
  footer,.footer,.o_footer{display:none!important;}
  .page{margin-top:0!important;padding-top:0!important;}
</style>
          <table style="width:100%;border-collapse:collapse;margin-bottom:8px;border-bottom:2px solid #000;padding-bottom:6px;">
            <tr>
              <td style="width:78px;text-align:center;vertical-align:top;">&#160;</td>
              <td style="text-align:center;vertical-align:middle;">
                <div style="font-size:13pt;font-weight:bold;">جمهورية مصر العربية</div>
                <div style="font-size:12pt;font-weight:bold;">محافظة بورسعيد</div>
                <div style="font-size:11pt;">الإدارة العامة للشؤون المالية والإدارية</div>
                <div style="font-size:11pt;font-weight:bold;">إدارة الأصول الثابتة</div>
              </td>
              <td style="width:78px;text-align:center;vertical-align:middle;">
                <img t-att-src="'data:image/png;base64,' + (env.company.logo.decode('utf-8') if env.company.logo else '')"
                     style="width:70px;height:70px;object-fit:contain;" alt="شعار المحافظة"/>
              </td>
            </tr>
          </table>

          <h2 style="text-align:center;font-size:13pt;text-decoration:underline;margin:10px 0;">
            جدول الإهلاك — <t t-esc="doc.asset_number"/> — <t t-esc="doc.name"/>
          </h2>

          <!-- ملخص الأصل -->
          <table style="width:100%;border-collapse:collapse;margin-bottom:10px;">
            <tr>
              <td style="padding:6px;border:1px solid #ddd;text-align:center;background:#EBF5FB;">
                <div style="font-size:12pt;font-weight:bold;color:#1F3864;"><t t-esc="'%s' % '{:,.2f}'.format(doc.purchase_value)"/> ج.م</div>
                <div style="font-size:9pt;color:#666;">تكلفة الاقتناء</div>
              </td>
              <td style="padding:6px;border:1px solid #ddd;text-align:center;background:#FFF3E0;">
                <div style="font-size:12pt;font-weight:bold;color:#C55A11;"><t t-esc="'%s' % '{:,.2f}'.format(doc.accumulated_depreciation)"/> ج.م</div>
                <div style="font-size:9pt;color:#666;">مجمع الإهلاك المرحَّل</div>
              </td>
              <td style="padding:6px;border:1px solid #ddd;text-align:center;background:#E8F5E9;">
                <div style="font-size:12pt;font-weight:bold;color:#375623;"><t t-esc="'%s' % '{:,.2f}'.format(doc.book_value)"/> ج.م</div>
                <div style="font-size:9pt;color:#666;">القيمة الدفترية الحالية</div>
              </td>
              <td style="padding:6px;border:1px solid #ddd;text-align:center;background:#f5f5f5;">
                <div style="font-size:11pt;font-weight:bold;color:#333;"><t t-esc="doc.depreciation_rate"/>% سنوياً</div>
                <div style="font-size:9pt;color:#666;"><t t-esc="doc.category_id.useful_life_years if doc.category_id else 0"/> سنة</div>
              </td>
            </tr>
          </table>

          <!-- جدول الإهلاك -->
          <table style="width:100%;border-collapse:collapse;font-size:10pt;">
            <thead>
              <tr style="background:#1F3864;color:white;">
                <th style="padding:6px;border:1px solid #ddd;text-align:center;">السنة</th>
                <th style="padding:6px;border:1px solid #ddd;">السنة المالية</th>
                <th style="padding:6px;border:1px solid #ddd;">تاريخ الإهلاك</th>
                <th style="padding:6px;border:1px solid #ddd;text-align:left;">القيمة الدفترية أول المدة</th>
                <th style="padding:6px;border:1px solid #ddd;text-align:left;">قسط الإهلاك</th>
                <th style="padding:6px;border:1px solid #ddd;text-align:left;">مجمع الإهلاك</th>
                <th style="padding:6px;border:1px solid #ddd;text-align:left;">القيمة الدفترية آخر المدة</th>
                <th style="padding:6px;border:1px solid #ddd;text-align:center;">الحالة</th>
              </tr>
            </thead>
            <tbody>
              <t t-set="cumulative_dep" t-value="0.0"/>
              <t t-foreach="doc.depreciation_line_ids" t-as="line">
                <t t-set="bov" t-value="doc.purchase_value - cumulative_dep"/>
                <t t-set="cumulative_dep" t-value="cumulative_dep + line.amount"/>
                <tr t-attf-style="background:{{ '#f0f7ee' if line.move_id and line.move_id.state == 'posted' else '#fffff0' if not line.move_id else 'white' }};">
                  <td style="padding:5px;border:1px solid #ddd;text-align:center;font-weight:bold;color:#1F3864;"><t t-esc="line.sequence"/></td>
                  <td style="padding:5px;border:1px solid #ddd;text-align:center;"><t t-esc="line.fiscal_year or '—'"/></td>
                  <td style="padding:5px;border:1px solid #ddd;"><t t-esc="line.depreciation_date or '—'"/></td>
                  <td style="padding:5px;border:1px solid #ddd;text-align:left;"><t t-esc="'%s' % '{:,.2f}'.format(bov)"/></td>
                  <td style="padding:5px;border:1px solid #ddd;text-align:left;font-weight:bold;color:#1F3864;"><t t-esc="'%s' % '{:,.2f}'.format(line.amount)"/></td>
                  <td style="padding:5px;border:1px solid #ddd;text-align:left;color:#C55A11;"><t t-esc="'%s' % '{:,.2f}'.format(cumulative_dep)"/></td>
                  <td style="padding:5px;border:1px solid #ddd;text-align:left;font-weight:bold;color:#375623;"><t t-esc="'%s' % '{:,.2f}'.format(line.remaining_value)"/></td>
                  <td style="padding:5px;border:1px solid #ddd;text-align:center;font-size:9pt;">
                    <t t-if="line.move_id and line.move_id.state == 'posted'"><span style="color:#375623;font-weight:bold;">✔ مرحَّل</span></t>
                    <t t-else=""><span style="color:#999;">معلق</span></t>
                  </td>
                </tr>
              </t>
            </tbody>
          </table>

          <table style="width:100%;border-collapse:collapse;margin-top:16px;">
            <tr>
              <td style="width:33%;text-align:center;padding:12px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F3864;">رئيس قسم الأصول</div><div style="margin-top:22px;border-top:1px solid #999;padding-top:4px;font-size:9pt;color:#666;">الاسم والتوقيع</div></td>
              <td style="width:33%;text-align:center;padding:12px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F3864;">مدير الشؤون المالية</div><div style="margin-top:22px;border-top:1px solid #999;padding-top:4px;font-size:9pt;color:#666;">الاسم والتوقيع</div></td>
              <td style="width:33%;text-align:center;padding:12px;border:1px solid #ccc;"><div style="font-weight:bold;color:#1F3864;">رئيس الديوان العام</div><div style="margin-top:22px;border-top:1px solid #999;padding-top:4px;font-size:9pt;color:#666;">الاسم والختم الرسمي</div></td>
            </tr>
          </table>

          <div style="margin-top:8px;font-size:8pt;color:#555;text-align:center;border-top:1px solid #ccc;padding-top:4px;">
            نظام أوبو إيآر بي — Paradise Integrated Solutions
            طُبع بتاريخ: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d-%m-%Y %H:%M')"/>
            — محافظة بورسعيد
          </div>
        </div>
      </t>
    </t>
  </t>
</template>

</odoo>
