<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Delete old client action if exists, then create act_url -->
    <delete model="ir.actions.client" search="[('tag','=','portsaid_dashboard')]"/>

    <record id="action_portsaid_dashboard_url" model="ir.actions.act_url">
        <field name="name">لوحة القيادة التنفيذية</field>
        <field name="url">/portsaid/dashboard</field>
        <field name="target">new</field>
    </record>
</odoo>
