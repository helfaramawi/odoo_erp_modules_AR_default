<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="report_dossier_template">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="rec">
        <t t-call="web.external_layout">
          <div class="page" style="direction:rtl; font-family:'Amiri', 'Noto Naskh Arabic', Arial, sans-serif; font-size:12px;">
            <!-- ═══ هيدر الديوان العام — شعار المحافظة ═══ -->
            <div style="direction:rtl; display:table; width:100%; border-bottom:3px double #1F497D; padding-bottom:10px; margin-bottom:14px;">
              <!-- شعار المحافظة — يسار الصفحة (يمين في RTL) -->
              <div style="display:table-cell; width:80px; vertical-align:middle; text-align:center;">
                <img t-if="rec.company_id.logo"
                     t-att-src="'data:image/png;base64,' + rec.company_id.logo.decode('utf-8')"
                     style="max-height:70px; max-width:70px; object-fit:contain;"
                     alt="شعار المحافظة"/>
                <div t-else="" style="width:70px; height:70px; border:2px solid #1F497D; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:9px; color:#1F497D; text-align:center; line-height:1.3;">
                  شعار<br/>المحافظة
                </div>
              </div>
              <!-- النص المركزي -->
              <div style="display:table-cell; vertical-align:middle; text-align:center; padding:0 10px;">
                <div style="font-size:11px; color:#666; margin-bottom:2px;">جمهورية مصر العربية — محافظة بورسعيد</div>
                <div style="font-size:17px; font-weight:bold; color:#1F497D; margin-bottom:2px;">الديوان العام لمحافظة بورسعيد</div>
                <div style="font-size:13px; font-weight:bold; color:#333; margin-bottom:4px;">استمارة 101 ساير — سجل الاضابير</div>
                <div style="font-size:9px; color:#999;">Paradise Integrated Solutions | إدارة المالية</div>
              </div>
              <!-- رقم السجل / التاريخ — يمين الصفحة (يسار في RTL) -->
              <div style="display:table-cell; width:100px; vertical-align:middle; text-align:center; font-size:10px; color:#444;">
                <div style="border:1px solid #ddd; border-radius:4px; padding:4px 6px; background:#f9f9f9;">
                  <div style="color:#1F497D; font-weight:bold; margin-bottom:2px;">رقم المستند</div>
                  <div><t t-esc="rec.dossier_number or ''"/></div>
                  <div style="margin-top:4px; color:#666;">التاريخ</div>
                  <div><t t-esc="rec.fiscal_year or ''"/></div>
                </div>
              </div>
            </div>
            <!-- ════════════════════════════════════════════════ -->

            <table style="width:100%; border-collapse:collapse; font-size:11px; margin-bottom:12px;">
              <tr>
                <td style="width:25%; color:#444; padding:5px 0;">رقم الاضبارة:</td>
                <td style="border-bottom:1px solid #999; font-weight:bold; padding:5px 8px;"><t t-esc="rec.dossier_number"/></td>
                <td style="width:25%; color:#444; padding:5px 0;">السنة المالية:</td>
                <td style="border-bottom:1px solid #999; padding:5px 8px;"><t t-esc="rec.fiscal_year"/></td>
              </tr>
              <tr>
                <td style="color:#444; padding:5px 0;">البند:</td>
                <td style="border-bottom:1px solid #999; padding:5px 8px;"><t t-esc="rec.budget_line"/></td>
                <td style="color:#444; padding:5px 0;">رقم استمارة 50:</td>
                <td style="border-bottom:1px solid #999; padding:5px 8px;"><t t-esc="rec.form50_ref or ''"/></td>
              </tr>
              <tr>
                <td style="color:#444; padding:5px 0;">صاحب الحق:</td>
                <td style="border-bottom:1px solid #999; padding:5px 8px;"><t t-esc="rec.vendor_id.name if rec.vendor_id else ''"/></td>
                <td style="color:#444; padding:5px 0;">المبلغ:</td>
                <td style="border-bottom:1px solid #999; font-weight:bold; padding:5px 8px;"><t t-esc="rec.amount"/> جنيه</td>
              </tr>
              <tr>
                <td style="color:#444; padding:5px 0;">موقع الأرشيف الورقي:</td>
                <td colspan="3" style="border-bottom:1px solid #999; padding:5px 8px;"><t t-esc="rec.physical_shelf or '_______________'"/></td>
              </tr>
            </table>

            <div style="border:1px solid #C55A11; padding:8px; margin-bottom:12px;">
              <div style="background:#C55A11; color:white; padding:4px 8px; margin:-8px -8px 8px; font-weight:bold;">
                قائمة المرفقات (<t t-esc="rec.attachment_count"/> من 10)
                <t t-if="rec.is_complete"> &#8212; مكتملة</t>
                <t t-if="not rec.is_complete"> &#8212; ناقصة</t>
              </div>
              <table style="width:100%; font-size:10px; margin-top:4px;">
                <thead>
                  <tr style="background:#FBE9D8;">
                    <th style="padding:4px; text-align:right;">م</th>
                    <th style="padding:4px; text-align:right;">نوع المرفق</th>
                    <th style="padding:4px; text-align:right;">الحالة</th>
                    <th style="padding:4px; text-align:right;">ملاحظة</th>
                  </tr>
                </thead>
                <tbody>
                  <t t-foreach="rec.attachment_ids" t-as="att">
                    <tr style="border-bottom:0.5px solid #eee;">
                      <td style="padding:4px;"><t t-esc="att_index + 1"/></td>
                      <td style="padding:4px;"><t t-esc="dict(att._fields['attachment_type'].selection).get(att.attachment_type)"/></td>
                      <td style="padding:4px; color:green;">&#10003; مرفق</td>
                      <td style="padding:4px;"><t t-esc="att.notes or ''"/></td>
                    </tr>
                  </t>
                </tbody>
              </table>
              <t t-if="rec.missing_attachments">
                <div style="margin-top:8px; padding:6px; background:#FFF0F0; border:1px solid #ffcccc; font-size:10px; color:#c00;">
                  <strong>مرفقات ناقصة:</strong> <t t-esc="rec.missing_attachments"/>
                </div>
              </t>
            </div>

            <table style="width:100%; margin-top:24px; font-size:11px;">
              <tr>
                <td style="text-align:center; width:50%; padding:8px;">
                  <div style="border-bottom:1px solid #666; margin-bottom:4px; min-height:28px;"></div>
                  مدير الحسابات
                </td>
                <td style="text-align:center; width:50%; padding:8px;">
                  <div style="border-bottom:1px solid #666; margin-bottom:4px; min-height:28px;"></div>
                  رئيس المصلحة
                </td>
              </tr>
            </table>
          </div>
        </t>
      </t>
    </t>
  </template>
</odoo>
