<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="report_insurance_receipt">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="d">
        <t t-call="web.external_layout">
          <div class="page" dir="rtl"
               style="font-family:'Traditional Arabic',Arial,serif;">

            <div style="text-align:center; margin-bottom:15px;">
              <h3 style="margin:0;">إيصال إيداع تأمين</h3>
              <div style="font-size:11px;">
                <t t-if="d.book_classification == 'provisional'">دفتر التأمينات المؤقتة</t>
                <t t-if="d.book_classification == 'final'">دفتر التأمينات النهائية</t>
                — استمارة 78 ع.ح — محافظة بورسعيد
              </div>
            </div>

            <table style="width:100%; font-size:11px; border-collapse:collapse;
                          border:1px solid #000;">
              <tr>
                <td style="padding:5px; border:1px solid #000; background:#f0f0f0; width:30%;">
                  <strong>رقم الإيداع</strong>
                </td>
                <td style="padding:5px; border:1px solid #000; font-family:monospace;
                           font-weight:bold;">
                  <t t-out="d.name"/>
                </td>
              </tr>
              <tr>
                <td style="padding:5px; border:1px solid #000; background:#f0f0f0;">
                  <strong>تسلسل دفتر 78</strong>
                </td>
                <td style="padding:5px; border:1px solid #000; font-family:monospace;">
                  <t t-out="d.form78_sequence or '—'"/>
                </td>
              </tr>
              <tr>
                <td style="padding:5px; border:1px solid #000; background:#f0f0f0;">
                  <strong>نوع التأمين</strong>
                </td>
                <td style="padding:5px; border:1px solid #000;">
                  <t t-out="dict(d._fields['deposit_type'].selection).get(d.deposit_type)"/>
                </td>
              </tr>
              <tr>
                <td style="padding:5px; border:1px solid #000; background:#f0f0f0;">
                  <strong>صيغة الإيداع</strong>
                </td>
                <td style="padding:5px; border:1px solid #000;">
                  <t t-out="dict(d._fields['collateral_type'].selection).get(d.collateral_type)"/>
                </td>
              </tr>
              <tr>
                <td style="padding:5px; border:1px solid #000; background:#f0f0f0;">
                  <strong>المورد / المقاول</strong>
                </td>
                <td style="padding:5px; border:1px solid #000;">
                  <t t-out="d.vendor_id.name"/>
                </td>
              </tr>
              <tr>
                <td style="padding:5px; border:1px solid #000; background:#f0f0f0;">
                  <strong>قيمة التأمين</strong>
                </td>
                <td style="padding:5px; border:1px solid #000; font-weight:bold;">
                  <t t-out="'%.2f' % d.amount"/>
                  <span t-field="d.currency_id.symbol"/>
                </td>
              </tr>
              <tr t-if="d.percentage">
                <td style="padding:5px; border:1px solid #000; background:#f0f0f0;">
                  <strong>النسبة من العقد</strong>
                </td>
                <td style="padding:5px; border:1px solid #000;">
                  <t t-out="'%.2f %%' % d.percentage"/>
                </td>
              </tr>
              <tr t-if="d.contract_value">
                <td style="padding:5px; border:1px solid #000; background:#f0f0f0;">
                  <strong>قيمة العقد</strong>
                </td>
                <td style="padding:5px; border:1px solid #000;">
                  <t t-out="'%.2f' % d.contract_value"/>
                </td>
              </tr>
              <tr>
                <td style="padding:5px; border:1px solid #000; background:#f0f0f0;">
                  <strong>تاريخ الإيداع</strong>
                </td>
                <td style="padding:5px; border:1px solid #000;">
                  <t t-out="d.deposit_date"/>
                </td>
              </tr>
              <tr t-if="d.expiry_date">
                <td style="padding:5px; border:1px solid #000; background:#f0f0f0;">
                  <strong>تاريخ الانتهاء المخطط</strong>
                </td>
                <td style="padding:5px; border:1px solid #000;">
                  <t t-out="d.expiry_date"/>
                </td>
              </tr>
              <tr t-if="d.cash_receipt_number">
                <td style="padding:5px; border:1px solid #000; background:#f0f0f0;">
                  <strong>رقم إيصال التوريد</strong>
                </td>
                <td style="padding:5px; border:1px solid #000; font-family:monospace;">
                  <t t-out="d.cash_receipt_number"/>
                </td>
              </tr>
              <tr t-if="d.cheque_id">
                <td style="padding:5px; border:1px solid #000; background:#f0f0f0;">
                  <strong>تفاصيل الشيك</strong>
                </td>
                <td style="padding:5px; border:1px solid #000;">
                  رقم: <t t-out="d.cheque_id.cheque_number"/>
                  — البنك: <t t-out="d.cheque_id.drawn_on_bank"/>
                </td>
              </tr>
            </table>

            <!-- Signatures -->
            <table style="width:100%; margin-top:40px; font-size:10px;"
                   class="table-borderless">
              <tr>
                <td style="text-align:center;">
                  <div>المورد (استلام الإيصال)</div>
                  <div style="margin-top:30px; border-top:1px solid #000; padding-top:3px;">
                    ............................
                  </div>
                </td>
                <td style="text-align:center;">
                  <div>أمين الخزينة</div>
                  <div style="margin-top:30px; border-top:1px solid #000; padding-top:3px;">
                    ............................
                  </div>
                </td>
                <td style="text-align:center;">
                  <div>رئيس الحسابات</div>
                  <div style="margin-top:30px; border-top:1px solid #000; padding-top:3px;">
                    ............................
                  </div>
                </td>
              </tr>
            </table>

            <div style="margin-top:20px; padding:8px; border:1px dashed #888; font-size:9px;">
              <strong>تنبيه قانوني:</strong> هذا الإيصال دليل قانوني لالتزام المحافظة بإرجاع
              قيمة التأمين للمورد عند انتهاء العقد أو اعتماد التسليم، ما لم تُصادَر
              بأمر إداري مسبب. يُحفَظ هذا الإيصال في ملف العقد وفي ملف التأمينات.
            </div>

          </div>
          <p style="page-break-after: always;"/>
        </t>
      </t>
    </t>
  </template>

</odoo>
