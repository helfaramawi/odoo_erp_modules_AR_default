<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="group_insurance_user" model="res.groups">
    <field name="name">دفاتر التأمينات — مستخدم</field>
    <field name="category_id" ref="base.module_category_accounting_accounting"/>
    <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
  </record>

  <record id="group_insurance_manager" model="res.groups">
    <field name="name">دفاتر التأمينات — مدير</field>
    <field name="category_id" ref="base.module_category_accounting_accounting"/>
    <field name="implied_ids" eval="[(4, ref('group_insurance_user')), (4, ref('account.group_account_manager'))]"/>
  </record>
</odoo>
