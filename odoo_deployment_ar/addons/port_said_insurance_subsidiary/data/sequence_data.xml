<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- تسلسل إيداعات التأمين (name field) -->
  <record id="seq_insurance_deposit" model="ir.sequence">
    <field name="name">إيداعات التأمين</field>
    <field name="code">port_said.insurance_deposit</field>
    <field name="prefix">DEP/%(year)s/</field>
    <field name="padding">5</field>
    <field name="use_date_range">True</field>
    <field name="company_id" eval="False"/>
  </record>

  <!-- تسلسل دفتر 78 - تأمينات مؤقتة (للسجل الفعلي) -->
  <record id="seq_insurance_provisional" model="ir.sequence">
    <field name="name">دفتر 78 - تأمينات مؤقتة</field>
    <field name="code">port_said.insurance.provisional</field>
    <field name="prefix">78-PRV/%(year)s/</field>
    <field name="padding">4</field>
    <field name="use_date_range">True</field>
    <field name="company_id" eval="False"/>
  </record>

  <!-- تسلسل دفتر 78 - تأمينات نهائية -->
  <record id="seq_insurance_final" model="ir.sequence">
    <field name="name">دفتر 78 - تأمينات نهائية</field>
    <field name="code">port_said.insurance.final</field>
    <field name="prefix">78-FNL/%(year)s/</field>
    <field name="padding">4</field>
    <field name="use_date_range">True</field>
    <field name="company_id" eval="False"/>
  </record>

  <!-- تسلسل الفولية - مؤقت -->
  <record id="seq_insurance_folio_provisional" model="ir.sequence">
    <field name="name">فوليوهات دفتر التأمينات المؤقتة</field>
    <field name="code">port_said.insurance.folio.provisional</field>
    <field name="prefix">FOL-PRV/%(year)s/</field>
    <field name="padding">4</field>
    <field name="use_date_range">True</field>
    <field name="company_id" eval="False"/>
  </record>

  <!-- تسلسل الفولية - نهائي -->
  <record id="seq_insurance_folio_final" model="ir.sequence">
    <field name="name">فوليوهات دفتر التأمينات النهائية</field>
    <field name="code">port_said.insurance.folio.final</field>
    <field name="prefix">FOL-FNL/%(year)s/</field>
    <field name="padding">4</field>
    <field name="use_date_range">True</field>
    <field name="company_id" eval="False"/>
  </record>

  <!-- Cron: توليد فوليوهات شهرياً -->
  <record id="cron_insurance_generate_monthly" model="ir.cron">
    <field name="name">دفاتر التأمينات — توليد فوليوهات شهرية</field>
    <field name="model_id" ref="model_port_said_insurance_folio"/>
    <field name="state">code</field>
    <field name="code">model.cron_generate_monthly_folios()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">months</field>
    <field name="numbercall">-1</field>
    <field name="active" eval="True"/>
  </record>

</odoo>
