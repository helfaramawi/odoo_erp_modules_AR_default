<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_release_wizard_form" model="ir.ui.view">
    <field name="name">port_said.insurance.release.wizard.form</field>
    <field name="model">port_said.insurance.release.wizard</field>
    <field name="arch" type="xml">
      <form string="إفراج جماعي عن التأمينات">
        <sheet>
          <group>
            <field name="release_date"/>
            <field name="release_reason" placeholder="السبب القانوني أو الإداري للإفراج..."/>
          </group>
          <notebook>
            <page string="خطابات الضمان" invisible="not bank_guarantee_ids">
              <field name="bank_guarantee_ids" readonly="1">
                <tree>
                  <field name="name"/>
                  <field name="vendor_id"/>
                  <field name="amount"/>
                  <field name="state"/>
                </tree>
              </field>
            </page>
            <page string="الإيداعات" invisible="not deposit_ids">
              <field name="deposit_ids" readonly="1">
                <tree>
                  <field name="name"/>
                  <field name="vendor_id"/>
                  <field name="amount"/>
                  <field name="collateral_type"/>
                  <field name="state"/>
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
        <footer>
          <button name="action_release_all" type="object" string="تأكيد الإفراج" class="oe_highlight"/>
          <button special="cancel" string="إلغاء"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_release_wizard_guarantees" model="ir.actions.act_window">
    <field name="name">إفراج جماعي</field>
    <field name="res_model">port_said.insurance.release.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="binding_model_id" ref="port_said_advances.model_port_said_bank_guarantee"/>
  </record>

  <record id="action_release_wizard_deposits" model="ir.actions.act_window">
    <field name="name">إفراج جماعي</field>
    <field name="res_model">port_said.insurance.release.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="binding_model_id" ref="model_port_said_insurance_deposit"/>
  </record>

</odoo>
