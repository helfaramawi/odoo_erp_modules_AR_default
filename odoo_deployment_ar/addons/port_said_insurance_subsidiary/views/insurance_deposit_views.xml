<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_insurance_deposit_tree" model="ir.ui.view">
    <field name="name">port_said.insurance_deposit.tree</field>
    <field name="model">port_said.insurance_deposit</field>
    <field name="arch" type="xml">
      <tree string="إيداعات التأمينات"
            decoration-info="state == 'draft'"
            decoration-success="state == 'active'"
            decoration-muted="state == 'released'"
            decoration-danger="state == 'forfeited'">
        <field name="name"/>
        <field name="form78_sequence"/>
        <field name="book_classification"/>
        <field name="collateral_type"/>
        <field name="vendor_id"/>
        <field name="amount" sum="إجمالي"/>
        <field name="deposit_date"/>
        <field name="state"/>
      </tree>
    </field>
  </record>

  <record id="view_insurance_deposit_form" model="ir.ui.view">
    <field name="name">port_said.insurance_deposit.form</field>
    <field name="model">port_said.insurance_deposit</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_activate" type="object" string="تفعيل الإيداع"
                  invisible="state != 'draft'" class="oe_highlight"/>
          <button name="action_release" type="object" string="إفراج"
                  invisible="state != 'active'"/>
          <button name="action_forfeit" type="object" string="مصادرة"
                  invisible="state != 'active'"
                  groups="account.group_account_manager"
                  confirm="المصادرة إجراء نهائي لا رجعة فيه."/>
          <field name="state" widget="statusbar"
                 statusbar_visible="draft,active,released"/>
        </header>
        <sheet>
          <div class="oe_title">
            <label for="name"/>
            <h1><field name="name" readonly="1"/></h1>
          </div>
          <group>
            <group string="التصنيف">
              <field name="deposit_type"/>
              <field name="book_classification" readonly="1"/>
              <field name="collateral_type"/>
              <field name="form78_sequence" readonly="1"/>
              <field name="fiscal_year" readonly="1"/>
            </group>
            <group string="المورد والعقد">
              <field name="vendor_id"/>
              <field name="purchase_order_id"/>
              <field name="contract_value"/>
              <field name="percentage"/>
            </group>
          </group>
          <group string="المبلغ والتواريخ">
            <group>
              <field name="amount"/>
              <field name="currency_id" invisible="1"/>
              <field name="deposit_date"/>
              <field name="expiry_date"/>
              <field name="release_date" readonly="1"/>
            </group>
          </group>

          <group string="تفاصيل الإيداع النقدي"
                 invisible="collateral_type != 'cash'">
            <field name="cash_receipt_number"
                   required="collateral_type == 'cash'"/>
            <field name="cash_account_id"/>
          </group>

          <group string="تفاصيل الإيداع بشيك"
                 invisible="collateral_type != 'cheque'">
            <field name="cheque_id"
                   required="collateral_type == 'cheque'"
                   options="{'no_create': True}"/>
          </group>

          <notebook>
            <page string="القيود والفولية">
              <group>
                <group>
                  <field name="activation_move_id" readonly="1"/>
                  <field name="release_move_id" readonly="1"/>
                </group>
                <group>
                  <field name="insurance_folio_id" readonly="1"/>
                </group>
              </group>
            </page>
            <page string="الإفراج / المصادرة"
                  invisible="state not in ['released','forfeited']">
              <field name="release_reason"/>
            </page>
            <page string="ملاحظات">
              <field name="notes"/>
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter">
          <field name="message_follower_ids"/>
          <field name="activity_ids"/>
          <field name="message_ids"/>
        </div>
      </form>
    </field>
  </record>

  <record id="view_insurance_deposit_search" model="ir.ui.view">
    <field name="name">port_said.insurance_deposit.search</field>
    <field name="model">port_said.insurance_deposit</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="form78_sequence"/>
        <field name="vendor_id"/>
        <field name="cash_receipt_number"/>
        <separator/>
        <filter string="مُودَع" name="f_active" domain="[('state','=','active')]"/>
        <filter string="مُفرَج عنه" name="f_released" domain="[('state','=','released')]"/>
        <filter string="مُصادَر" name="f_forfeited" domain="[('state','=','forfeited')]"/>
        <separator/>
        <filter string="تأمين مؤقت" name="f_prov"
                domain="[('book_classification','=','provisional')]"/>
        <filter string="تأمين نهائي" name="f_final"
                domain="[('book_classification','=','final')]"/>
        <separator/>
        <filter string="نقدية" name="f_cash" domain="[('collateral_type','=','cash')]"/>
        <filter string="بشيك" name="f_cheque" domain="[('collateral_type','=','cheque')]"/>
        <group expand="1" string="تجميع حسب">
          <filter string="التصنيف" name="g_class" context="{'group_by':'book_classification'}"/>
          <filter string="الصيغة" name="g_col" context="{'group_by':'collateral_type'}"/>
          <filter string="الحالة" name="g_state" context="{'group_by':'state'}"/>
          <filter string="المورد" name="g_vendor" context="{'group_by':'vendor_id'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="action_insurance_deposit" model="ir.actions.act_window">
    <field name="name">إيداعات التأمينات</field>
    <field name="res_model">port_said.insurance_deposit</field>
    <field name="view_mode">tree,form</field>
    <field name="search_view_id" ref="view_insurance_deposit_search"/>
  </record>

</odoo>
