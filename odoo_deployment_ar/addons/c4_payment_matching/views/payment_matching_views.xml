<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_account_payment_form_c4" model="ir.ui.view">
    <field name="name">account.payment.form.c4</field>
    <field name="model">account.payment</field>
    <field name="inherit_id" ref="account.view_account_payment_form"/>
    <field name="arch" type="xml">
      <xpath expr="//notebook" position="inside">
        <page string="Payment Matching / مطابقة الدفع"
              invisible="payment_type != 'outbound'">
          <group>
            <field name="override_matching"/>
            <field name="early_pay_discount"/>
            <field name="discount_account_id"
                   invisible="not early_pay_discount"/>
          </group>
        </page>
      </xpath>
    </field>
  </record>
</odoo>