<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="report_form75_template">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="rec">
        <t t-call="web.external_layout">
          <div class="page" style="direction:rtl; font-family:'Amiri', 'Noto Naskh Arabic', Arial, sans-serif;">
            <!-- ═══ هيدر الديوان العام — شعار المحافظة ═══ -->
            <div style="direction:rtl; display:table; width:100%; border-bottom:3px double #1F497D; padding-bottom:10px; margin-bottom:14px;">
              <!-- شعار المحافظة — يسار الصفحة (يمين في RTL) -->
              <div style="display:table-cell; width:80px; vertical-align:middle; text-align:center;">
                <img t-if="rec.company_id.logo"
                     t-att-src="'data:image/png;base64,' + rec.company_id.logo.decode('utf-8')"
                     style="max-height:70px; max-width:70px; object-fit:contain;"
                     alt="شعار المحافظة"/>
                <div t-else="" style="width:70px; height:70px; border:2px solid #1F497D; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:9px; color:#1F497D; text-align:center; line-height:1.3;">
                  شعار<br/>المحافظة
                </div>
              </div>
              <!-- النص المركزي -->
              <div style="display:table-cell; vertical-align:middle; text-align:center; padding:0 10px;">
                <div style="font-size:11px; color:#666; margin-bottom:2px;">جمهورية مصر العربية — محافظة بورسعيد</div>
                <div style="font-size:17px; font-weight:bold; color:#1F497D; margin-bottom:2px;">الديوان العام لمحافظة بورسعيد</div>
                <div style="font-size:13px; font-weight:bold; color:#333; margin-bottom:4px;">استمارة 75 ع.ح — الحسابات الشهرية والختامية</div>
                <div style="font-size:9px; color:#999;">Paradise Integrated Solutions | إدارة المالية</div>
              </div>
              <!-- رقم السجل / التاريخ — يمين الصفحة (يسار في RTL) -->
              <div style="display:table-cell; width:100px; vertical-align:middle; text-align:center; font-size:10px; color:#444;">
                <div style="border:1px solid #ddd; border-radius:4px; padding:4px 6px; background:#f9f9f9;">
                  <div style="color:#1F497D; font-weight:bold; margin-bottom:2px;">رقم المستند</div>
                  <div><t t-esc="rec.display_name or ''"/></div>
                  <div style="margin-top:4px; color:#666;">التاريخ</div>
                  <div><t t-esc="str(rec.fiscal_year) + '/' + str(rec.fiscal_period)"/></div>
                </div>
              </div>
            </div>
            <!-- ════════════════════════════════════════════════ -->

            <p style="text-align:center;"><t t-esc="rec.display_name"/></p>
            <table class="table table-bordered" style="width:70%; margin:auto; font-size:13px;">
              <tr><td>الرصيد الافتتاحي</td><td style="text-align:left;"><t t-esc="rec.opening_balance"/></td></tr>
              <tr><td>إجمالي الصرفيات</td><td style="text-align:left;"><t t-esc="rec.total_sarfiyat"/></td></tr>
              <tr><td>إجمالي التسويات</td><td style="text-align:left;"><t t-esc="rec.total_taswiyat"/></td></tr>
              <tr style="font-weight:bold; background:#FFF9C4;"><td>الرصيد الختامي</td><td style="text-align:left;"><t t-esc="rec.closing_balance"/></td></tr>
            </table>
            <div style="margin-top:40px; font-size:12px;">
              <h5 style="text-align:center; color:#1F497D;">مذكرة التوقيعات المعتمدة — 3 مراحل متسلسلة</h5>
              <table style="width:100%; border-top:1px solid #1F497D; padding-top:16px;">
                <tr>
                  <td style="text-align:center; width:33%;">
                    <strong>مراقب الحسابات</strong><br/><br/>
                    _________________<br/>
                    <t t-esc="rec.stage1_user_id.name if rec.stage1_user_id else ''"/><br/>
                    <small><t t-esc="rec.stage1_date or ''"/></small>
                  </td>
                  <td style="text-align:center; width:33%;">
                    <strong>مدير الحسابات</strong><br/><br/>
                    _________________<br/>
                    <t t-esc="rec.stage2_user_id.name if rec.stage2_user_id else ''"/><br/>
                    <small><t t-esc="rec.stage2_date or ''"/></small>
                  </td>
                  <td style="text-align:center; width:33%;">
                    <strong>رئيس المصلحة</strong><br/><br/>
                    _________________<br/>
                    <t t-esc="rec.stage3_user_id.name if rec.stage3_user_id else ''"/><br/>
                    <small><t t-esc="rec.stage3_date or ''"/></small>
                  </td>
                </tr>
              </table>
            </div>
          </div>
        </t>
      </t>
    </t>
  </template>
</odoo>
