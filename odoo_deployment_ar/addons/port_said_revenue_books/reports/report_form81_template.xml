<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="report_form81">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="folio">
        <t t-call="web.external_layout">
          <t t-set="matrix" t-value="folio._get_matrix_for_print()"/>
          <t t-set="cols" t-value="matrix['columns']"/>
          <t t-set="labels" t-value="matrix['column_labels']"/>
          <t t-set="ctotals" t-value="matrix['column_totals']"/>

          <div class="page" dir="rtl"
               style="font-family:'Traditional Arabic',Arial,serif;">

            <div style="text-align:center; margin-bottom:10px;">
              <h3 style="margin:0;"><t t-out="folio.book_id.name"/></h3>
              <div style="font-size:11px;">
                استمارة رقم <t t-out="folio.book_id.form_number"/>
                —
                <t t-if="folio.book_id.direction == 'revenues'">الموارد (الأبواب 7-9)</t>
                <t t-elif="folio.book_id.direction == 'expenses'">الاستخدامات (الأبواب 1-6)</t>
              </div>
              <div style="font-size:10px;">
                <t t-out="dict(folio._fields['period_month'].selection).get(folio.period_month)"/>
                <t t-out="folio.fiscal_year"/>
                — محافظة بورسعيد
              </div>
            </div>

            <!-- Identity strip -->
            <table style="width:100%; font-size:10px; margin-bottom:6px;"
                   class="table-borderless">
              <tr>
                <td><strong>رقم الفولية:</strong> <t t-out="folio.folio_number"/></td>
                <td><strong>الحالة:</strong>
                  <t t-out="dict(folio._fields['state'].selection).get(folio.state)"/>
                </td>
                <td><strong>عدد السطور:</strong> <t t-out="folio.line_count"/></td>
              </tr>
            </table>

            <!-- Totals by chapter (Fasle) -->
            <table style="width:100%; font-size:10px; border-collapse:collapse; border:1px solid #000;">
              <thead>
                <tr style="background:#dddddd;">
                  <th style="padding:4px; border:1px solid #000; width:15%;">كود الباب/الفصل</th>
                  <th style="padding:4px; border:1px solid #000; width:50%;">الوصف</th>
                  <th style="padding:4px; border:1px solid #000; width:15%;">
                    نقل من قبله
                  </th>
                  <th style="padding:4px; border:1px solid #000; width:20%;">
                    إجمالي الشهر
                  </th>
                </tr>
              </thead>
              <tbody>
                <t t-foreach="cols" t-as="c">
                  <tr>
                    <td style="padding:3px; border:1px solid #000; font-weight:bold;">
                      <t t-out="c"/>
                    </td>
                    <td style="padding:3px; border:1px solid #000;">
                      <t t-out="labels.get(c, c)"/>
                    </td>
                    <td style="padding:3px; border:1px solid #000; text-align:left; color:#888;">
                      —
                    </td>
                    <td style="padding:3px; border:1px solid #000; text-align:left;">
                      <t t-out="'%.2f' % ctotals.get(c, 0.0)"/>
                    </td>
                  </tr>
                </t>
                <!-- Grand total -->
                <tr style="background:#f5f5f5; font-weight:bold;">
                  <td colspan="2" style="padding:4px; border:2px solid #000; text-align:center;">
                    الإجمالي
                  </td>
                  <td style="padding:4px; border:2px solid #000; text-align:left;">
                    <t t-out="'%.2f' % folio.opening_carryforward"/>
                  </td>
                  <td style="padding:4px; border:2px solid #000; text-align:left;">
                    <t t-out="'%.2f' % folio.period_total"/>
                  </td>
                </tr>
                <tr style="font-weight:bold;">
                  <td colspan="3" style="padding:4px; border:1px solid #000; text-align:center;">
                    نقل بعده (التراكمي من بداية السنة المالية)
                  </td>
                  <td style="padding:4px; border:1px solid #000; text-align:left;
                             background:#ffe9c6;">
                    <t t-out="'%.2f' % folio.closing_carryforward"/>
                  </td>
                </tr>
              </tbody>
            </table>

            <!-- Signatures -->
            <table style="width:100%; margin-top:40px; font-size:10px;"
                   class="table-borderless">
              <tr>
                <td style="text-align:center;">
                  <div>موظف الشطب</div>
                  <div style="margin-top:25px; border-top:1px solid #000; padding-top:3px;">
                    <t t-out="folio.crossout_signed_by or '............................'"/>
                  </div>
                </td>
                <td style="text-align:center;">
                  <div>رئيس الحسابات</div>
                  <div style="margin-top:25px; border-top:1px solid #000; padding-top:3px;">
                    <t t-out="folio.accounts_head_signed_by or '............................'"/>
                  </div>
                </td>
                <td style="text-align:center;">
                  <div>الجهاز المركزي للمحاسبات</div>
                  <div style="margin-top:25px; border-top:1px solid #000; padding-top:3px;">
                    ............................
                  </div>
                </td>
              </tr>
            </table>

          </div>
          <p style="page-break-after: always;"/>
        </t>
      </t>
    </t>
  </template>

</odoo>
