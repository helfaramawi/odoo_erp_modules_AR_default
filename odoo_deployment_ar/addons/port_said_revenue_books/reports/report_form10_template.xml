<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="report_form10">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="folio">
        <t t-call="web.external_layout">
          <t t-set="matrix" t-value="folio._get_matrix_for_print()"/>
          <t t-set="cols" t-value="matrix['columns']"/>
          <t t-set="labels" t-value="matrix['column_labels']"/>
          <t t-set="rows" t-value="matrix['rows']"/>
          <t t-set="ctotals" t-value="matrix['column_totals']"/>

          <div class="page" dir="rtl"
               style="font-family:'Traditional Arabic',Arial,serif; font-size:9px;">

            <!-- Header -->
            <div style="text-align:center; margin-bottom:8px;">
              <h3 style="margin:0; font-size:14px;">
                <t t-out="folio.book_id.name"/>
              </h3>
              <div style="font-size:10px;">
                نموذج رقم <t t-out="folio.book_id.form_number"/>
                — <t t-out="dict(folio._fields['period_month'].selection).get(folio.period_month)"/>
                <t t-out="folio.fiscal_year"/>
                — محافظة بورسعيد
              </div>
              <div style="font-size:9px; color:#555;">
                رقم الفولية: <t t-out="folio.folio_number"/>
                — الحالة: <t t-out="dict(folio._fields['state'].selection).get(folio.state)"/>
                — عدد الأعمدة النشطة: <t t-out="len(cols)"/>
              </div>
            </div>

            <!-- Carry-forward strip -->
            <table style="width:100%; font-size:9px; margin-bottom:4px; border:1px solid #000;">
              <tr style="background:#f0f0f0;">
                <td style="padding:2px; border:1px solid #000; width:33%;"><strong>نقل من قبله</strong></td>
                <td style="padding:2px; border:1px solid #000; width:34%;"><strong>إجمالي الشهر</strong></td>
                <td style="padding:2px; border:1px solid #000; width:33%;"><strong>نقل بعده</strong></td>
              </tr>
              <tr>
                <td style="padding:2px; border:1px solid #000; text-align:left;">
                  <t t-out="'%.2f' % folio.opening_carryforward"/>
                </td>
                <td style="padding:2px; border:1px solid #000; text-align:left;">
                  <t t-out="'%.2f' % folio.period_total"/>
                </td>
                <td style="padding:2px; border:1px solid #000; text-align:left; font-weight:bold;">
                  <t t-out="'%.2f' % folio.closing_carryforward"/>
                </td>
              </tr>
            </table>

            <!-- Main cross-tab matrix -->
            <t t-if="not cols">
              <div style="text-align:center; padding:30px; color:#999;">
                لا توجد سطور محاسبية في هذه الفترة ضمن نطاق الأبواب المحدد.
              </div>
            </t>
            <t t-else="">
              <table style="width:100%; font-size:8px; border-collapse:collapse;
                            border:1.5px solid #000;">
                <thead>
                  <tr style="background:#dddddd;">
                    <th style="padding:3px; border:1px solid #000; width:70px;">التاريخ</th>
                    <t t-foreach="cols" t-as="c">
                      <th style="padding:3px; border:1px solid #000; font-size:7.5px;
                                 writing-mode:vertical-rl; min-width:45px; max-width:60px;
                                 text-align:center;">
                        <div style="transform:rotate(180deg);">
                          <div style="font-weight:bold; color:#a00;"><t t-out="c"/></div>
                          <div style="font-size:6.5px; color:#555;">
                            <t t-out="labels.get(c, c)[:20]"/>
                          </div>
                        </div>
                      </th>
                    </t>
                    <th style="padding:3px; border:1px solid #000; background:#fff4e5;
                               font-weight:bold; width:80px;">إجمالي اليوم</th>
                  </tr>
                </thead>
                <tbody>
                  <t t-foreach="rows" t-as="row">
                    <tr>
                      <td style="padding:2px; border:1px solid #000; text-align:center;">
                        <t t-out="row['day']"/>
                      </td>
                      <t t-foreach="cols" t-as="c">
                        <td style="padding:2px; border:1px solid #000; text-align:left;
                                   font-size:8px;">
                          <t t-if="row['values'][c]">
                            <t t-out="'%.2f' % row['values'][c]"/>
                          </t>
                        </td>
                      </t>
                      <td style="padding:2px; border:1px solid #000; text-align:left;
                                 font-weight:bold; background:#fff9ee;">
                        <t t-out="'%.2f' % row['day_total']"/>
                      </td>
                    </tr>
                  </t>
                  <!-- Column totals row -->
                  <tr style="background:#f5f5f5; font-weight:bold;">
                    <td style="padding:3px; border:1.5px solid #000; text-align:center;">
                      جملة الشهر
                    </td>
                    <t t-foreach="cols" t-as="c">
                      <td style="padding:3px; border:1.5px solid #000; text-align:left;">
                        <t t-out="'%.2f' % ctotals.get(c, 0.0)"/>
                      </td>
                    </t>
                    <td style="padding:3px; border:1.5px solid #000; text-align:left;
                               background:#ffe9c6;">
                      <t t-out="'%.2f' % matrix['grand_total']"/>
                    </td>
                  </tr>
                </tbody>
              </table>
            </t>

            <!-- Signatures -->
            <table style="width:100%; margin-top:30px; font-size:10px;"
                   class="table-borderless">
              <tr>
                <td style="text-align:center; width:33%;">
                  <div>موظف الشطب</div>
                  <div style="margin-top:25px; border-top:1px solid #000; padding-top:3px;">
                    <t t-out="folio.crossout_signed_by or '............................'"/>
                  </div>
                </td>
                <td style="text-align:center; width:34%;">
                  <div>رئيس الحسابات</div>
                  <div style="margin-top:25px; border-top:1px solid #000; padding-top:3px;">
                    <t t-out="folio.accounts_head_signed_by or '............................'"/>
                  </div>
                </td>
                <td style="text-align:center; width:33%;">
                  <div>المراجع المالي</div>
                  <div style="margin-top:25px; border-top:1px solid #000; padding-top:3px;">
                    ............................
                  </div>
                </td>
              </tr>
            </table>

            <div style="text-align:center; font-size:8px; margin-top:12px; color:#666;">
              نقل بعده — يحوَّل الرصيد
              <t t-out="'%.2f' % folio.closing_carryforward"/>
              إلى فولية <t t-out="dict(folio._fields['period_month'].selection).get(folio.period_month)"/> اللاحقة
            </div>

          </div>
          <p style="page-break-after: always;"/>
        </t>
      </t>
    </t>
  </template>

</odoo>
