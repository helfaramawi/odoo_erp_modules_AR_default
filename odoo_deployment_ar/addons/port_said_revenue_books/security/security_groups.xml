<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="group_revenue_user" model="res.groups">
    <field name="name">دفاتر إيرادات/مصروفات — مستخدم</field>
    <field name="category_id" ref="base.module_category_accounting_accounting"/>
    <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
  </record>

  <record id="group_revenue_manager" model="res.groups">
    <field name="name">دفاتر إيرادات/مصروفات — مدير</field>
    <field name="category_id" ref="base.module_category_accounting_accounting"/>
    <field name="implied_ids" eval="[(4, ref('group_revenue_user')), (4, ref('account.group_account_manager'))]"/>
  </record>
</odoo>
