<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="cron_revenue_generate_monthly" model="ir.cron">
    <field name="name">دفاتر إيرادات/مصروفات — توليد فوليوهات شهرية</field>
    <field name="model_id" ref="model_port_said_revenue_folio"/>
    <field name="state">code</field>
    <field name="code">model.cron_generate_monthly_folios()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">months</field>
    <field name="numbercall">-1</field>
    <field name="active" eval="True"/>
  </record>

  <record id="cron_revenue_recompute_open" model="ir.cron">
    <field name="name">دفاتر إيرادات/مصروفات — إعادة حساب الفوليوهات المفتوحة</field>
    <field name="model_id" ref="model_port_said_revenue_folio"/>
    <field name="state">code</field>
    <field name="code">model.cron_recompute_open_folios()</field>
    <field name="interval_number">1</field>
    <field name="interval_type">days</field>
    <field name="numbercall">-1</field>
    <field name="active" eval="True"/>
  </record>

</odoo>
