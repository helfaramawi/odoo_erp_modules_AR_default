<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="report_daftar55_template">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="rec">
        <t t-call="web.external_layout">
          <div class="page" style="direction:rtl; font-family:'Amiri', 'Noto Naskh Arabic', Arial, sans-serif; font-size:12px;">

            <!-- ═══ هيدر الديوان العام — شعار المحافظة ═══ -->
            <div style="direction:rtl; display:table; width:100%; border-bottom:3px double #1F497D; padding-bottom:10px; margin-bottom:14px;">
              <!-- شعار المحافظة — يسار الصفحة (يمين في RTL) -->
              <div style="display:table-cell; width:80px; vertical-align:middle; text-align:center;">
                <img t-if="rec.company_id.logo"
                     t-att-src="'data:image/png;base64,' + rec.company_id.logo.decode('utf-8')"
                     style="max-height:70px; max-width:70px; object-fit:contain;"
                     alt="شعار المحافظة"/>
                <div t-else="" style="width:70px; height:70px; border:2px solid #1F497D; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:9px; color:#1F497D; text-align:center; line-height:1.3;">
                  شعار<br/>المحافظة
                </div>
              </div>
              <!-- النص المركزي -->
              <div style="display:table-cell; vertical-align:middle; text-align:center; padding:0 10px;">
                <div style="font-size:11px; color:#666; margin-bottom:2px;">جمهورية مصر العربية — محافظة بورسعيد</div>
                <div style="font-size:17px; font-weight:bold; color:#1F497D; margin-bottom:2px;">الديوان العام لمحافظة بورسعيد</div>
                <div style="font-size:13px; font-weight:bold; color:#333; margin-bottom:4px;">دفتر 55 ع.ح — سجل الصرف وأوامر الدفع</div>
                <div style="font-size:9px; color:#999;">Paradise Integrated Solutions | إدارة المالية</div>
              </div>
              <!-- رقم السجل / التاريخ — يمين الصفحة (يسار في RTL) -->
              <div style="display:table-cell; width:100px; vertical-align:middle; text-align:center; font-size:10px; color:#444;">
                <div style="border:1px solid #ddd; border-radius:4px; padding:4px 6px; background:#f9f9f9;">
                  <div style="color:#1F497D; font-weight:bold; margin-bottom:2px;">رقم المستند</div>
                  <div><t t-esc="rec.sequence_number or ''"/></div>
                  <div style="margin-top:4px; color:#666;">التاريخ</div>
                  <div><t t-esc="rec.date_received or ''"/></div>
                </div>
              </div>
            </div>
            <!-- ════════════════════════════════════════════════ -->


            <!-- قسم أ -->
            <div style="border:1px solid #1F497D; padding:8px; margin-bottom:8px;">
              <div style="background:#1F497D; color:white; padding:4px 8px; margin:-8px -8px 8px; font-weight:bold;">قسم أ — بيانات الطلب</div>
              <table style="width:100%; border-collapse:collapse;">
                <tr>
                  <td style="width:20%; color:#444;">المصلحة:</td>
                  <td style="width:30%; border-bottom:1px solid #999;"><t t-esc="rec.department_name or ''"/></td>
                  <td style="width:20%; color:#444;">القسم:</td>
                  <td style="border-bottom:1px solid #999;"><t t-esc="rec.division_name or ''"/></td>
                </tr>
                <tr>
                  <td style="color:#444; padding-top:6px;">المبلغ المستحق إلى:</td>
                  <td colspan="3" style="border-bottom:1px solid #999; padding-top:6px;"><t t-esc="rec.vendor_id.name or ''"/></td>
                </tr>
                <tr>
                  <td style="color:#444; padding-top:6px;">بموجب استمارة:</td>
                  <td style="border-bottom:1px solid #999; padding-top:6px;"><t t-esc="rec.form50_ref or ''"/></td>
                  <td style="color:#444;">رقم القومي:</td>
                  <td style="border-bottom:1px solid #999;"><t t-esc="rec.national_id or ''"/></td>
                </tr>
                <tr>
                  <td style="color:#444; padding-top:6px;">البنك:</td>
                  <td style="border-bottom:1px solid #999; padding-top:6px;"><t t-esc="rec.bank_name or ''"/></td>
                  <td style="color:#444;">الفرع:</td>
                  <td style="border-bottom:1px solid #999;"><t t-esc="rec.bank_branch or ''"/></td>
                </tr>
                <tr>
                  <td style="color:#444; padding-top:6px;">IBAN:</td>
                  <td style="border-bottom:1px solid #999; padding-top:6px;"><t t-esc="rec.iban or ''"/></td>
                  <td style="color:#444;">عدد المرفقات:</td>
                  <td style="border-bottom:1px solid #999;"><t t-esc="rec.attachment_count_declared or ''"/></td>
                </tr>
                <tr>
                  <td style="color:#444; padding-top:6px;">الكاتب المنوط:</td>
                  <td style="border-bottom:1px solid #999; padding-top:6px;"><t t-esc="rec.writer_assigned or ''"/></td>
                  <td style="color:#444;">تقييد في سجل "ز":</td>
                  <td style="border-bottom:1px solid #999;"><t t-esc="rec.register_z_ref or ''"/></td>
                </tr>
              </table>
            </div>

            <!-- المبالغ والاستقطاعات -->
            <div style="border:1px solid #1F497D; padding:8px; margin-bottom:8px;">
              <div style="background:#1F497D; color:white; padding:4px 8px; margin:-8px -8px 8px; font-weight:bold;">الاعتماد الإداري ونوع الخصم — بيانات الاستقطاعات</div>
              <table style="width:100%; border-collapse:collapse; font-size:11px;">
                <thead>
                  <tr style="background:#D9E1F2;">
                    <th style="padding:4px; border:1px solid #aaa;">إجمالي الأصل</th>
                    <th style="padding:4px; border:1px solid #aaa;">الدمغة العادية (1%)</th>
                    <th style="padding:4px; border:1px solid #aaa;">الدمغة الإضافية (3×)</th>
                    <th style="padding:4px; border:1px solid #aaa;">الدمغة النسبية (0.008)</th>
                    <th style="padding:4px; border:1px solid #aaa;">ضريبة الأرباح (3%)</th>
                    <th style="padding:4px; border:1px solid #aaa; background:#FFF2CC;">إجمالي الخصم</th>
                    <th style="padding:4px; border:1px solid #aaa; background:#E2EFDA; font-weight:bold;">صافي المبلغ</th>
                  </tr>
                </thead>
                <tbody>
                  <tr style="text-align:center;">
                    <td style="border:1px solid #aaa; padding:6px;"><t t-esc="rec.amount_gross"/></td>
                    <td style="border:1px solid #aaa; padding:6px;"><t t-esc="rec.deductions_stamp_normal"/></td>
                    <td style="border:1px solid #aaa; padding:6px;"><t t-esc="rec.deductions_stamp_extra"/></td>
                    <td style="border:1px solid #aaa; padding:6px;"><t t-esc="rec.deductions_stamp_proportional"/></td>
                    <td style="border:1px solid #aaa; padding:6px;"><t t-esc="rec.deductions_commercial_tax"/></td>
                    <td style="border:1px solid #aaa; padding:6px; background:#FFF2CC;"><t t-esc="rec.total_deductions"/></td>
                    <td style="border:1px solid #aaa; padding:6px; background:#E2EFDA; font-weight:bold; font-size:13px;">
                      <t t-esc="rec.amount_net"/>
                    </td>
                  </tr>
                </tbody>
              </table>
              <!-- التفقيط -->
              <div style="margin-top:8px; padding:6px; background:#FFFBE6; border:1px solid #E0C84A;">
                <span style="color:#444; font-weight:bold;">الصافي بالتفقيط: </span>
                <span style="font-weight:bold; font-size:13px;"><t t-esc="rec.amount_words or ''"/></span>
              </div>
            </div>

            <!-- قسم ج — التوقيعات -->
            <div style="border:1px solid #1F497D; padding:8px; margin-bottom:8px;">
              <div style="background:#375623; color:white; padding:4px 8px; margin:-8px -8px 8px; font-weight:bold;">قسم ج — المراجعة والتوقيعات</div>
              <table style="width:100%; margin-top:8px;">
                <tr>
                  <td style="text-align:center; width:33%; padding:8px;">
                    <div style="border-bottom:1px solid #666; margin-bottom:4px; min-height:30px;"><t t-esc="rec.reviewer_id.name if rec.reviewer_id else ''"/></div>
                    <small style="color:#444;">المراجع</small><br/>
                    <small style="color:#888;">ختم روجع: <t t-esc="rec.reviewer_stamp_date or '___________'"/></small>
                  </td>
                  <td style="text-align:center; width:33%; padding:8px;">
                    <div style="border-bottom:1px solid #666; margin-bottom:4px; min-height:30px;"><t t-esc="rec.auditor_id.name if rec.auditor_id else ''"/></div>
                    <small style="color:#444;">مراقب الحسابات</small>
                  </td>
                  <td style="text-align:center; width:33%; padding:8px;">
                    <div style="border-bottom:1px solid #666; margin-bottom:4px; min-height:30px;"><t t-esc="rec.accounts_head_id.name if rec.accounts_head_id else ''"/></div>
                    <small style="color:#444;">رئيس الحسابات</small>
                  </td>
                </tr>
              </table>
              <div style="margin-top:8px; font-size:11px; color:#444;">
                تاريخ ورود الاستمارة: <strong><t t-esc="rec.date_received"/></strong> |
                تاريخ الإعادة من المراجع: <strong><t t-esc="rec.date_returned or '___________'"/></strong>
              </div>
            </div>

            <!-- قسم د — دفتر 224 -->
            <div style="border:1px solid #1F497D; padding:8px; margin-bottom:8px;">
              <div style="background:#C55A11; color:white; padding:4px 8px; margin:-8px -8px 8px; font-weight:bold;">قسم د — قيود دفتر 224 ع.ح</div>
              <table style="width:100%; margin-top:8px; font-size:11px;">
                <tr>
                  <td style="width:40%; color:#444;">رقم مسلسل دفتر 224:</td>
                  <td style="border-bottom:1px solid #999; font-weight:bold;"><t t-esc="rec.daftar224_sequence or '___________'"/></td>
                </tr>
                <tr style="margin-top:8px;">
                  <td colspan="2" style="padding-top:8px; font-weight:bold; color:#1F497D;">القيود المحاسبية الإجمالية:</td>
                </tr>
                <tr>
                  <td colspan="2" style="font-family:monospace; font-size:10px; padding:4px; background:#f8f8f8;">
                    <t t-esc="rec.amount_gross"/> &#160; من ح/ <t t-esc="rec.budget_line or 'البند'"/>
                    <br/>
                    &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;إلى مذكورين:
                    <br/>
                    &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;<t t-esc="rec.total_deductions"/> &#160; ح/ حسابات جارية دائنة
                    <br/>
                    &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;<t t-esc="rec.amount_net"/> &#160; ح/ حساب أوامر الدفع
                  </td>
                </tr>
              </table>
              <div style="margin-top:8px; font-size:11px;">
                توقيع موظفي الشطب: <t t-esc="rec.crossout_signed_by or '________________________'"/>
              </div>
            </div>

            <!-- Footer -->
            <div style="margin-top:16px; text-align:center; font-size:10px; color:#888; border-top:1px solid #ddd; padding-top:6px;">
              رقم مسلسل دفتر 55: <strong><t t-esc="rec.sequence_number"/></strong> |
              السنة المالية: <t t-esc="rec.fiscal_year"/> |
              رئيس المصلحة: <t t-esc="rec.section_head_id.name if rec.section_head_id else '___________'"/>
            </div>
          </div>
        </t>
      </t>
    </t>
  </template>
</odoo>
