<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══ Report Action ═════════════════════════════════════════════════════ -->
    <record id="action_report_form193" model="ir.actions.report">
        <field name="name">استمارة 193 ع.ح — إذن صرف العهدة</field>
        <field name="model">custody.assignment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_eg_custody.report_form193_template</field>
        <field name="report_file">l10n_eg_custody.report_form193_template</field>
        <field name="print_report_name">'استمارة 193 - ' + (object.name or '')</field>
        <field name="binding_model_id" ref="model_custody_assignment"/>
        <field name="binding_type">report</field>
</record>

    <!-- ══ QWeb Template ════════════════════════════════════════════════════ -->
    <template id="report_form193_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="direction: rtl; font-family: 'Cairo', 'Amiri', Arial, sans-serif;">

                        <!-- Header -->
                        <div style="text-align: center; margin-bottom: 20px; border-bottom: 2px solid #000; padding-bottom: 10px;">
                            <h2 style="margin: 0; font-size: 16pt; font-weight: bold;">
                                جمهورية مصر العربية
                            </h2>
                            <h3 style="margin: 4px 0; font-size: 13pt;">
                                الديوان العام لمحافظة بورسعيد
                            </h3>
                            <h3 style="margin: 4px 0; font-size: 13pt;">
                                إدارة المخازن
                            </h3>
                            <div style="margin-top: 10px; display: flex; justify-content: space-between; font-size: 11pt;">
                                <span>استمارة رقم 193 (ع.ح)</span>
                                <span><strong>رقم العهدة: </strong><t t-esc="doc.name"/></span>
                                <span><strong>رقم الاستمارة: </strong><t t-esc="doc.form_193_ref"/></span>
                            </div>
                        </div>

                        <!-- Title -->
                        <h2 style="text-align: center; font-size: 14pt; text-decoration: underline; margin-bottom: 15px;">
                            إذن صرف عهدة شخصية
                        </h2>

                        <!-- Employee Information Block -->
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 15px; font-size: 11pt;">
                            <tr>
                                <td style="border: 1px solid #000; padding: 6px; font-weight: bold; background: #f0f0f0; width: 30%;">اسم الموظف المستلم</td>
                                <td style="border: 1px solid #000; padding: 6px; width: 70%;"><t t-esc="doc.employee_id.name"/></td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #000; padding: 6px; font-weight: bold; background: #f0f0f0; color: red;">الرقم القومي (إلزامي)</td>
                                <td style="border: 1px solid #000; padding: 6px; font-weight: bold; font-size: 13pt; letter-spacing: 2px;">
                                    <t t-esc="doc.national_id or 'غير مسجل — مطلوب للرقابة المالية'"/>
                                    <t t-if="not doc.national_id">
                                        <span style="color: red; font-size: 9pt;"> ⚠ يجب إدخال الرقم القومي قبل الطباعة</span>
                                    </t>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #000; padding: 6px; font-weight: bold; background: #f0f0f0;">الوظيفة</td>
                                <td style="border: 1px solid #000; padding: 6px;"><t t-esc="doc.employee_job_id.name or ''"/></td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #000; padding: 6px; font-weight: bold; background: #f0f0f0;">الإدارة / القسم</td>
                                <td style="border: 1px solid #000; padding: 6px;"><t t-esc="doc.employee_department_id.name or ''"/></td>
                            </tr>
                        </table>

                        <!-- Item Information Block -->
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 15px; font-size: 11pt;">
                            <thead>
                                <tr style="background: #d0d0d0;">
                                    <th style="border: 1px solid #000; padding: 7px; text-align: center;">م</th>
                                    <th style="border: 1px solid #000; padding: 7px; text-align: center;">اسم الصنف</th>
                                    <th style="border: 1px solid #000; padding: 7px; text-align: center;">الرقم التسلسلي</th>
                                    <th style="border: 1px solid #000; padding: 7px; text-align: center;">الكمية</th>
                                    <th style="border: 1px solid #000; padding: 7px; text-align: center;">الوحدة</th>
                                    <th style="border: 1px solid #000; padding: 7px; text-align: center;">القيمة التقديرية</th>
                                    <th style="border: 1px solid #000; padding: 7px; text-align: center;">نوع العهدة</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="border: 1px solid #000; padding: 6px; text-align: center;">1</td>
                                    <td style="border: 1px solid #000; padding: 6px;"><t t-esc="doc.product_id.name"/></td>
                                    <td style="border: 1px solid #000; padding: 6px; text-align: center;"><t t-esc="doc.serial_number or '—'"/></td>
                                    <td style="border: 1px solid #000; padding: 6px; text-align: center;"><t t-esc="doc.qty"/></td>
                                    <td style="border: 1px solid #000; padding: 6px; text-align: center;"><t t-esc="doc.uom_id.name or ''"/></td>
                                    <td style="border: 1px solid #000; padding: 6px; text-align: center;">
                                        <t t-esc="'{:,.2f}'.format(doc.estimated_value) if doc.estimated_value else '—'"/>
                                    </td>
                                    <td style="border: 1px solid #000; padding: 6px; text-align: center;">
                                        <t t-if="doc.custody_type == 'sub'">فرعية</t>
                                        <t t-elif="doc.custody_type == 'location'">مكانية</t>
                                        <t t-else="">شخصية</t>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Warehouse + Dates -->
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 15px; font-size: 11pt;">
                            <tr>
                                <td style="border: 1px solid #000; padding: 6px; font-weight: bold; background: #f0f0f0; width: 25%;">المخزن</td>
                                <td style="border: 1px solid #000; padding: 6px; width: 25%;"><t t-esc="doc.warehouse_id.name or ''"/></td>
                                <td style="border: 1px solid #000; padding: 6px; font-weight: bold; background: #f0f0f0; width: 25%;">تاريخ الصرف</td>
                                <td style="border: 1px solid #000; padding: 6px; width: 25%;"><t t-esc="doc.issue_date"/></td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #000; padding: 6px; font-weight: bold; background: #f0f0f0;">رقم إذن الصرف</td>
                                <td style="border: 1px solid #000; padding: 6px;"><t t-esc="doc.issue_permit_ref or '—'"/></td>
                                <td style="border: 1px solid #000; padding: 6px; font-weight: bold; background: #f0f0f0;">تاريخ الاسترداد المتوقع</td>
                                <td style="border: 1px solid #000; padding: 6px;"><t t-esc="doc.expected_return_date or '—'"/></td>
                            </tr>
                        </table>

                        <!-- Signature Block — MANDATORY -->
                        <div style="margin-top: 25px; font-size: 11pt;">
                            <p style="font-weight: bold; text-decoration: underline; margin-bottom: 15px;">توقيعات إلزامية (مطلوبة للرقابة المالية الجهاز المركزي للمحاسبات)</p>
                            <table style="width: 100%; border-collapse: collapse;">
                                <tr>
                                    <td style="border: 1px solid #000; padding: 15px; text-align: center; width: 33%;">
                                        <p style="font-weight: bold; margin: 0;">أمين المخزن</p>
                                        <p style="margin: 5px 0;"><t t-esc="doc.storekeeper_id.name if doc.storekeeper_id else '........................'"/></p>
                                        <p style="margin-top: 30px; color: #555;">التوقيع: ........................</p>
                                        <p style="margin: 5px 0; color: #555;">التاريخ: <t t-esc="doc.issue_date"/></p>
                                    </td>
                                    <td style="border: 1px solid #000; padding: 15px; text-align: center; width: 33%;">
                                        <p style="font-weight: bold; margin: 0;">مدير الإدارة</p>
                                        <p style="margin: 5px 0;"><t t-esc="doc.dept_manager_id.name if doc.dept_manager_id else '........................'"/></p>
                                        <p style="margin-top: 30px; color: #555;">التوقيع: ........................</p>
                                        <p style="margin: 5px 0; color: #555;">التاريخ: ........................</p>
                                    </td>
                                    <td style="border: 1px solid #000; padding: 15px; text-align: center; width: 33%;">
                                        <p style="font-weight: bold; margin: 0;">الموظف المستلم</p>
                                        <p style="margin: 5px 0;"><t t-esc="doc.employee_id.name"/></p>
                                        <p style="font-size: 9pt; color: #555;">ر.ق: <t t-esc="doc.national_id or '⚠ مطلوب'"/></p>
                                        <p style="margin-top: 20px; color: #555;">التوقيع: ........................</p>
                                        <p style="margin: 5px 0; color: #555;">التاريخ: ........................</p>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Footer -->
                        <div style="margin-top: 20px; border-top: 1px solid #000; padding-top: 8px; font-size: 9pt; color: #555; display: flex; justify-content: space-between;">
                            <span>نظام أوبو إيآر بي — Paradise AI Solutions</span>
                            <span>طُبع بتاريخ: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d %H:%M')"/></span>
                            <span>استمارة 193 (ع.ح) — محافظة بورسعيد</span>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- ══ Custody Sheet Report (Form 1 Warehouses) ════════════════════════ -->
    <record id="action_report_custody_sheet" model="ir.actions.report">
        <field name="name">كشف العهدة - نموذج 1 مخازن</field>
        <field name="model">custody.assignment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_eg_custody.report_custody_sheet_template</field>
        <field name="print_report_name">'كشف العهدة - ' + (object.employee_id.name or '')</field>
        <field name="binding_model_id" ref="model_custody_assignment"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_custody_sheet_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="direction: rtl; font-family: 'Cairo', Arial, sans-serif;">
                        <div style="text-align: center; margin-bottom: 15px;">
                            <h3>الديوان العام لمحافظة بورسعيد — كشف العهدة</h3>
                            <h4>نموذج 1 مخازن — إجمالي عهدة الموظف</h4>
                        </div>
                        <table style="width:100%; border-collapse: collapse; font-size: 10pt;">
                            <tr>
                                <td style="border:1px solid #000;padding:5px;font-weight:bold;background:#eee;">اسم الموظف</td>
                                <td style="border:1px solid #000;padding:5px;" colspan="3"><t t-esc="doc.employee_id.name"/></td>
                                <td style="border:1px solid #000;padding:5px;font-weight:bold;background:#eee;">الرقم القومي</td>
                                <td style="border:1px solid #000;padding:5px;font-weight:bold;"><t t-esc="doc.national_id or '⚠ مطلوب'"/></td>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000;padding:5px;font-weight:bold;background:#eee;">الإدارة</td>
                                <td style="border:1px solid #000;padding:5px;" colspan="3"><t t-esc="doc.employee_department_id.name or ''"/></td>
                                <td style="border:1px solid #000;padding:5px;font-weight:bold;background:#eee;">المخزن</td>
                                <td style="border:1px solid #000;padding:5px;"><t t-esc="doc.warehouse_id.name or ''"/></td>
                            </tr>
                        </table>
                        <br/>
                        <table style="width:100%;border-collapse:collapse;font-size:10pt;">
                            <thead>
                                <tr style="background:#d0d0d0;">
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">رقم العهدة</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">رقم استمارة 193</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">الصنف</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">الكمية</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">الرقم التسلسلي</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">القيمة</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">تاريخ الصرف</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">الحالة</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="doc.name"/></td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="doc.form_193_ref"/></td>
                                    <td style="border:1px solid #000;padding:5px;"><t t-esc="doc.product_id.name"/></td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="doc.qty"/></td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="doc.serial_number or '—'"/></td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="'{:,.2f}'.format(doc.estimated_value) if doc.estimated_value else '—'"/></td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="doc.issue_date"/></td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;">
                                        <t t-if="doc.state=='active'">نشطة</t>
                                        <t t-elif="doc.state=='transferred'">محولة</t>
                                        <t t-elif="doc.state=='returned'">مستردة</t>
                                        <t t-else=""><t t-esc="doc.state"/></t>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <div style="margin-top:20px;text-align:center;font-size:9pt;color:#777;">
                            طُبع من نظام أوبو إيآر بي — الديوان العام لمحافظة بورسعيد
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

<!-- ══ كشف العهد — Custody List Report ════════════════════════════════ -->
    <record id="action_report_custody_list" model="ir.actions.report">
        <field name="name">كشف العهد المسجلة</field>
        <field name="model">custody.assignment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_eg_custody.report_custody_list_template</field>
        <field name="print_report_name">'كشف العهد - ' + context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')</field>
        <field name="binding_model_id" ref="model_custody_assignment"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_a4"/>
    </record>

    <template id="report_custody_list_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page" style="direction:rtl;font-family:'Cairo',Arial,sans-serif;font-size:11pt;">

                    <!-- Header -->
                    <div style="text-align:center;border-bottom:2px solid #000;padding-bottom:10px;margin-bottom:16px;">
                        <h2 style="margin:0;font-size:15pt;font-weight:bold;">جمهورية مصر العربية</h2>
                        <h3 style="margin:4px 0;font-size:12pt;">الديوان العام لمحافظة بورسعيد</h3>
                        <h3 style="margin:4px 0;font-size:12pt;">إدارة المخازن</h3>
                    </div>

                    <h2 style="text-align:center;text-decoration:underline;margin-bottom:16px;font-size:13pt;">
                        كشف بيان العهد
                    </h2>

                    <div style="display:flex;justify-content:space-between;margin-bottom:12px;font-size:10pt;">
                        <span><strong>تاريخ الكشف:</strong>
                            <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/>
                        </span>
                        <span><strong>إجمالي العهد:</strong> <t t-esc="len(docs)"/></span>
                    </div>

                    <!-- Table -->
                    <table style="width:100%;border-collapse:collapse;font-size:9pt;">
                        <thead>
                            <tr style="background:#1F4E79;color:white;">
                                <th style="border:1px solid #000;padding:6px;text-align:center;width:4%;">م</th>
                                <th style="border:1px solid #000;padding:6px;text-align:center;width:10%;">رقم العهدة</th>
                                <th style="border:1px solid #000;padding:6px;text-align:center;width:9%;">رقم 193</th>
                                <th style="border:1px solid #000;padding:6px;text-align:center;width:14%;">الموظف</th>
                                <th style="border:1px solid #000;padding:6px;text-align:center;width:12%;">الرقم القومي</th>
                                <th style="border:1px solid #000;padding:6px;text-align:center;width:12%;">الإدارة</th>
                                <th style="border:1px solid #000;padding:6px;text-align:center;width:12%;">الصنف</th>
                                <th style="border:1px solid #000;padding:6px;text-align:center;width:5%;">الكمية</th>
                                <th style="border:1px solid #000;padding:6px;text-align:center;width:9%;">نوع العهدة</th>
                                <th style="border:1px solid #000;padding:6px;text-align:center;width:9%;">تاريخ الصرف</th>
                                <th style="border:1px solid #000;padding:6px;text-align:center;width:9%;">القيمة</th>
                                <th style="border:1px solid #000;padding:6px;text-align:center;width:8%;">الحالة</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="doc">
                                <tr t-att-style="'background:#e8f5e9;' if doc.state == 'active' else ('background:#fff3e0;' if doc.state == 'transferred' else ('background:#fafafa;' if doc.state == 'returned' else ''))">
                                    <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="doc_index + 1"/></td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;font-weight:bold;"><t t-esc="doc.name"/></td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="doc.form_193_ref"/></td>
                                    <td style="border:1px solid #000;padding:5px;"><t t-esc="doc.employee_id.name"/></td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;font-size:9pt;">
                                        <t t-if="doc.national_id">
                                            <t t-esc="doc.national_id"/>
                                        </t>
                                        <t t-else="">
                                            <span style="color:red;font-weight:bold;">غير مسجل</span>
                                        </t>
                                    </td>
                                    <td style="border:1px solid #000;padding:5px;"><t t-esc="doc.employee_department_id.name if doc.employee_department_id else ''"/></td>
                                    <td style="border:1px solid #000;padding:5px;"><t t-esc="doc.product_id.name"/></td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="doc.qty"/></td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;">
                                        <t t-if="doc.custody_type == 'personal'">شخصية</t>
                                        <t t-elif="doc.custody_type == 'sub'">فرعية</t>
                                        <t t-else="">مكانية</t>
                                    </td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="doc.issue_date"/></td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;">
                                        <t t-esc="'{:,.0f}'.format(doc.estimated_value) if doc.estimated_value else '—'"/>
                                    </td>
                                    <td style="border:1px solid #000;padding:5px;text-align:center;font-weight:bold;">
                                        <t t-if="doc.state == 'active'"><span style="color:#1E7145;">نشطة</span></t>
                                        <t t-elif="doc.state == 'transferred'"><span style="color:#C55A11;">محولة</span></t>
                                        <t t-elif="doc.state == 'returned'"><span style="color:#888;">مستردة</span></t>
                                        <t t-elif="doc.state == 'draft'"><span style="color:#555;">مسودة</span></t>
                                        <t t-else=""><t t-esc="doc.state"/></t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- Summary -->
                    <table style="width:50%;border-collapse:collapse;margin-top:14px;margin-right:auto;font-size:10pt;">
                        <tr style="background:#f0f0f0;font-weight:bold;">
                            <td style="border:1px solid #000;padding:6px;">إجمالي العهد</td>
                            <td style="border:1px solid #000;padding:6px;text-align:center;"><t t-esc="len(docs)"/></td>
                        </tr>
                        <tr>
                            <td style="border:1px solid #000;padding:6px;">عهد نشطة</td>
                            <td style="border:1px solid #000;padding:6px;text-align:center;color:#1E7145;font-weight:bold;">
                                <t t-esc="len([d for d in docs if d.state == 'active'])"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="border:1px solid #000;padding:6px;">عهد محولة</td>
                            <td style="border:1px solid #000;padding:6px;text-align:center;color:#C55A11;font-weight:bold;">
                                <t t-esc="len([d for d in docs if d.state == 'transferred'])"/>
                            </td>
                        </tr>
                        <tr style="background:#f9f9f9;font-weight:bold;">
                            <td style="border:1px solid #000;padding:6px;">إجمالي القيمة التقديرية</td>
                            <td style="border:1px solid #000;padding:6px;text-align:center;">
                                <t t-esc="'{:,.0f}'.format(sum(d.estimated_value for d in docs))"/> جنيه
                            </td>
                        </tr>
                    </table>

                    <!-- Signature -->
                    <div style="margin-top:24px;display:flex;justify-content:space-between;font-size:10pt;">
                        <div style="text-align:center;">
