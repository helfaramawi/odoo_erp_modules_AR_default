<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_lease_contract" model="ir.actions.report">
        <field name="name">عقد إيجار / حق انتفاع</field>
        <field name="model">auction.lease.contract</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">l10n_eg_auction.report_lease_contract_template</field>
        <field name="print_report_name">'عقد إيجار - ' + (object.name or '')</field>
        <field name="binding_model_id" ref="model_auction_lease_contract"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_lease_contract_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="direction:rtl;font-family:'Cairo',Arial,sans-serif;font-size:11pt;">
                        <div style="text-align:center;border-bottom:2px solid #000;padding-bottom:12px;margin-bottom:18px;">
                            <h2 style="margin:0;font-size:15pt;">جمهورية مصر العربية — الديوان العام لمحافظة بورسعيد</h2>
                        </div>
                        <h2 style="text-align:center;text-decoration:underline;margin-bottom:16px;">عقد إيجار / حق انتفاع</h2>
                        <p style="line-height:2;">
                            <strong>رقم العقد:</strong> <t t-esc="doc.name"/>  #160;#160; #160;#160;
                            <strong>رقم المزاد:</strong> <t t-esc="doc.auction_request_id.name if doc.auction_request_id else '—'"/>
                        </p>

                        <table style="width:100%;border-collapse:collapse;margin-bottom:14px;">
                            <tr>
                                <td style="border:1px solid #000;padding:6px;background:#f0f0f0;font-weight:bold;width:25%;">المستأجر</td>
                                <td style="border:1px solid #000;padding:6px;" colspan="3"><t t-esc="doc.partner_id.name"/></td>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000;padding:6px;background:#f0f0f0;font-weight:bold;">وصف الأصل</td>
                                <td style="border:1px solid #000;padding:6px;" colspan="3"><t t-esc="doc.asset_description"/></td>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000;padding:6px;background:#f0f0f0;font-weight:bold;">تاريخ البداية</td>
                                <td style="border:1px solid #000;padding:6px;"><t t-esc="doc.start_date"/></td>
                                <td style="border:1px solid #000;padding:6px;background:#f0f0f0;font-weight:bold;">تاريخ الانتهاء</td>
                                <td style="border:1px solid #000;padding:6px;"><t t-esc="doc.end_date"/></td>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000;padding:6px;background:#f0f0f0;font-weight:bold;">قيمة العقد السنوية</td>
                                <td style="border:1px solid #000;padding:6px;font-weight:bold;"><t t-esc="'{:,.2f}'.format(doc.contract_value)"/> جنيه</td>
                                <td style="border:1px solid #000;padding:6px;background:#f0f0f0;font-weight:bold;">نسبة الزيادة السنوية</td>
                                <td style="border:1px solid #000;padding:6px;"><t t-esc="'{:.2f}'.format(doc.annual_increase_pct)"/>%</td>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000;padding:6px;background:#f0f0f0;font-weight:bold;">فترة السماح</td>
                                <td style="border:1px solid #000;padding:6px;"><t t-esc="doc.grace_period_months"/> شهر</td>
                                <td style="border:1px solid #000;padding:6px;background:#f0f0f0;font-weight:bold;">دورية الدفع</td>
                                <td style="border:1px solid #000;padding:6px;">
                                    <t t-if="doc.payment_frequency == 'monthly'">شهري</t>
                                    <t t-elif="doc.payment_frequency == 'quarterly'">ربع سنوي</t>
                                    <t t-elif="doc.payment_frequency == 'biannual'">نصف سنوي</t>
                                    <t t-else="">سنوي</t>
                                </td>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000;padding:6px;background:#f0f0f0;font-weight:bold;">التأمين النهائي</td>
                                <td style="border:1px solid #000;padding:6px;"><t t-esc="'{:,.2f}'.format(doc.insurance_amount)"/> جنيه (<t t-esc="doc.insurance_pct"/>%)</td>
                                <td style="border:1px solid #000;padding:6px;background:#f0f0f0;font-weight:bold;">إجمالي العقد</td>
                                <td style="border:1px solid #000;padding:6px;font-weight:bold;"><t t-esc="'{:,.2f}'.format(doc.total_expected)"/> جنيه</td>
                            </tr>
                        </table>

                        <!-- Payment Schedule -->
                        <h4 style="margin-bottom:8px;">جدول الدفعات</h4>
                        <table style="width:100%;border-collapse:collapse;font-size:10pt;margin-bottom:16px;">
                            <thead>
                                <tr style="background:#d0d0d0;">
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">رقم الدفعة</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">السنة</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">تاريخ الاستحقاق</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">المبلغ (جنيه)</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;">الحالة</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.payment_schedule_ids" t-as="line">
                                    <tr>
                                        <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="line.installment_number"/></td>
                                        <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="line.year_number"/></td>
                                        <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="line.due_date"/></td>
                                        <td style="border:1px solid #000;padding:5px;text-align:center;"><t t-esc="'{:,.2f}'.format(line.amount)"/></td>
                                        <td style="border:1px solid #000;padding:5px;text-align:center;">
                                            <t t-if="line.state == 'paid'">مدفوع ✓</t>
                                            <t t-elif="line.state == 'overdue'">متأخر ⚠</t>
                                            <t t-else="">معلق</t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <div style="margin-top:30px;">
                            <table style="width:100%;border-collapse:collapse;">
                                <tr>
                                    <td style="border:1px solid #000;padding:18px;text-align:center;width:50%;">
                                        <p style="font-weight:bold;">رئيس الديوان العام / المفوض</p>
                                        <p style="margin-top:35px;color:#555;">التوقيع: .........................</p>
                                        <p style="color:#555;">الختم الرسمي</p>
                                    </td>
                                    <td style="border:1px solid #000;padding:18px;text-align:center;width:50%;">
                                        <p style="font-weight:bold;">المستأجر: <t t-esc="doc.partner_id.name"/></p>
                                        <p style="margin-top:35px;color:#555;">التوقيع: .........................</p>
                                        <p style="color:#555;">التاريخ: .........................</p>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
