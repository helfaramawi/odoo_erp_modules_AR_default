<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_form6" model="ir.actions.report">
        <field name="name">محضر جرد أصناف - نموذج 6 مخازن حكومية</field>
        <field name="model">stock.stocktaking.session</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_stocktaking_eg.report_form6_template</field>
        <field name="print_report_name">'محضر جرد - ' + (object.name or '')</field>
        <field name="binding_model_id" ref="model_stock_stocktaking_session"/>
        <field name="binding_type">report</field>
</record>

    <template id="report_form6_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="direction:rtl;font-family:'Cairo',Arial,sans-serif;font-size:10pt;">
                        <!-- Header -->
                        <div style="text-align:center;border-bottom:2px solid #000;padding-bottom:10px;margin-bottom:14px;">
                            <h2 style="margin:0;font-size:14pt;">جمهورية مصر العربية</h2>
                            <h3 style="margin:3px 0;font-size:11pt;">الديوان العام لمحافظة بورسعيد — إدارة المخازن</h3>
                            <div style="display:flex;justify-content:space-between;margin-top:6px;font-size:10pt;">
                                <span><strong>رقم المحضر:</strong> <t t-esc="doc.name"/></span>
                                <strong style="font-size:12pt;">نموذج 6 مخازن</strong>
                                <span><strong>السنة المالية:</strong> <t t-esc="doc.fiscal_year"/></span>
                            </div>
                        </div>
                        <h2 style="text-align:center;text-decoration:underline;margin-bottom:12px;font-size:12pt;">
                            محضر جرد أصناف
                        </h2>

                        <!-- Session Info -->
                        <table style="width:100%;border-collapse:collapse;margin-bottom:12px;font-size:10pt;">
                            <tr>
                                <td style="border:1px solid #000;padding:5px;background:#f0f0f0;font-weight:bold;width:22%;">تاريخ الجرد</td>
                                <td style="border:1px solid #000;padding:5px;width:28%;"><t t-esc="doc.stocktaking_date"/></td>
                                <td style="border:1px solid #000;padding:5px;background:#f0f0f0;font-weight:bold;width:22%;">المستودع</td>
                                <td style="border:1px solid #000;padding:5px;width:28%;"><t t-esc="doc.warehouse_id.name"/></td>
                            </tr>
                            <tr>
                                <td style="border:1px solid #000;padding:5px;background:#f0f0f0;font-weight:bold;">رئيس لجنة الجرد</td>
                                <td style="border:1px solid #000;padding:5px;"><t t-esc="doc.committee_chairman_id.name if doc.committee_chairman_id else '........................'"/></td>
                                <td style="border:1px solid #000;padding:5px;background:#f0f0f0;font-weight:bold;">أمين المخزن</td>
                                <td style="border:1px solid #000;padding:5px;"><t t-esc="doc.storekeeper_id.name if doc.storekeeper_id else '........................'"/></td>
                            </tr>
                        </table>

                        <!-- Items Table — Form 6 format -->
                        <table style="width:100%;border-collapse:collapse;font-size:9.5pt;margin-bottom:12px;">
                            <thead>
                                <tr style="background:#c0c0c0;">
                                    <th style="border:1px solid #000;padding:6px;text-align:center;width:4%;">م</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;width:8%;">كود</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;width:22%;">اسم الصنف</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;width:7%;">الوحدة</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;width:10%;">الكمية بالسجلات</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;width:10%;">الكمية الفعلية</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;width:8%;">الفرق</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;width:7%;">السعر</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;width:10%;">قيمة الفرق</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;width:8%;">زيادة/عجز</th>
                                    <th style="border:1px solid #000;padding:6px;text-align:center;width:6%;">ملاحظات</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.line_ids" t-as="line">
                                    <tr t-att-style="'background:#e8f5e9;' if line.difference_type == 'surplus' else ('background:#ffebee;' if line.difference_type == 'deficit' else '')">
                                        <td style="border:1px solid #000;padding:4px;text-align:center;"><t t-esc="line_index + 1"/></td>
                                        <td style="border:1px solid #000;padding:4px;text-align:center;"><t t-esc="line.product_code or '—'"/></td>
                                        <td style="border:1px solid #000;padding:4px;"><t t-esc="line.product_id.name"/></td>
                                        <td style="border:1px solid #000;padding:4px;text-align:center;"><t t-esc="line.uom_id.name if line.uom_id else ''"/></td>
                                        <td style="border:1px solid #000;padding:4px;text-align:center;"><t t-esc="'%.2f' % line.system_qty"/></td>
                                        <td style="border:1px solid #000;padding:4px;text-align:center;font-weight:bold;"><t t-esc="'%.2f' % line.physical_qty"/></td>
                                        <td style="border:1px solid #000;padding:4px;text-align:center;font-weight:bold;">
                                            <t t-esc="'%.2f' % abs(line.difference_qty)"/>
                                        </td>
                                        <td style="border:1px solid #000;padding:4px;text-align:center;"><t t-esc="'%.2f' % line.standard_cost"/></td>
                                        <td style="border:1px solid #000;padding:4px;text-align:center;font-weight:bold;">
                                            <t t-esc="'%.2f' % abs(line.difference_value)"/>
                                        </td>
                                        <td style="border:1px solid #000;padding:4px;text-align:center;">
                                            <t t-if="line.difference_type == 'surplus'"><span style="color:green;font-weight:bold;">زيادة ↑</span></t>
                                            <t t-elif="line.difference_type == 'deficit'"><span style="color:red;font-weight:bold;">عجز ↓</span></t>
                                            <t t-else=""><span style="color:#555;">مطابق</span></t>
                                        </td>
                                        <td style="border:1px solid #000;padding:4px;font-size:8pt;"><t t-esc="line.notes or ''"/></td>
                                    </tr>
                                </t>
                            </tbody>
                            <!-- Totals row -->
                            <tfoot>
                                <tr style="background:#e0e0e0;font-weight:bold;">
                                    <td colspan="8" style="border:1px solid #000;padding:6px;text-align:center;">الإجمالي</td>
                                    <td style="border:1px solid #000;padding:6px;text-align:center;">
                                        <span style="color:green;">+<t t-esc="'%.2f' % doc.total_surplus_value"/></span> /
                                        <span style="color:red;">-<t t-esc="'%.2f' % doc.total_deficit_value"/></span>
                                    </td>
                                    <td colspan="2" style="border:1px solid #000;padding:6px;text-align:center;">
                                        ز: <t t-esc="doc.total_surplus_items"/> — ع: <t t-esc="doc.total_deficit_items"/>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Signature Block -->
                        <div style="margin-top:16px;font-weight:bold;text-decoration:underline;margin-bottom:10px;">توقيعات لجنة الجرد</div>
                        <table style="width:100%;border-collapse:collapse;">
                            <tr>
                                <td style="border:1px solid #000;padding:16px;text-align:center;width:33%;">
                                    <p style="font-weight:bold;margin:0;">رئيس اللجنة</p>
                                    <p style="margin:4px 0;"><t t-esc="doc.committee_chairman_id.name if doc.committee_chairman_id else '........................'"/></p>
                                    <p style="margin-top:25px;color:#555;">التوقيع: .........................</p>
                                </td>
                                <td style="border:1px solid #000;padding:16px;text-align:center;width:33%;">
                                    <p style="font-weight:bold;margin:0;">أعضاء اللجنة</p>
                                    <p style="margin:4px 0;font-size:9pt;white-space:pre-line;"><t t-esc="doc.committee_members or '........................'"/></p>
                                    <p style="margin-top:10px;color:#555;">التوقيع: .........................</p>
                                </td>
                                <td style="border:1px solid #000;padding:16px;text-align:center;width:33%;">
                                    <p style="font-weight:bold;margin:0;">أمين المخزن</p>
                                    <p style="margin:4px 0;"><t t-esc="doc.storekeeper_id.name if doc.storekeeper_id else '........................'"/></p>
                                    <p style="margin-top:25px;color:#555;">التوقيع: .........................</p>
                                </td>
                            </tr>
                        </table>
                        <div style="margin-top:10px;font-size:9pt;color:#777;text-align:center;border-top:1px solid #ccc;padding-top:6px;">
                            نظام أوبو إيآر بي — الديوان العام لمحافظة بورسعيد — محضر جرد أصناف نموذج 6 مخازن
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
