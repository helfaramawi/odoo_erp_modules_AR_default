<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══ Stocktaking Session Form ══════════════════════════════════════════ -->
    <record id="view_stocktaking_session_form" model="ir.ui.view">
        <field name="name">stock.stocktaking.session.form</field>
        <field name="model">stock.stocktaking.session</field>
        <field name="arch" type="xml">
            <form string="محضر جرد أصناف">
                <header>
                    <button name="action_load_stock"     string="تحميل المخزون الحالي"  type="object" class="btn-primary"   invisible="state != 'draft'"/>
                    <button name="action_post"           string="ترحيل الجرد ✓"          type="object" class="btn-primary"   invisible="state != 'counting'"/>
                    <button name="action_validate"       string="اعتماد الجرد"           type="object" class="btn-success"   invisible="state != 'done'"/>
                    <button name="action_print_form6"    string="طباعة نموذج 6"          type="object" class="btn-secondary" invisible="state == 'draft'"/>
                    <button name="action_print_surplus_deficit" string="كشف الزيادة والعجز" type="object" class="btn-secondary" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,counting,done,validated"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-arrow-up" invisible="total_surplus_items == 0">
                            <div class="o_stat_info">
                                <field name="total_surplus_items" class="o_stat_value"/>
                                <span class="o_stat_text" style="color:green">زيادة</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" icon="fa-arrow-down" invisible="total_deficit_items == 0">
                            <div class="o_stat_info">
                                <field name="total_deficit_items" class="o_stat_value"/>
                                <span class="o_stat_text" style="color:red">عجز</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group string="بيانات جلسة الجرد">
                        <group>
                            <field name="stocktaking_date"/>
                            <field name="fiscal_year"/>
                            <field name="warehouse_id"/>
                            <field name="location_id"/>
                        </group>
                        <group>
                            <field name="committee_chairman_id"/>
                            <field name="committee_members"/>
                            <field name="storekeeper_id"/>
                        </group>
                    </group>
                    <group string="ملخص الجرد" invisible="state == 'draft'">
                        <group>
                            <field name="total_items" readonly="1"/>
                            <field name="total_surplus_items" readonly="1"/>
                            <field name="total_deficit_items" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_surplus_value" readonly="1"/>
                            <field name="total_deficit_value" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="أصناف الجرد" name="lines">
                            <field name="line_ids" mode="tree">
                                <tree editable="bottom"
                                    decoration-success="difference_type == 'surplus'"
                                    decoration-danger="difference_type == 'deficit'"
                                    decoration-muted="difference_type == 'none'">
                                    <field name="product_id"/>
                                    <field name="product_code" optional="show"/>
                                    <field name="uom_id" readonly="1"/>
                                    <field name="system_qty" readonly="1"/>
                                    <field name="physical_qty"/>
                                    <field name="difference_qty" readonly="1"
                                        decoration-success="difference_qty &gt; 0"
                                        decoration-danger="difference_qty &lt; 0"/>
                                    <field name="standard_cost"/>
                                    <field name="difference_value" readonly="1"
                                        decoration-success="difference_value &gt; 0"
                                        decoration-danger="difference_value &lt; 0"/>
                                    <field name="difference_type" widget="badge"
                                        decoration-success="difference_type == 'surplus'"
                                        decoration-danger="difference_type == 'deficit'"
                                        decoration-muted="difference_type == 'none'"
                                        optional="show"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>
                        <page string="ملاحظات"><field name="notes"/></page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ══ List View ════════════════════════════════════════════════════════ -->
    <record id="view_stocktaking_session_list" model="ir.ui.view">
        <field name="name">stock.stocktaking.session.list</field>
        <field name="model">stock.stocktaking.session</field>
        <field name="arch" type="xml">
            <tree string="جلسات الجرد" decoration-success="state=='validated'" decoration-info="state=='counting'">
                <field name="name"/>
                <field name="stocktaking_date"/>
                <field name="fiscal_year"/>
                <field name="warehouse_id"/>
                <field name="total_items"/>
                <field name="total_surplus_items"/>
                <field name="total_deficit_items"/>
                <field name="total_surplus_value"/>
                <field name="total_deficit_value"/>
                <field name="state" widget="badge"
                    decoration-success="state in ['done','validated']"
                    decoration-info="state=='counting'"
                    decoration-muted="state=='draft'"/>
            </tree>
        </field>
    </record>

    <!-- ══ Action + Menu ════════════════════════════════════════════════════ -->
    <record id="action_stocktaking_session" model="ir.actions.act_window">
        <field name="name">جرد المخازن</field>
        <field name="res_model">stock.stocktaking.session</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">إنشاء جلسة جرد جديدة</p>
            <p>الجرد السنوي للمخازن الحكومية وفق نموذج 6 مخازن</p>
        </field>
    </record>

    <menuitem id="menu_stocktaking" name="الجرد الحكومي" parent="stock.menu_stock_warehouse_mgmt" sequence="25" action="action_stocktaking_session"/>
</odoo>
