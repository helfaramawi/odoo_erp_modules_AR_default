<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══ Inspection Report Form ════════════════════════════════════════════ -->
    <record id="view_inspection_report_form" model="ir.ui.view">
        <field name="name">stock.inspection.report.form</field>
        <field name="model">stock.inspection.report</field>
        <field name="arch" type="xml">
            <form string="محضر الفحص">
                <header>
                    <button name="action_validate" string="تحقق من الصحة ✓" type="object"
                        class="btn-primary" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group string="بيانات محضر الفحص">
                        <group>
                            <field name="picking_id"/>
                            <field name="purchase_order_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="reference_batch" required="1"/>
                        </group>
                        <group>
                            <field name="test_group" required="1"/>
                            <field name="inspection_qty" required="1"/>
                            <field name="approved_qty"/>
                            <field name="inspection_date"/>
                            <field name="inspector_id"/>
                        </group>
                    </group>
                    <group string="نتيجة الفحص">
                        <field name="result" widget="radio" options="{'horizontal': true}"/>
                        <field name="rejection_reason" invisible="result == 'pass'" placeholder="سبب الرفض أو الملاحظات..."/>
                    </group>
                    <group string="إذن الإضافة المرتبط" invisible="not addition_permit_id">
                        <field name="addition_permit_id" readonly="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_inspection_report_list" model="ir.ui.view">
        <field name="name">stock.inspection.report.list</field>
        <field name="model">stock.inspection.report</field>
        <field name="arch" type="xml">
            <tree string="محاضر الفحص" decoration-success="state=='done'" decoration-danger="state=='rejected'">
                <field name="name"/>
                <field name="picking_id"/>
                <field name="purchase_order_id"/>
                <field name="partner_id"/>
                <field name="reference_batch"/>
                <field name="inspection_qty"/>
                <field name="approved_qty"/>
                <field name="inspection_date"/>
                <field name="result" widget="badge" decoration-success="result=='pass'" decoration-danger="result=='fail'"/>
                <field name="state" widget="badge" decoration-success="state=='done'" decoration-danger="state=='rejected'"/>
            </tree>
        </field>
    </record>

    <record id="action_inspection_report" model="ir.actions.act_window">
        <field name="name">محاضر الفحص</field>
        <field name="res_model">stock.inspection.report</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ══ Addition Permit Form ══════════════════════════════════════════════ -->
    <record id="view_addition_permit_form" model="ir.ui.view">
        <field name="name">stock.addition.permit.form</field>
        <field name="model">stock.addition.permit</field>
        <field name="arch" type="xml">
            <form string="إذن إضافة">
                <header>
                    <button name="action_post"   string="ترحيل إذن الإضافة" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="إلغاء" type="object" invisible="state != 'draft'"/>
                    <button name="action_print_form1" string="طباعة نموذج 1" type="object" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group string="بيانات إذن الإضافة">
                        <group>
                            <field name="permit_date"/>
                            <field name="partner_id" required="1"/>
                            <field name="purchase_order_id"/>
                            <field name="picking_id"/>
                            <field name="inspection_report_id"/>
                        </group>
                        <group>
                            <field name="product_id" required="1"/>
                            <field name="qty" required="1"/>
                            <field name="uom_id" readonly="1"/>
                            <field name="warehouse_id" required="1"/>
                            <field name="location_id" required="1"/>
                            <field name="site_id"/>
                            <field name="storekeeper_id"/>
                        </group>
                    </group>
                    <group string="ملاحظات">
                        <field name="notes" nolabel="1" placeholder="ملاحظات..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_addition_permit_list" model="ir.ui.view">
        <field name="name">stock.addition.permit.list</field>
        <field name="model">stock.addition.permit</field>
        <field name="arch" type="xml">
            <tree string="أذونات الإضافة" decoration-success="state=='posted'">
                <field name="name"/>
                <field name="permit_date"/>
                <field name="partner_id"/>
                <field name="purchase_order_id"/>
                <field name="product_id"/>
                <field name="qty"/>
                <field name="uom_id"/>
                <field name="warehouse_id"/>
                <field name="state" widget="badge" decoration-success="state=='posted'" decoration-muted="state=='cancel'"/>
            </tree>
        </field>
    </record>

    <record id="action_addition_permit" model="ir.actions.act_window">
        <field name="name">أذونات الإضافة</field>
        <field name="res_model">stock.addition.permit</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_addition_permit_root" name="أذونات الإضافة" sequence="88"
              web_icon="stock_addition_permit,static/description/icon.png"/>
    <menuitem id="menu_addition_permit" name="أذونات الإضافة" parent="menu_addition_permit_root" action="action_addition_permit" sequence="10"/>
    <menuitem id="menu_inspection_reports" name="محاضر الفحص" parent="menu_addition_permit_root" action="action_inspection_report" sequence="20"/>
</odoo>
