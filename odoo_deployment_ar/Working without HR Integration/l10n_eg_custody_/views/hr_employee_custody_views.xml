<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_custody_inherit" model="ir.ui.view">
        <field name="name">hr.employee.custody.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_custody" type="object"
                    class="oe_stat_button" icon="fa-archive"
                    invisible="custody_count == 0">
                    <div class="o_stat_info">
                        <field name="custody_count" class="o_stat_value"/>
                        <span class="o_stat_text">عهدة نشطة</span>
                    </div>
                </button>
                <button name="action_view_custody" type="object"
                    class="oe_stat_button" icon="fa-exclamation-triangle"
                    invisible="not has_overdue_custody">
                    <div class="o_stat_info">
                        <span class="o_stat_value" style="color:red;">!</span>
                        <span class="o_stat_text" style="color:red;">متأخرة</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="العهد" name="custody_page"
                      invisible="custody_count == 0">
                    <group string="ملخص العهد النشطة">
                        <group>
                            <field name="custody_count" readonly="1"/>
                            <field name="custody_value_total" readonly="1"/>
                            <field name="has_overdue_custody" readonly="1"/>
                        </group>
                    </group>
                    <div>
                        <button name="action_view_custody" type="object"
                            string="عرض جميع العهد" class="btn btn-primary btn-sm"/>
                        <button name="action_view_custody_transfers" type="object"
                            string="تحويلات العهدة" class="btn btn-secondary btn-sm"
                            style="margin-right:8px;"/>
                    </div>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Department custody grouping action -->
    <record id="action_custody_by_department" model="ir.actions.act_window">
        <field name="name">العهد حسب الإدارة</field>
        <field name="res_model">custody.assignment</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'group_by': 'employee_department_id'}</field>
        <field name="domain">[('state', 'in', ['active', 'transferred'])]</field>
    </record>

    <menuitem id="menu_custody_by_dept"
              name="العهد حسب الإدارة"
              parent="l10n_eg_custody.menu_custody_root"
              action="action_custody_by_department"
              sequence="20"/>

    <!-- GAFI Audit Report -->
    <record id="action_gafi_custody_audit" model="ir.actions.act_window">
        <field name="name">تقرير GAFI - أرباب العهد</field>
        <field name="res_model">custody.assignment</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', 'in', ['active', 'transferred'])]</field>
        <field name="context">{'group_by': 'employee_id'}</field>
    </record>

    <menuitem id="menu_gafi_audit"
              name="تقرير GAFI - أرباب العهد"
              parent="l10n_eg_custody.menu_custody_root"
              action="action_gafi_custody_audit"
              sequence="30"/>
</odoo>
