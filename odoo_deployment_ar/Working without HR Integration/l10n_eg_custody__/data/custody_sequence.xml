<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_custody_assignment" model="ir.sequence">
        <field name="name">تسلسل رقم العهدة</field>
        <field name="code">custody.assignment</field>
        <field name="prefix">EHD/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
        <field name="use_date_range">True</field>
    </record>
    <record id="seq_custody_transfer" model="ir.sequence">
        <field name="name">تسلسل رقم تحويل العهدة</field>
        <field name="code">custody.transfer</field>
        <field name="prefix">TEHD/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
    </record>
</odoo>
