<odoo>
    <record id="view_war_finance_control_tree" model="ir.ui.view">
        <field name="name">war.finance.control.tree</field>
        <field name="model">war.finance.control</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="company_id"/>
                <field name="journal_threshold"/>
                <field name="currency_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_war_finance_control_form" model="ir.ui.view">
        <field name="name">war.finance.control.form</field>
        <field name="model">war.finance.control</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="company_id"/>
                        <field name="journal_threshold"/>
                        <field name="currency_id" readonly="1"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_war_finance_control" model="ir.actions.act_window">
        <field name="name">Finance Controls</field>
        <field name="res_model">war.finance.control</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_war_finance_control" name="Finance Controls" parent="d365_war_base.menu_war_room_root" action="action_war_finance_control" sequence="30" groups="d365_war_base.group_war_room_manager"/>
</odoo>
